/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(3-(octyloxy)propyl)propane-1,3-diamine  (C14H32N2O, CAS 68123-06-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3OctyloxyPropylPropane13Diamine;
formula     C14H32N2O;
CAS         68123-06-8;
InChIKey    PLVXZTCCPYSWNN-UHFFFAOYSA-N;
MW          244.423;      // g/mol [origin=calculated method=formula-sum]
Tc          837.93;      // K   [origin=predictive method=joback]
Pc          15.885;      // bar [origin=predictive method=joback]
omega       1.0359;      // -   [origin=predictive method=lee-kesler]
Tb          665.04;      // K   [origin=predictive method=joback]
HvapTb      66245.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.943 1.40872 -0.0007188 1.221e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH2O; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group O; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(3-octoxypropyl)propane-1,3-diamine" "n-(3-octyloxypropyl)-1,3-propanediamine" "1,3-propanediamine, n-(3-(octyloxy)propyl)-" "1,3-propanediamine, n-[3-(octyloxy)propyl]-" "1,3-propanediamine, n1-(3-(octyloxy)propyl)-" "1,3-propanediamine, n1-[3-(octyloxy)propyl]-" "n-(3-octyloxypropyl)-1,3-propylenediamine" "1,3-propanediamine,n1-[3-(octyloxy)propyl]-" "n-(3-octyloxy-n-propyl)-1,3-propylenediamine" "n-(3-octyloxy-n-propyl)-1,3-propylenediamine;" );
gibbsFormation
{
    dHf_298   -377250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     804.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117840.0
    phase     gas;
}
