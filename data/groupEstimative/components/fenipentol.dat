/*--------------------------------*- Choupo -*-----------------------*\
  Component: fenipentol  (C11H16O, CAS 583-03-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fenipentol;
formula     C11H16O;
CAS         583-03-9;
InChIKey    OVGORFFCBUIFIA-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          763.57;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.8738;      // -   [origin=predictive method=lee-kesler]
Tb          569.70;      // K   [origin=predictive method=joback]
HvapTb      58647.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.407 1.00982 -0.0006394 1.545e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylpentan-1-ol" "1-phenyl-1-pentanol" "pancoral" "suiclisin" "1-phenylpentanol" "alpha-butylbenzyl alcohol" "phenylbutylcarbinol" "phenylpentanol" "benzenemethanol, .alpha.-butyl-" "fenipentol(jan)" "1-pentanol, 1-phenyl-" "1-phenyl-1-hydroxypentane" );
gibbsFormation
{
    dHf_298   -191350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14890.0
    phase     gas;
}
