/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl pyruvate  (C4H6O3, CAS 600-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylPyruvate;
formula     C4H6O3;
CAS         600-22-6;
InChIKey    CWKLZLBVOJRSOM-UHFFFAOYSA-N;
MW          102.089;      // g/mol [origin=calculated method=formula-sum]
Tc          591.88;      // K   [origin=predictive method=joback]
Pc          42.496;      // bar [origin=predictive method=joback]
omega       0.4786;      // -   [origin=predictive method=lee-kesler]
Tb          403.21;      // K   [origin=predictive method=joback]
HvapTb      38651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.02 0.30104 -8.05e-05 -2.974e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-oxidanylidenepropanoate" "methyl 2-oxopropanoate" "pyruvic acid, methyl ester" "methylpyruvate" "pyruvic acid methyl ester" "methyl 2-oxopropionate" "propanoic acid, 2-oxo-, methyl ester" "methylglyoxylic acid methyl ester" "pyruvic acid methylester" "2-oxopropanoic acid methyl ester" "2-oxo-propionic acid methyl ester" "propanoic acid, 2-oxo-,methyl ester" );
gibbsFormation
{
    dHf_298   -555750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-456490.0
    phase     gas;
}
