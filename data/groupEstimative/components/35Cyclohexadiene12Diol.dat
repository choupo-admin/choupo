/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-cyclohexadiene-1,2-diol  (C6H8O2, CAS 75453-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Cyclohexadiene12Diol;
formula     C6H8O2;
CAS         75453-80-4;
InChIKey    YDRSQRPHLBEPTP-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          722.19;      // K   [origin=predictive method=joback]
Pc          53.592;      // bar [origin=predictive method=joback]
omega       1.1395;      // -   [origin=predictive method=lee-kesler]
Tb          534.44;      // K   [origin=predictive method=joback]
HvapTb      63012.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.09 0.6254 -0.00036356 6.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=CH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexa-3,5-diene-1,2-diol" "benzene cis-glycol" "cis-1,2-dihydrocatechol" "benzene dihydrodiol" "5,6-dihydroxycyclohexa-1,3-diene" "1,2-dihydrobenzene-1,2-diol" "1,2-dihydro-1,2-dihydroxybenzene" );
standardThermochemistry
{
    dHf_298   -322090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     343.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197340.0
}
