/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(3-aminophenyl)imino]diethane-2,1-diyl dibenzoate  (C24H24N2O4, CAS 65059-89-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3AminophenylIminoDiethane21DiylDibenzoate;
formula     C24H24N2O4;
CAS         65059-89-4;
InChIKey    HVBRMCOTFDAFOM-UHFFFAOYSA-N;
MW          404.466;      // g/mol [origin=calculated method=formula-sum]
Tc          1282.24;      // K   [origin=predictive method=joback]
Pc          16.272;      // bar [origin=predictive method=joback]
omega       1.2540;      // -   [origin=predictive method=lee-kesler]
Tb          1035.15;      // K   [origin=predictive method=joback]
HvapTb      104006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.726 2.0638 -0.00127516 2.602e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 14; } { group AC; count 3; } { group CH2N; count 1; } { group ACNH2; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group COO; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(3-aminophenyl)-[2-(phenylcarbonyloxy)ethyl]amino]ethyl benzoate" "ethanol, 2,2'-((3-aminophenyl)imino)bis-, 1,1'-dibenzoate" "ethanol, 2,2'-((3-aminophenyl)imino)bis-, dibenzoate (ester)" "ethanol, 2,2'-[(3-aminophenyl)imino]bis-, 1,1'-dibenzoate" "ethanol, 2,2'-[(3-aminophenyl)imino]bis-, dibenzoate (ester)" "(3-aminophenyl)diethanolamine dibenzoate" "2-[3-amino-n-(2-benzoyloxyethyl)anilino]ethyl benzoate" );
standardThermochemistry
{
    dHf_298   -373810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     935.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35290.0
}
