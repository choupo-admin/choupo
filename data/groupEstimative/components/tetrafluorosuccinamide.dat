/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrafluorosuccinamide  (C4H4F4N2O2, CAS 377-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrafluorosuccinamide;
formula     C4H4F4N2O2;
CAS         377-37-7;
InChIKey    MYWRUVWOYAPWLT-UHFFFAOYSA-N;
MW          188.08;      // g/mol [origin=calculated method=formula-sum]
Tc          735.52;      // K   [origin=predictive method=joback]
Pc          44.208;      // bar [origin=predictive method=joback]
omega       0.8886;      // -   [origin=predictive method=lee-kesler]
Tb          534.54;      // K   [origin=predictive method=joback]
HvapTb      53412.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.37 0.7504 -0.0006524 2.0652e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF2; count 2; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group F; count 4; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3-tetrakis(fluoranyl)butanediamide" "2,2,3,3-tetrafluorobutanediamide" "1,1,2,2-tetrafluoroethane-1,2-dicarboxamide" "tetrafluorobutanediamide" "butanediamide,n1,n1,n4,n4,2,2,3,3-octafluoro-" "butanediamide,octafluoro- (9ci); succinamide, octafluoro- (8ci); perfluorosuccinamide" );
gibbsFormation
{
    dHf_298   -1085410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-915700.0
    phase     gas;
}
