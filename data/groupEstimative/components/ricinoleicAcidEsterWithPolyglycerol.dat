/*--------------------------------*- Choupo -*-----------------------*\
  Component: ricinoleic acid, ester with polyglycerol  (C21H42O6, CAS 68936-89-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ricinoleicAcidEsterWithPolyglycerol;
formula     C21H42O6;
CAS         68936-89-0;
InChIKey    CJJXHKDWGQADHB-DPMBMXLASA-N;
MW          390.561;      // g/mol [origin=calculated method=formula-sum]
Tc          1588.69;      // K   [origin=predictive method=joback]
Pc          12.782;      // bar [origin=predictive method=joback]
omega       0.4680;      // -   [origin=predictive method=lee-kesler]
Tb          1198.99;      // K   [origin=predictive method=joback]
HvapTb      145696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.835 2.01122 -0.0009882 1.351e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 2; } { group CH=CH; count 1; } { group OH; count 4; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 2; } { group dCH; count 2; } { group OH; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z,12r)-12-oxidanyloctadec-9-enoic acid;propane-1,2,3-triol" "1,2,3-propanetriol, homopolymer, (9z,12r)-12-hydroxy-9-octadecenoate" "(z,12r)-12-hydroxyoctadec-9-enoic acid; propane-1,2,3-triol" );
gibbsFormation
{
    dHf_298   -1440920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1312.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-794670.0
    phase     gas;
}
