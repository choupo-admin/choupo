/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetostearin  (C23H44O5, CAS 27177-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetostearin;
formula     C23H44O5;
CAS         27177-85-1;
InChIKey    RGGBUUSHDAWGIN-UHFFFAOYSA-N;
MW          400.6;      // g/mol [origin=calculated method=formula-sum]
Tc          1150.93;      // K   [origin=predictive method=joback]
Pc          9.094;      // bar [origin=predictive method=joback]
omega       0.8123;      // -   [origin=predictive method=lee-kesler]
Tb          934.02;      // K   [origin=predictive method=joback]
HvapTb      97897.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.408 2.11914 -0.0010718 1.576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH; count 1; } { group OH; count 1; } { group CH3COO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group CH; count 1; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-acetyloxy-2-oxidanyl-propyl) octadecanoate" "acetomonostearin" "stearin, aceto-" "glycerol monoacetate monostearate" "(3-acetyloxy-2-hydroxypropyl) octadecanoate" "1,2,3-propanetriol monoacetate monoctadecanoate" "octdecanoic acid, monester with 1,2,3-propanetriol monoacetate" "octadecanoic acid, monoester with 1,2,3-propanetriol monoacetate" );
standardThermochemistry
{
    dHf_298   -1310120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1195.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-617220.0
}
