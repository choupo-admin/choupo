/*--------------------------------*- Choupo -*-----------------------*\
  Component: butoxypentachlorobenzene  (C10H9Cl5O, CAS 90842-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butoxypentachlorobenzene;
formula     C10H9Cl5O;
CAS         90842-58-3;
InChIKey    WZEKHHYDVVXEED-UHFFFAOYSA-N;
MW          322.431;      // g/mol [origin=calculated method=formula-sum]
Tc          918.22;      // K   [origin=predictive method=joback]
Pc          22.166;      // bar [origin=predictive method=joback]
omega       0.7604;      // -   [origin=predictive method=lee-kesler]
Tb          689.55;      // K   [origin=predictive method=joback]
HvapTb      67775.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (121.343 0.54822 -0.0002072 -1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group AC; count 1; } { group CH2O; count 1; } { group ACCl; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dC_ring; count 6; } { group Cl; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butoxy-2,3,4,5,6-pentakis(chloranyl)benzene" "benzene, butoxypentachloro-" "pentachlorophenyl butyl ether" "ether, butyl pentachlorophenyl (6ci,7ci)" "1-butoxy-2,3,4,5,6-pentachlorobenzene" );
standardThermochemistry
{
    dHf_298   -281470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67070.0
}
