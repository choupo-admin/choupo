/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodobicyclo[2.2.1]hexane  (C6H9I, CAS 74725-75-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodobicyclo221Hexane;
formula     C6H9I;
CAS         74725-75-0;
InChIKey    OMMNMGTXQRHKPX-UHFFFAOYSA-N;
MW          208.038;      // g/mol [origin=calculated method=formula-sum]
Tc          692.27;      // K   [origin=predictive method=joback]
Pc          43.800;      // bar [origin=predictive method=joback]
omega       0.2398;      // -   [origin=predictive method=lee-kesler]
Tb          443.74;      // K   [origin=predictive method=joback]
HvapTb      36998.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.35 1.2065 -0.001357 5.967e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-iodanylbicyclo[2.1.1]hexane" "4-iodobicyclo[2.1.1]hexane" "bicyclo[2.1.1]hexane,1-iodo-" "bicyclo(2.1.1)hexane, 1-iodo-" );
gibbsFormation
{
    dHf_298   70540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173770.0
    phase     gas;
}
