/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetylthiophene  (C6H6OS, CAS 88-15-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetylthiophene;
formula     C6H6OS;
CAS         88-15-3;
InChIKey    WYJOVVXUZNRJQY-UHFFFAOYSA-N;
MW          126.173;      // g/mol [origin=calculated method=formula-sum]
Tc          694.46;      // K   [origin=predictive method=joback]
Pc          46.466;      // bar [origin=predictive method=joback]
omega       0.4014;      // -   [origin=predictive method=lee-kesler]
Tb          461.83;      // K   [origin=predictive method=joback]
HvapTb      43320.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.95 0.54693 -0.00039292 1.1116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-thiophen-2-ylethanone" "1-(2-thienyl)ethanone" "methyl 2-thienyl ketone" "2-acetothienone" "ethanone, 1-(2-thienyl)-" "2-acetothiophene" "ketone, methyl 2-thienyl" "2-aceto thiophene" "1-thiophen-2-yl-ethanone" "2-thienyl methyl ketone" "alpha-acetylthiophene" "methyl-2-thienyl ketone" );
gibbsFormation
{
    dHf_298   -49580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5130.0
    phase     gas;
}
