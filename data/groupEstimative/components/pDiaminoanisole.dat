/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-diaminoanisole  (C7H10N2O, CAS 5307-02-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pDiaminoanisole;
formula     C7H10N2O;
CAS         5307-02-8;
InChIKey    HGUYBLVGLMAUFF-UHFFFAOYSA-N;
MW          138.17;      // g/mol [origin=calculated method=formula-sum]
Tc          800.69;      // K   [origin=predictive method=joback]
Pc          44.922;      // bar [origin=predictive method=joback]
omega       0.6830;      // -   [origin=predictive method=lee-kesler]
Tb          563.88;      // K   [origin=predictive method=joback]
HvapTb      58468.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.7 0.53152 -0.00022992 1.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH3O; count 1; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxybenzene-1,4-diamine" "2-methoxy-p-phenylenediamine" "2,5-diaminoanisole" "2-mppd" "1,4-benzenediamine, 2-methoxy-" "p-phenylenediamine, 2-methoxy-" "2-methoxy-1,4-benzenediamine" "1,4-diamino-2-methoxybenzene" );
standardThermochemistry
{
    dHf_298   -38860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=129110.0
}
