/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, (chloromethyl)ethoxydimethyl-  (C5H13ClOSi, CAS 13508-53-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H13ClOSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneChloromethylEthoxydimethyl;
formula     C5H13ClOSi;
CAS         13508-53-7;
InChIKey    IGMQAYXTTRYCPZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          152.693;      // g/mol [origin=calculated method=formula-sum]
Tc          555.02;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.2916;      // -   [origin=predictive method=lee-kesler]
Tb          375.25;      // K   [origin=predictive method=joback]
HvapTb      33813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.552 0.21626 0.0002572 -2.147e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2O; count 1; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl-ethoxy-dimethyl-silane" "(chloromethyl)dimethylethoxysilane" "(chloromethyl)ethoxydimethylsilane" "chloromethyl-ethoxy-dimethylsilane" "silane, dimethylchloromethylethoxy-" "dimethyl-chlormethyl-ethoxysilan" "silane, (dimethyl(chloromethyl)ethoxy)-" "silane, [dimethyl(chloromethyl)ethoxy]-" "silane,(chloromethyl)ethoxydimethyl-" );
gibbsFormation
{
    dHf_298   -406110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230470.0
    phase     gas;
}
