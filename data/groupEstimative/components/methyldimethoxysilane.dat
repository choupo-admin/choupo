/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyldimethoxysilane  (C3H9O2Si, CAS 16881-77-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3H9O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methyldimethoxysilane;
formula     C3H9O2Si;
CAS         16881-77-9;
InChIKey    PKTOVQRKCNPVKY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          105.188;      // g/mol [origin=calculated method=formula-sum]
Tc          481.64;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.2537;      // -   [origin=predictive method=lee-kesler]
Tb          313.78;      // K   [origin=predictive method=joback]
HvapTb      27239.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.57 0.05936 0.00029 -1.937e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethoxy(methyl)silicon" "dimethoxy(methyl)silane" "silane, dimethoxymethyl-" "dimethoxymethylsilane" "methyl dimethoxysilane" "i516" );
standardThermochemistry
{
    dHf_298   -425500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-288000.0
}
