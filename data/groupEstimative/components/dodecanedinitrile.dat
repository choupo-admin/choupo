/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecanedinitrile  (C12H20N2, CAS 4543-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecanedinitrile;
formula     C12H20N2;
CAS         4543-66-2;
InChIKey    AVQYXBDAZWIFTO-UHFFFAOYSA-N;
MW          192.306;      // g/mol [origin=calculated method=formula-sum]
Tc          870.70;      // K   [origin=predictive method=joback]
Pc          17.075;      // bar [origin=predictive method=joback]
omega       0.9031;      // -   [origin=predictive method=lee-kesler]
Tb          678.32;      // K   [origin=predictive method=joback]
HvapTb      63262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.98 1.0134 -0.000567 1.19e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,10-dicyanodecane" "decamethylenedinitrile" "dodecanodinitrile" "1,12-dodecanedinitrile" "1,10-decamethylenedinitrile" "decamethylene dicyanide" "dodecandinitril" "decane-1,10-dicarbonitrile" );
gibbsFormation
{
    dHf_298   38750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=316520.0
    phase     gas;
}
