/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl phenyl sulfide  (C13H12S, CAS 831-91-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylPhenylSulfide;
formula     C13H12S;
CAS         831-91-4;
InChIKey    LKMCJXXOBRCATQ-UHFFFAOYSA-N;
MW          200.299;      // g/mol [origin=calculated method=formula-sum]
Tc          883.97;      // K   [origin=predictive method=joback]
Pc          31.315;      // bar [origin=predictive method=joback]
omega       0.4935;      // -   [origin=predictive method=lee-kesler]
Tb          619.18;      // K   [origin=predictive method=joback]
HvapTb      55901.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.139 1.07539 -0.0007056 1.669e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethylsulfanyl)benzene" "benzylthiobenzene" "benzylsulfanylbenzene" "benzyl(phenyl)sulfane" "phenyl benzyl sulfide" "benzene, [(phenylmethyl)thio]-" "(benzylsulfanyl)benzene" "(phenylmethylthio)benzene" "benzyl-phenyl sulfide" "benzyl phenyl sulphide" "sulfide, benzyl phenyl" "1,2-diphenyl-1-thiaethane" );
gibbsFormation
{
    dHf_298   203280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=316520.0
    phase     gas;
}
