/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-Dimethylphenol  (C8H10O, CAS 108-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethylphenol;
formula     C8H10O;
CAS         108-68-9;
InChIKey    TUAMRELNJMMDMT-UHFFFAOYSA-N;
MW          122.167;      // g/mol [origin=calculated method=formula-sum]
Tc          722.32;      // K   [origin=predictive method=joback]
Pc          43.226;      // bar [origin=predictive method=joback]
omega       0.5140;      // -   [origin=predictive method=lee-kesler]
Tb          494.92;      // K   [origin=predictive method=joback]
HvapTb      49354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.91 0.78004 -0.00063192 2.177e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-xylenol" "1-hydroxy-3,5-dimethylbenzene" "3,5-xylenol" "phenol, 3,5-dimethyl-" "sym-m-xylenol" "3,5-dmp" "5-hydroxy-m-xylene" "xylenol 200" "3,5-dimethyl phenol" "CCRIS 724" "benzene, 1,3-dimethyl-5-hydroxy-" "3,5-dimethyl-phenol" );
standardThermochemistry
{
    dHf_298   -160700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-35360.0
}
