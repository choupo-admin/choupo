/*--------------------------------*- Choupo -*-----------------------*\
  Component: lefetamine  (C16H19N, CAS 7262-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lefetamine;
formula     C16H19N;
CAS         7262-75-1;
InChIKey    YEJZJVJJPVZXGX-MRXNPFEDSA-N;
MW          225.335;      // g/mol [origin=calculated method=formula-sum]
Tc          862.27;      // K   [origin=predictive method=joback]
Pc          22.981;      // bar [origin=predictive method=joback]
omega       0.5999;      // -   [origin=predictive method=lee-kesler]
Tb          631.04;      // K   [origin=predictive method=joback]
HvapTb      57417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.839 1.49584 -0.0010248 2.671e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 10; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r)-n,n-dimethyl-1,2-diphenyl-ethanamine" "lefetamina" "lefetaminum" "lephetamine" "n,n-dimethyl-1,2-diphenylethanamine" "lefetamine [inn]" "lefetaminum [inn-latin]" "1-dimethylamino-1,2-diphenylethane" "(-)-n,n-dimethyl-1,2-diphenylethylamine" "(1r)-n,n-dimethyl-1,2-diphenylethanamine" "benzeneethanamine, n,n-dimethyl-alpha-phenyl-, (r)-" "ethylamine, n,n-dimethyl-1,2-diphenyl-, (-)-" );
standardThermochemistry
{
    dHf_298   161740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=417000.0
}
