/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropyl-1,3-dithiolane  (C6H12S2, CAS 26733-24-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropyl13Dithiolane;
formula     C6H12S2;
CAS         26733-24-4;
InChIKey    CMOLCULWXQDIMM-UHFFFAOYSA-N;
MW          148.282;      // g/mol [origin=calculated method=formula-sum]
Tc          682.73;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.2741;      // -   [origin=predictive method=lee-kesler]
Tb          447.38;      // K   [origin=predictive method=joback]
HvapTb      40443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.09 0.74026 -0.0004706 1.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-yl-1,3-dithiolane" "1,3-dithiolane, 2-isopropyl-" "2-isopropyl-[1,3]dithiolane" "2-(propan-2-yl)-1,3-dithiolane" );
gibbsFormation
{
    dHf_298   -21450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113470.0
    phase     gas;
}
