/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenylsilane  (C12H10Si, CAS 775-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H10Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diphenylsilane;
formula     C12H10Si;
CAS         775-12-2;
InChIKey    BPYFPNZHLXDIGA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          182.297;      // g/mol [origin=calculated method=formula-sum]
Tc          777.48;      // K   [origin=predictive method=joback]
Pc          33.029;      // bar [origin=predictive method=joback]
omega       0.3623;      // -   [origin=predictive method=lee-kesler]
Tb          527.52;      // K   [origin=predictive method=joback]
HvapTb      46858.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.83 0.986 -0.0006914 1.826e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diphenylsilicon" "silane, diphenyl-" "benzene, 1,1'-silylenebis-" "di(phenyl)silicon" );
gibbsFormation
{
    dHf_298   182050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=274980.0
    phase     gas;
}
