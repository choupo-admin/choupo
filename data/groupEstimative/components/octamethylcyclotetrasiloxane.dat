/*--------------------------------*- Choupo -*-----------------------*\
  Component: octamethylcyclotetrasiloxane  (C8H24O4Si4, CAS 556-67-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H24O4Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        octamethylcyclotetrasiloxane;
formula     C8H24O4Si4;
CAS         556-67-2;
InChIKey    HMMGMWAXVFQUOA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          296.616;      // g/mol [origin=calculated method=formula-sum]
Tc          723.20;      // K   [origin=predictive method=joback]
Pc          18.676;      // bar [origin=predictive method=joback]
omega       0.3140;      // -   [origin=predictive method=lee-kesler]
Tb          511.72;      // K   [origin=predictive method=joback]
HvapTb      53012.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (166.87 0.09496 0.0010742 -7.22e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4,6,6,8,8-octamethyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "cyclotetrasiloxane, octamethyl-" "oktamethylcyklotetrasiloxan" "omcts" "cyclic dimethylsiloxane tetramer" "oktamethylzyklotetrasiloxan" "2,2,4,4,6,6,8,8-octamethyl-1,3,5,7,2,4,6,8-tetroxatetrasilocane" "cyclotetrasiloxane, 2,2,4,4,6,6,8,8-octamethyl-" "agn-pc-03w6nd" "dimethylsiloxane cyclic tetramer" "hmmgmwaxvfquoa-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -1095950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     740.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-690680.0
    phase     gas;
}
