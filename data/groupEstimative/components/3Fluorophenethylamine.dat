/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-fluorophenethylamine  (C8H10FN, CAS 404-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Fluorophenethylamine;
formula     C8H10FN;
CAS         404-70-6;
InChIKey    AUCVZEYHEFAWHO-UHFFFAOYSA-N;
MW          139.173;      // g/mol [origin=calculated method=formula-sum]
Tc          698.65;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.5224;      // -   [origin=predictive method=lee-kesler]
Tb          486.10;      // K   [origin=predictive method=joback]
HvapTb      46164.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.408 0.6991 -0.00043536 1.012e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group CH2NH2; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-fluorophenyl)ethanamine" "2-(3-fluorophenyl)ethylamine" "2-(3-fluoro-phenyl)-ethylamine" "2-(3-fluorophenyl)ethan-1-amine" "benzeneethanamine, 3-fluoro-" "phenethylamine,m-fluoro- (8ci);2-(3-fluorophenyl)ethanamine;2-(3-fluorophenyl)ethylamine;3-fluorobenzeneethanamine;m-fluorophenylethylamine;" );
gibbsFormation
{
    dHf_298   -145710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9100.0
    phase     gas;
}
