/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-decyn-1-yl tetrahydropyranyl ether  (C15H26O2, CAS 51652-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Decyn1YlTetrahydropyranylEther;
formula     C15H26O2;
CAS         51652-45-0;
InChIKey    UCIRGAWKROSICQ-UHFFFAOYSA-N;
MW          238.371;      // g/mol [origin=calculated method=formula-sum]
Tc          824.72;      // K   [origin=predictive method=joback]
Pc          18.595;      // bar [origin=predictive method=joback]
omega       0.6733;      // -   [origin=predictive method=lee-kesler]
Tb          620.72;      // K   [origin=predictive method=joback]
HvapTb      58485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.973 1.33492 -0.00065616 9.238e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group tC; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-dec-5-ynoxyoxane" "2-(5-decynyloxy)tetrahydro-2h-pyran" "2h-pyran, 2-(5-decynyloxy)tetrahydro-" "2h-pyran, 2-(5-decyn-1-yloxy)tetrahydro-" "2h-pyran,2-(5-decyn-1-yloxy)tetrahydro-" "2h-pyran,2-(5-decynyloxy)tetrahydro- (9ci); 5-decyn-1-yl 2-tetrahydropyranyl ether" );
gibbsFormation
{
    dHf_298   -290530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=111550.0
    phase     gas;
}
