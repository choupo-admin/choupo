/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(bis(2-hydroxyethyl)amino)ethyl octadecanoate  (C24H49NO4, CAS 10248-74-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bis2HydroxyethylAminoEthylOctadecanoate;
formula     C24H49NO4;
CAS         10248-74-5;
InChIKey    FVIMRJIDRHUTQP-UHFFFAOYSA-N;
MW          415.659;      // g/mol [origin=calculated method=formula-sum]
Tc          1268.93;      // K   [origin=predictive method=joback]
Pc          8.991;      // bar [origin=predictive method=joback]
omega       0.5677;      // -   [origin=predictive method=lee-kesler]
Tb          1003.74;      // K   [origin=predictive method=joback]
HvapTb      111826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.372 2.42092 -0.0013606 2.743e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 20; } { group OH; count 2; } { group CH2COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 22; } { group OH; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]ethyl octadecanoate" "2-(bis(2-hydroxyethyl)amino)ethyl stearate" "octadecanoic acid, 2-[bis(2-hydroxyethyl)amino]ethyl ester" "octadecanoic acid, 2-(bis(2-hydroxyethyl)amino)ethyl ester" );
standardThermochemistry
{
    dHf_298   -1092900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1259.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-322030.0
}
