/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-difluoroanisole  (C7H6F2O, CAS 115144-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Difluoroanisole;
formula     C7H6F2O;
CAS         115144-40-6;
InChIKey    DSEVNUCNUTYYHW-UHFFFAOYSA-N;
MW          144.12;      // g/mol [origin=calculated method=formula-sum]
Tc          608.54;      // K   [origin=predictive method=joback]
Pc          34.765;      // bar [origin=predictive method=joback]
omega       0.4315;      // -   [origin=predictive method=lee-kesler]
Tb          417.36;      // K   [origin=predictive method=joback]
HvapTb      35552.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.9 0.43132 -0.00017592 4.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH3O; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(fluoranyl)-4-methoxy-benzene" "1,2-difluoro-4-methoxybenzene" "1,2-difluoro-4-methoxy-benzene" "1,2-difluor-4-methoxybenzol" "3,4-difluoro-1-methoxybenzene" "benzene, 1,2-difluoro-4-methoxy-" "3,4-difluoroanisole 98%" "3,4-difluoro-1-methoxy-benzene" "3,4-difluorophenyl methyl ether" );
standardThermochemistry
{
    dHf_298   -498660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-393410.0
}
