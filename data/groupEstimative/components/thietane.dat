/*--------------------------------*- Choupo -*-----------------------*\
  Component: thietane  (C3H6S, CAS 287-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thietane;
formula     C3H6S;
CAS         287-27-4;
InChIKey    XSROQCDVUIHRSI-UHFFFAOYSA-N;
MW          74.141;      // g/mol [origin=calculated method=formula-sum]
Tc          540.52;      // K   [origin=predictive method=joback]
Pc          57.046;      // bar [origin=predictive method=joback]
omega       0.1788;      // -   [origin=predictive method=lee-kesler]
Tb          331.75;      // K   [origin=predictive method=joback]
HvapTb      28478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.32 0.47101 -0.0003873 1.309e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethylene sulfide" "thiacyclobutane" "propane, 1,3-epithio-" "trimethylene sulfide (8ci)" );
gibbsFormation
{
    dHf_298   26990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     295.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70600.0
    phase     gas;
}
