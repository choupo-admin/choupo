/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dibromo-1-chloro ethane  (C2H3Br2Cl, CAS 594-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dibromo1ChloroEthane;
formula     C2H3Br2Cl;
CAS         594-17-2;
InChIKey    GEFSLKMOZACLPI-UHFFFAOYSA-N;
MW          222.304;      // g/mol [origin=calculated method=formula-sum]
Tc          647.08;      // K   [origin=predictive method=joback]
Pc          60.093;      // bar [origin=predictive method=joback]
omega       0.3127;      // -   [origin=predictive method=lee-kesler]
Tb          411.88;      // K   [origin=predictive method=joback]
HvapTb      36005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.87 0.40282 -0.00042 1.617e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 1; } { group C; count 1; } { group Cl; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(bromanyl)-1-chloranyl-ethane" "chlorodibromoethane" "1,1-dibromo-1-chloroethane" );
standardThermochemistry
{
    dHf_298   -56440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14490.0
}
