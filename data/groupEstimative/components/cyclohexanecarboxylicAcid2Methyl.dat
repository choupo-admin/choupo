/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanecarboxylic acid, 2-methyl-  (C8H14O2, CAS 56586-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanecarboxylicAcid2Methyl;
formula     C8H14O2;
CAS         56586-13-1;
InChIKey    VSKXJRZPVDLHFY-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          763.49;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       0.6109;      // -   [origin=predictive method=lee-kesler]
Tb          543.03;      // K   [origin=predictive method=joback]
HvapTb      50686.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.45 0.91022 -0.0005096 9.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylcyclohexane-1-carboxylic acid" "2-methylcyclohexanecarboxylic acid" "2-methyl-1-cyclohexanecarboxylic acid, mixture of cis and trans" "cis-2-methylcyclohexanecarboxylic acid" "2-methyl-2-cyclohexanoic acid" "cyclohexanecarboxylicacid, 2-methyl-" "2-methyl-1-cyclohexanecarboxylic acid" "trans-2-methylcyclohexanecarboxylic acid" "(1)-cis-2-methylcyclohexanecarboxylic acid" "cyclohexanecarboxylic acid, 2-methyl-, trans-" );
gibbsFormation
{
    dHf_298   -524740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310690.0
    phase     gas;
}
