/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-3-heptyloxane  (C12H23ClO, CAS 31563-51-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro3Heptyloxane;
formula     C12H23ClO;
CAS         31563-51-6;
InChIKey    QSUBJPYMZOAHNQ-UHFFFAOYSA-N;
MW          218.765;      // g/mol [origin=calculated method=formula-sum]
Tc          749.65;      // K   [origin=predictive method=joback]
Pc          19.859;      // bar [origin=predictive method=joback]
omega       0.5780;      // -   [origin=predictive method=lee-kesler]
Tb          553.42;      // K   [origin=predictive method=joback]
HvapTb      51321.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.474 1.24322 -0.0006611 1.133e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group FCH2O; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group Cl; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-3-heptyl-oxane" "pyran, 4-chloro-3-heptyltetrahydro-" "4-chloro-3-heptyltetrahydro-2h-pyran" "pyran, 4-chloro-3-heptyltetrahydro-," );
gibbsFormation
{
    dHf_298   -404770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31150.0
    phase     gas;
}
