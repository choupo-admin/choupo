/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-2,2,6,6-tetramethyl-1-piperidineethanol  (C11H23NO2, CAS 52722-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxy2266Tetramethyl1Piperidineethanol;
formula     C11H23NO2;
CAS         52722-86-8;
InChIKey    STEYNUVPFMIUOY-UHFFFAOYSA-N;
MW          201.31;      // g/mol [origin=calculated method=formula-sum]
Tc          835.39;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       1.3161;      // -   [origin=predictive method=lee-kesler]
Tb          654.50;      // K   [origin=predictive method=joback]
HvapTb      72818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-155.808 1.90328 -0.0018298 7.558e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 2; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-hydroxyethyl)-2,2,6,6-tetramethyl-piperidin-4-ol" "1-(2-hydroxyethyl)-2,2,6,6-tetramethylpiperidin-4-ol" "1-piperidineethanol, 4-hydroxy-2,2,6,6-tetramethyl-" "1-(2-hydroxyethyl)-2,2,6,6-tetramethyl-4-piperidinol" "4-hydroxy-1-(2-hydroxyethyl)-2,2,6,6-tetramethylpiperidine" "4-hydroxy-2,2,6,6-tetramethylpiperidine-1-ethanol" "k823" "1-(2'-hydroxyethyl)-2,2,6,6-tetramethyl-4-piperidinol" "1-(2-hydroxyethyl)-4-hydroxy-2,2,6,6-tetramethylpiperidine" "n-(2'-hydroxyethyl)-4-hydroxy-2,2,6,6-tetramethylpiperidine" "1-(2-hydroxyethyl)-2,2,6,6-tetramethyl-4-hydroxypiperidine;4-hydroxy-1-(2-hydroxyethyl)-2,2,6,6-tetramethylpiperidine;4-hydroxy-2,2,6,6-tetramethyl-1-piperidineethanol;c 10-2625;n-2-hydroxyethyl-4-hydroxy-2,2,6,6-tetramethylpiperidine;" );
standardThermochemistry
{
    dHf_298   -457020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     706.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110970.0
}
