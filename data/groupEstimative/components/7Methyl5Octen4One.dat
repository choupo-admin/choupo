/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methyl-5-octen-4-one  (C9H16O, CAS 32064-78-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Methyl5Octen4One;
formula     C9H16O;
CAS         32064-78-1;
InChIKey    KBOYTXRTSGPWID-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          649.53;      // K   [origin=predictive method=joback]
Pc          26.057;      // bar [origin=predictive method=joback]
omega       0.5065;      // -   [origin=predictive method=lee-kesler]
Tb          463.11;      // K   [origin=predictive method=joback]
HvapTb      41944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.798 0.85676 -0.0005341 1.3376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methyloct-5-en-4-one" );
gibbsFormation
{
    dHf_298   -229730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26240.0
    phase     gas;
}
