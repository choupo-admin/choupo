/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-phenyldiethanolamine  (C10H15NO2, CAS 120-07-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPhenyldiethanolamine;
formula     C10H15NO2;
CAS         120-07-0;
InChIKey    OJPDDQSCZGTACX-UHFFFAOYSA-N;
MW          181.235;      // g/mol [origin=calculated method=formula-sum]
Tc          833.58;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       1.4749;      // -   [origin=predictive method=lee-kesler]
Tb          651.88;      // K   [origin=predictive method=joback]
HvapTb      75531.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.216 1.0668 -0.0007248 1.903e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-hydroxyethyl(phenyl)amino]ethanol" "2,2'-(phenylimino)diethanol" "phenyl diethanolamine" "diethanolaniline" "diethanolphenylamine" "n,n-bis(2-hydroxyethyl)aniline" "phenyldiethanolamine" "diethanolaminobenzene" "n,n-diethanolaniline" "n,n-dioxyethylaniline" "2,2'-phenyliminodiethanol" "ethanol, 2,2'-(phenylimino)bis-" );
gibbsFormation
{
    dHf_298   -250130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17130.0
    phase     gas;
}
