/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-5-hexen-3-ol  (C7H14O, CAS 67760-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl5Hexen3Ol;
formula     C7H14O;
CAS         67760-89-8;
InChIKey    LZJQEGCYVOMQID-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          618.02;      // K   [origin=predictive method=joback]
Pc          32.916;      // bar [origin=predictive method=joback]
omega       0.7224;      // -   [origin=predictive method=lee-kesler]
Tb          448.06;      // K   [origin=predictive method=joback]
HvapTb      46877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.548 0.68864 -0.0004158 1.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylhex-5-en-3-ol" "5-hexen-3-ol, 5-methyl-" );
gibbsFormation
{
    dHf_298   -229680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51910.0
    phase     gas;
}
