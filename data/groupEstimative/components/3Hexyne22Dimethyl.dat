/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexyne, 2,2-dimethyl-  (C8H14, CAS 4911-60-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexyne22Dimethyl;
formula     C8H14;
CAS         4911-60-8;
InChIKey    XYBFBXTUWDPXLK-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          588.86;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.2226;      // -   [origin=predictive method=lee-kesler]
Tb          388.41;      // K   [origin=predictive method=joback]
HvapTb      34258.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.299 0.73988 -0.00049106 1.3488e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylhex-3-yne" "2,2-dimethyl-3-hexyne" "2,2-dimethyl-hex-3-yne" "1-ethyl-2-tert-butylacetylene;2,2-dimethyl-3-hexyne" );
gibbsFormation
{
    dHf_298   55100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222120.0
    phase     gas;
}
