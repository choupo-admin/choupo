/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenethylsulfanylbenzene  (C14H14S, CAS 13865-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenethylsulfanylbenzene;
formula     C14H14S;
CAS         13865-49-1;
InChIKey    VRWWJIACGVONTQ-UHFFFAOYSA-N;
MW          214.326;      // g/mol [origin=calculated method=formula-sum]
Tc          900.51;      // K   [origin=predictive method=joback]
Pc          28.203;      // bar [origin=predictive method=joback]
omega       0.5436;      // -   [origin=predictive method=lee-kesler]
Tb          642.06;      // K   [origin=predictive method=joback]
HvapTb      58127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.048 1.17039 -0.00076 1.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethylsulfanylbenzene" "[(2-phenylethyl)sulfanyl]benzene" "sulfide, phenethyl phenyl" "sulfide, phenethyl phenyl," "[2-(phenylsulfanyl)ethyl]benzene" "benzene, [(2-phenylethyl)thio]-" "beta-phenylethyl phenyl sulfide" );
gibbsFormation
{
    dHf_298   182640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=324940.0
    phase     gas;
}
