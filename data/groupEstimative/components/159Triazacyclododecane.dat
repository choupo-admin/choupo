/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5,9-triazacyclododecane  (C9H21N3, CAS 294-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        159Triazacyclododecane;
formula     C9H21N3;
CAS         294-80-4;
InChIKey    VQFZKDXSJZVGDA-UHFFFAOYSA-N;
MW          171.288;      // g/mol [origin=calculated method=formula-sum]
Tc          868.71;      // K   [origin=predictive method=joback]
Pc          38.151;      // bar [origin=predictive method=joback]
omega       0.5128;      // -   [origin=predictive method=lee-kesler]
Tb          601.01;      // K   [origin=predictive method=joback]
HvapTb      57672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.8 0.9096 -0.000142 -1.444e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2NH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group NH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[12]anen3" "4,8,12-triazacyclododecan" );
gibbsFormation
{
    dHf_298   -77960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=247590.0
    phase     gas;
}
