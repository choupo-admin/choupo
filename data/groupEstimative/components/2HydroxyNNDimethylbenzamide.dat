/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-n,n-dimethylbenzamide  (C9H11NO2, CAS 1778-08-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyNNDimethylbenzamide;
formula     C9H11NO2;
CAS         1778-08-1;
InChIKey    UBAYZMJYXBTDBB-UHFFFAOYSA-N;
MW          165.192;      // g/mol [origin=calculated method=formula-sum]
Tc          806.35;      // K   [origin=predictive method=joback]
Pc          42.111;      // bar [origin=predictive method=joback]
omega       0.7798;      // -   [origin=predictive method=lee-kesler]
Tb          579.13;      // K   [origin=predictive method=joback]
HvapTb      59707.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.45 1.03044 -0.00084726 2.8286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-2-oxidanyl-benzamide" "salicyldimethylamide" "n,n-dimethylsalicylamide" "salicylamide, n,n-dimethyl-" "benzamide, 2-hydroxy-n,n-dimethyl-" "salicylamide,n-dimethyl-" "2-hydroxy-n,n-dimethyl-benzamide" "benzamide,2-hydroxy-n,n-dimethyl-" "(2-hydroxyphenyl)-n,n-dimethylcarboxamide" "benzamide, 2-hydroxy-n,n-dimethyl- (9ci)" );
gibbsFormation
{
    dHf_298   -214920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-35450.0
    phase     gas;
}
