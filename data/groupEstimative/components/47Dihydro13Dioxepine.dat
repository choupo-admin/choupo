/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7-dihydro-1,3-dioxepine  (C5H8O2, CAS 5417-32-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        47Dihydro13Dioxepine;
formula     C5H8O2;
CAS         5417-32-3;
InChIKey    BAKUAUDFCNFLBX-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          614.84;      // K   [origin=predictive method=joback]
Pc          49.804;      // bar [origin=predictive method=joback]
omega       0.2931;      // -   [origin=predictive method=lee-kesler]
Tb          395.55;      // K   [origin=predictive method=joback]
HvapTb      36946.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.9 0.5558 -0.00029768 4.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7-dihydro-1,3-dioxepin" "1,3-dioxepin, 4,7-dihydro-" "cis-4,7-dihydro-1,3-dioxepin" "cis-1,3-dioxep-5-ene" "4,3-dioxepin" "1,3-dioxep-5-ene" "1, 4,7-dihydro-" );
gibbsFormation
{
    dHf_298   -284250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     242.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-131000.0
    phase     gas;
}
