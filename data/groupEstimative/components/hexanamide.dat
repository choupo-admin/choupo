/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanamide  (C6H13NO, CAS 628-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanamide;
formula     C6H13NO;
CAS         628-02-4;
InChIKey    ALBYIUDWACNRRB-UHFFFAOYSA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          654.74;      // K   [origin=predictive method=joback]
Pc          35.685;      // bar [origin=predictive method=joback]
omega       0.6078;      // -   [origin=predictive method=lee-kesler]
Tb          463.28;      // K   [origin=predictive method=joback]
HvapTb      46337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.284 0.60772 -0.0003273 6.216e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-caproamide" "caproamide" "capronamide" "hexamide" "hexylamide" "n-hexanamide" "hexamide (van)" "hexanoamide" "n-capronamide" "n-caproic amide" "hexanoic acid amide" "hexanoic acid, amide" );
gibbsFormation
{
    dHf_298   -245960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-62830.0
    phase     gas;
}
