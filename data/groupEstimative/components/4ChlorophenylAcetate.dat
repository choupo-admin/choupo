/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorophenyl acetate  (C8H7ClO2, CAS 876-27-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorophenylAcetate;
formula     C8H7ClO2;
CAS         876-27-7;
InChIKey    KEUPLGRNURQXAR-UHFFFAOYSA-N;
MW          170.592;      // g/mol [origin=calculated method=formula-sum]
Tc          733.29;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       0.4976;      // -   [origin=predictive method=lee-kesler]
Tb          509.95;      // K   [origin=predictive method=joback]
HvapTb      48132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.31 0.57742 -0.00030136 3.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH3COO; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-chlorophenyl) ethanoate" "p-acetoxychlorobenzene" "acetic acid, p-chlorophenyl ester" "acetic acid, 4-chlorophenyl ester" "p-chlorophenyl acetate" "p-chlorophenylacetate" "4-monochlorophenol acetate" "phenol, p-chloro-, acetate" "(4-chlorophenyl) acetate" "p-chlorfenylester kyseliny octove" "acetic acid 4-chloro-phenyl ester" "acetic acid, 4-chlorophenyl ester (9ci)" );
gibbsFormation
{
    dHf_298   -316410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203040.0
    phase     gas;
}
