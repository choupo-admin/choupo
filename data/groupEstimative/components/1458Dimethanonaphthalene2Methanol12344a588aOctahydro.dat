/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4:5,8-dimethanonaphthalene-2-methanol, 1,2,3,4,4a,5,8,8a-octahydro-  (C13H18O, CAS 117574-21-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1458Dimethanonaphthalene2Methanol12344a588aOctahydro;
formula     C13H18O;
CAS         117574-21-7;
InChIKey    LLPLOWFYJGZIBV-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          801.35;      // K   [origin=predictive method=joback]
Pc          27.212;      // bar [origin=predictive method=joback]
omega       0.8747;      // -   [origin=predictive method=lee-kesler]
Tb          601.33;      // K   [origin=predictive method=joback]
HvapTb      60228.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-179.009 1.7409 -0.00141568 4.701e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 7; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 7; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-00b8ph" "1,2,3,4,4a,5,8,8a-octahydro-1,4:5,8-dimethanonaphthalen-2-ylmethanol" "1,2,3,4,4a,5,8,8a-octahydro-1,4:5,8-dimethanonaphthalene-2-methanol" );
gibbsFormation
{
    dHf_298   -175920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     187.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=171590.0
    phase     gas;
}
