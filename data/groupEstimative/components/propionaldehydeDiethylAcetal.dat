/*--------------------------------*- Choupo -*-----------------------*\
  Component: propionaldehyde diethyl acetal  (C7H16O2, CAS 4744-08-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propionaldehydeDiethylAcetal;
formula     C7H16O2;
CAS         4744-08-5;
InChIKey    MBNMGGKBGCIEGF-UHFFFAOYSA-N;
MW          132.203;      // g/mol [origin=calculated method=formula-sum]
Tc          572.80;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.4703;      // -   [origin=predictive method=lee-kesler]
Tb          404.16;      // K   [origin=predictive method=joback]
HvapTb      35608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.843 0.54836 -0.0001382 -3.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxypropane" "propane, 1,1-diethoxy-" "propionaldehyde, diethyl acetal" "diethyl propional" "propanaldiethylacetal" "diethoxypropane" "propane,1-diethoxy-" "propanal diethyl acetal" "propionaldehyde, diethyl acetal (8ci)" );
gibbsFormation
{
    dHf_298   -457530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-204380.0
    phase     gas;
}
