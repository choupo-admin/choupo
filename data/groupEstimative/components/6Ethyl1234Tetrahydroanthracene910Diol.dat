/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-ethyl-1,2,3,4-tetrahydroanthracene-9,10-diol  (C16H18O2, CAS 68279-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Ethyl1234Tetrahydroanthracene910Diol;
formula     C16H18O2;
CAS         68279-54-9;
InChIKey    CCJCCAFGRJMKIR-UHFFFAOYSA-N;
MW          242.318;      // g/mol [origin=calculated method=formula-sum]
Tc          1055.83;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       1.1156;      // -   [origin=predictive method=lee-kesler]
Tb          803.20;      // K   [origin=predictive method=joback]
HvapTb      83534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.249 1.73972 -0.00155532 5.749e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 3; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 7; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-anthracenediol, 6-ethyl-1,2,3,4-tetrahydro-" "6-ethyl-1,2,3,4-tetrahydro-9,10-anthracenediol" );
standardThermochemistry
{
    dHf_298   -248020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21130.0
}
