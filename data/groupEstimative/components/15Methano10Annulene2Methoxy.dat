/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-methano[10]annulene, 2-methoxy-  (C12H12O, CAS 58853-55-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Methano10Annulene2Methoxy;
formula     C12H12O;
CAS         58853-55-7;
InChIKey    DDBQPACEJITMHA-UHFFFAOYSA-N;
MW          172.227;      // g/mol [origin=calculated method=formula-sum]
Tc          787.48;      // K   [origin=predictive method=joback]
Pc          30.830;      // bar [origin=predictive method=joback]
omega       0.4857;      // -   [origin=predictive method=lee-kesler]
Tb          551.49;      // K   [origin=predictive method=joback]
HvapTb      49466.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.69 0.92892 -0.00057248 1.286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methoxybicyclo[4.4.1]undeca-1,3,5,7,9-pentaene" "bicyclo(4.4.1)undeca-1,3,5,7,9-pentaene, 2-methoxy-" "bicyclo[4.4.1]undeca-1,3,5,7,9-pentaene, 2-methoxy-" "bicyclo[4.4.1]undeca-1,3,5,7,9-pentaene,2-methoxy-" "2-methoxy-1,6-methano[10]annulene;2-methoxybicyclo[4.4.1]undeca-1,3,5,7,9-pentaene" );
gibbsFormation
{
    dHf_298   -13260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=142490.0
    phase     gas;
}
