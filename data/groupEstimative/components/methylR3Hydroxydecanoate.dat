/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl (r)-3-hydroxydecanoate  (C11H22O3, CAS 56618-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylR3Hydroxydecanoate;
formula     C11H22O3;
CAS         56618-58-7;
InChIKey    UBVACUZVNTVHTE-SNVBAGLBSA-N;
MW          202.294;      // g/mol [origin=calculated method=formula-sum]
Tc          767.70;      // K   [origin=predictive method=joback]
Pc          21.256;      // bar [origin=predictive method=joback]
omega       1.1115;      // -   [origin=predictive method=lee-kesler]
Tb          601.24;      // K   [origin=predictive method=joback]
HvapTb      63778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.907 1.03394 -0.0005136 7.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (3r)-3-oxidanyldecanoate" "(r)-3-hydroxydecanoic acid methyl ester" "(r)-3-hydroxy-decanoic acid methyl ester" "r-(3)-hydroxydecanoic acid, methyl ester" );
gibbsFormation
{
    dHf_298   -745160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     677.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-407890.0
    phase     gas;
}
