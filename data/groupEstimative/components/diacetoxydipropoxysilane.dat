/*--------------------------------*- Choupo -*-----------------------*\
  Component: diacetoxydipropoxysilane  (C10H20O6Si, CAS 17906-69-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H20O6Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diacetoxydipropoxysilane;
formula     C10H20O6Si;
CAS         17906-69-3;
InChIKey    NXDNKXIRKGNOMN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          264.349;      // g/mol [origin=calculated method=formula-sum]
Tc          769.54;      // K   [origin=predictive method=joback]
Pc          18.547;      // bar [origin=predictive method=joback]
omega       0.8324;      // -   [origin=predictive method=lee-kesler]
Tb          591.08;      // K   [origin=predictive method=joback]
HvapTb      57782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (136.434 0.51168 0.0003058 -3.332e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH3COO; count 2; } { group CH2O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[acetyloxy(dipropoxy)silyl] ethanoate" "diacetyl dipropyl orthosilicate" "acetic acid, dianhydride with silicic acid (h4sio4) dipropyl ester" "acetic acid, anhydride with silicic acid (h4sio4) dipropyl ester (2:1)" "[acetyloxy(dipropoxy)silyl] acetate" "acetic acid, anhydridewith silicic acid (h4sio4) dipropyl ester (2:1)" "aceticacid, dianhydride with silicic acid (h4sio4) dipropyl ester (8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -1260350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     797.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-902180.0
}
