/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-5-nonanol  (C10H22O, CAS 33933-78-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl5Nonanol;
formula     C10H22O;
CAS         33933-78-7;
InChIKey    AGSIGVZAVLOKLP-UHFFFAOYSA-N;
MW          158.285;      // g/mol [origin=calculated method=formula-sum]
Tc          684.06;      // K   [origin=predictive method=joback]
Pc          23.406;      // bar [origin=predictive method=joback]
omega       0.8490;      // -   [origin=predictive method=lee-kesler]
Tb          517.35;      // K   [origin=predictive method=joback]
HvapTb      53237.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.384 1.11366 -0.0007224 1.895e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylnonan-5-ol" "5-nonanol, 5-methyl-" "2-butyl-2-hexanol" "di-n-butyl methyl carbinol" "2-butyl-2-hexanol;5-methyl-5-nonanol" );
standardThermochemistry
{
    dHf_298   -410710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100660.0
}
