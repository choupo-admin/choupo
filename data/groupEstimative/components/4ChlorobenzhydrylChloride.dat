/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobenzhydryl chloride  (C13H10Cl2, CAS 134-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorobenzhydrylChloride;
formula     C13H10Cl2;
CAS         134-83-8;
InChIKey    ALKWTKGPKKAZMN-UHFFFAOYSA-N;
MW          237.123;      // g/mol [origin=calculated method=formula-sum]
Tc          888.34;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.5108;      // -   [origin=predictive method=lee-kesler]
Tb          629.80;      // K   [origin=predictive method=joback]
HvapTb      58128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.34 1.041 -0.00072276 1.871e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group CHCl; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-[chloranyl(phenyl)methyl]benzene" "4-chlorobenzhydrylchloride" "p-chlorobenzhydryl chloride" "benzene, 1-chloro-4-(chlorophenylmethyl)-" "methane, chloro(p-chlorophenyl)phenyl-" "1-chloro-4-[chloro(phenyl)methyl]benzene" "chloro(4-chlorophenyl)phenylmethane" "1-chloro-4-(chloro(phenyl)methyl)benzene" "4-chloro-1-(chlorophenylmethyl)benzene" "alkwtkgpkkazmn-uhfffaoysa-" "1-chloro-4-(chlorophenylmethyl)benzene" "1-chloro-4-(chloro-phenylmethyl)benzene" );
standardThermochemistry
{
    dHf_298   113180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=247470.0
}
