/*--------------------------------*- Choupo -*-----------------------*\
  Component: eicosyl methanoate  (C21H42O2, CAS 66326-15-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C21H42O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        eicosylMethanoate;
formula     C21H42O2;
CAS         66326-15-6;
InChIKey    XPSVNIWOCPFNFQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          326.565;      // g/mol [origin=calculated method=formula-sum]
Tc          815.67;      // K   [origin=predictive method=joback]
Pc          9.633;      // bar [origin=predictive method=joback]
omega       0.7778;      // -   [origin=predictive method=lee-kesler]
Tb          656.50;      // K   [origin=predictive method=joback]
HvapTb      59967.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.701 2.00692 -0.0012716 3.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 19; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "icosyl methanoate" );
gibbsFormation
{
    dHf_298   -400320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1157.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=169900.0
    phase     gas;
}
