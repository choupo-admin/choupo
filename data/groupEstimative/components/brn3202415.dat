/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3202415  (C17H19N, CAS 63019-09-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3202415;
formula     C17H19N;
CAS         63019-09-0;
InChIKey    UFLSFHMZKBRTEE-UHFFFAOYSA-N;
MW          237.346;      // g/mol [origin=calculated method=formula-sum]
Tc          901.71;      // K   [origin=predictive method=joback]
Pc          21.276;      // bar [origin=predictive method=joback]
omega       0.6438;      // -   [origin=predictive method=lee-kesler]
Tb          668.48;      // K   [origin=predictive method=joback]
HvapTb      61313.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.65 1.48596 -0.00102572 2.771e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH3; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-4-[2-(2-methylphenyl)ethenyl]aniline" "4-dimethylamino-2'-methylstilbene" "n,n-dimethyl-2'-methylstilbenamine" "4-stilbenamine, n,n,2'-trimethyl-" "stilbenamine, n,n-dimethyl-2'-methyl-" "n,n,2'-trimethyl-4-stilbenamine" );
gibbsFormation
{
    dHf_298   240660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=488820.0
    phase     gas;
}
