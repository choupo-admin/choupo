/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, monoester with 1,2-propanediol, polymer with 2-propenoic acid  (C10H16O5, CAS 78280-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2MethylMonoesterWith12PropanediolPolymerWith2P;
formula     C10H16O5;
CAS         78280-50-9;
InChIKey    FEQVRVZZAZBGAO-UHFFFAOYSA-N;
MW          216.233;      // g/mol [origin=calculated method=formula-sum]
Tc          912.12;      // K   [origin=predictive method=joback]
Pc          25.430;      // bar [origin=predictive method=joback]
omega       1.3081;      // -   [origin=predictive method=lee-kesler]
Tb          718.51;      // K   [origin=predictive method=joback]
HvapTb      77750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.561 0.74344 -0.0001651 -9.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-oxidanylpropan-2-yl 2-methylprop-2-enoate;prop-2-enoic acid" "hydroxypropylmethacrylate, acrylic acid polymer" "hydroxypropyl methacrylate, acrylic acid copolymer" );
standardThermochemistry
{
    dHf_298   -945340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     785.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-697850.0
}
