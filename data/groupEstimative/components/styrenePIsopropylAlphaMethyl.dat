/*--------------------------------*- Choupo -*-----------------------*\
  Component: styrene, p-isopropyl-.alpha.-methyl-  (C12H16, CAS 2388-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        styrenePIsopropylAlphaMethyl;
formula     C12H16;
CAS         2388-14-9;
InChIKey    XMCNZCCURGYSDQ-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          715.41;      // K   [origin=predictive method=joback]
Pc          25.025;      // bar [origin=predictive method=joback]
omega       0.4039;      // -   [origin=predictive method=lee-kesler]
Tb          501.94;      // K   [origin=predictive method=joback]
HvapTb      44266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.99 0.99126 -0.00062156 1.509e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propan-2-yl-4-prop-1-en-2-yl-benzene" "benzene, 1-(1-methylethenyl)-4-(1-methylethyl)-" "p-isopropenylisopropylbenzene" "p-isopropylisopropenylbenzene" "2-(p-isopropylphenyl)propene" "p-isopropyl-alpha-methylstyrene" "p-isopropyl-.alpha.-methylstyrene" ".alpha.-methyl-4-isopropylstyrene" "2-(4-isopropylphenyl)-1-propene" "4-isopropyl-.alpha.-methylstyrene" "1-propan-2-yl-4-prop-1-en-2-ylbenzene" );
gibbsFormation
{
    dHf_298   44410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229790.0
    phase     gas;
}
