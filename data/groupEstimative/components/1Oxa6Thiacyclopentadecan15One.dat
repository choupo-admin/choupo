/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-oxa-6-thiacyclopentadecan-15-one  (C13H24O2S, CAS 1725-16-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Oxa6Thiacyclopentadecan15One;
formula     C13H24O2S;
CAS         1725-16-2;
InChIKey    QOUGSQNSXBGSRU-UHFFFAOYSA-N;
MW          244.393;      // g/mol [origin=calculated method=formula-sum]
Tc          913.86;      // K   [origin=predictive method=joback]
Pc          23.703;      // bar [origin=predictive method=joback]
omega       0.5099;      // -   [origin=predictive method=lee-kesler]
Tb          657.20;      // K   [origin=predictive method=joback]
HvapTb      59693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.09 1.27981 -0.0004191 -7.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH2COO; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group COO; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -552130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     915.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-264470.0
}
