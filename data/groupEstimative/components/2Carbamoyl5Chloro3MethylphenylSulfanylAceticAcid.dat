/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(2-carbamoyl-5-chloro-3-methylphenyl)sulfanyl]acetic acid  (C10H10ClNO3S, CAS 66214-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Carbamoyl5Chloro3MethylphenylSulfanylAceticAcid;
formula     C10H10ClNO3S;
CAS         66214-43-5;
InChIKey    GDQGYYWSXWKWAQ-UHFFFAOYSA-N;
MW          259.704;      // g/mol [origin=calculated method=formula-sum]
Tc          1098.88;      // K   [origin=predictive method=joback]
Pc          34.480;      // bar [origin=predictive method=joback]
omega       1.2902;      // -   [origin=predictive method=lee-kesler]
Tb          848.14;      // K   [origin=predictive method=joback]
HvapTb      87869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.731 0.78231 -0.00042778 6.996e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group COOH; count 1; } { group ACCl; count 1; } { group CONH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-aminocarbonyl-5-chloranyl-3-methyl-phenyl)sulfanylethanoic acid" "acetic acid, ((2-(aminocarbonyl)-5-chloro-3-methylphenyl)thio)-" "acetic acid, [[2-(aminocarbonyl)-5-chloro-3-methylphenyl]thio]-" "acetic acid, 2-((2-(aminocarbonyl)-5-chloro-3-methylphenyl)thio)-" "acetic acid, 2-[[2-(aminocarbonyl)-5-chloro-3-methylphenyl]thio]-" "2-(2-carbamoyl-5-chloro-3-methylphenyl)sulfanylacetic acid" );
gibbsFormation
{
    dHf_298   -450540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268350.0
    phase     gas;
}
