/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-acetylpyrene  (C18H12O, CAS 3264-21-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Acetylpyrene;
formula     C18H12O;
CAS         3264-21-9;
InChIKey    KCIJNJVCFPSUBQ-UHFFFAOYSA-N;
MW          244.293;      // g/mol [origin=calculated method=formula-sum]
Tc          1006.87;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       0.8626;      // -   [origin=predictive method=lee-kesler]
Tb          756.17;      // K   [origin=predictive method=joback]
HvapTb      70954.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.99 1.49252 -0.00128246 4.4366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 7; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 7; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pyren-1-ylethanone" "ethanone, 1-(1-pyrenyl)-" "acetylpyrene" "ethanone,1-(1-pyrenyl)-" );
gibbsFormation
{
    dHf_298   202440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=369470.0
    phase     gas;
}
