/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4,4,6,6-hexakis(iodanyl)-3-phenyl-cyclohexane-1,1-diol  (C12H10I6O2, CAS 20033-08-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224466HexakisIodanyl3PhenylCyclohexane11Diol;
formula     C12H10I6O2;
CAS         20033-08-3;
InChIKey    PZYVSDRQCPCDFD-UHFFFAOYSA-N;
MW          947.61;      // g/mol [origin=calculated method=formula-sum]
Tc          1603.18;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       1.3425;      // -   [origin=predictive method=lee-kesler]
Tb          1245.87;      // K   [origin=predictive method=joback]
HvapTb      128767.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-203.01 2.5506 -0.0031992 1.5049e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C; count 4; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 2; } { group I; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group I; count 6; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   136200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1030.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=209300.0
}
