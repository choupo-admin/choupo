/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-iodobenzyl chloride  (C7H6ClI, CAS 59473-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2IodobenzylChloride;
formula     C7H6ClI;
CAS         59473-45-9;
InChIKey    FTMNWZHKQGKKAU-UHFFFAOYSA-N;
MW          252.475;      // g/mol [origin=calculated method=formula-sum]
Tc          780.65;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.3474;      // -   [origin=predictive method=lee-kesler]
Tb          521.99;      // K   [origin=predictive method=joback]
HvapTb      47872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.501 0.5762 -0.00042296 1.216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2Cl; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(chloromethyl)-2-iodanyl-benzene" "1-(chloromethyl)-2-iodobenzene" "benzene, 1-(chloromethyl)-2-iodo-" "59473-45-9 2-iodobenzyl chloride" "toluene, a-chloro-o-iodo- (6ci);1-chloromethyl-2-iodobenzene;benzene,1-(chloromethyl)-2-iodo-;o-iodobenzyl chloride;a-chloro-o-iodotoluene;" );
gibbsFormation
{
    dHf_298   98380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157030.0
    phase     gas;
}
