/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobut-2-yn-1-ol  (C4H5ClO, CAS 13280-07-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chlorobut2Yn1Ol;
formula     C4H5ClO;
CAS         13280-07-4;
InChIKey    RPUJAOFSZSEVPC-UHFFFAOYSA-N;
MW          104.533;      // g/mol [origin=calculated method=formula-sum]
Tc          622.80;      // K   [origin=predictive method=joback]
Pc          51.981;      // bar [origin=predictive method=joback]
omega       0.6259;      // -   [origin=predictive method=lee-kesler]
Tb          429.73;      // K   [origin=predictive method=joback]
HvapTb      47714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.992 0.2748 -0.00015246 3.418e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CH2Cl; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group tC; count 2; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylbut-2-yn-1-ol" "4-chloro-2-butyn-1-ol" "2-butyn-1-ol, 4-chloro-" "1-chloro-2-butyn-4-ol" "1-chloro-4-hydroxybut-2-yne" "1-chloro-2-butyn-4-ol;1-chloro-4-hydroxy-2-butyne; 4-chloro-2-butyn-1-ol; 4-chloro-2-butyne-1-ol;4-chloro-2-butynol" );
gibbsFormation
{
    dHf_298   -21560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36850.0
    phase     gas;
}
