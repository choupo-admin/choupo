/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylethylamine  (C4H11N, CAS 598-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylethylamine;
formula     C4H11N;
CAS         598-56-1;
InChIKey    DAZXVJBJRMWXJP-UHFFFAOYSA-N;
MW          73.139;      // g/mol [origin=calculated method=formula-sum]
Tc          464.68;      // K   [origin=predictive method=joback]
Pc          38.868;      // bar [origin=predictive method=joback]
omega       0.2686;      // -   [origin=predictive method=lee-kesler]
Tb          303.56;      // K   [origin=predictive method=joback]
HvapTb      26541.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.439 0.50776 -0.0003064 7.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylethanamine" "dimethylethylamine" "ethanamine, n,n-dimethyl-" "n-ethyldimethylamine" "ethylamine, n,n-dimethyl-" "ethyldimethylamine" "methanamine, n-ethyl-n-methyl-" "c13-15-alkyldimethylamines" "amines, c13-15-alkyldimethyl" "n,n-dimethylethanaminium" "agn-pc-0d6eh5" "ethylamine,n,n-dimethyl- (6ci,7ci,8ci); dmea; dimethylethylamine; methanamine,n-ethyl-n-methyl-; n,n-dimethylaminoethane; n,n-dimethylethanamine;n,n-dimethylethylamine; n-ethyldimethylamine" );
standardThermochemistry
{
    dHf_298   -58360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     327.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93580.0
}
