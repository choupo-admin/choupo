/*--------------------------------*- Choupo -*-----------------------*\
  Component: marmesin  (C14H14O4, CAS 13849-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        marmesin;
formula     C14H14O4;
CAS         13849-08-6;
InChIKey    FWYSBEAFFPBAQU-LBPRGKRZSA-N;
MW          246.262;      // g/mol [origin=calculated method=formula-sum]
Tc          965.52;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       1.2178;      // -   [origin=predictive method=lee-kesler]
Tb          748.70;      // K   [origin=predictive method=joback]
HvapTb      78575.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.82 1.46034 -0.00119106 3.83e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH; count 1; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-(2-oxidanylpropan-2-yl)-2,3-dihydrofuro[3,2-g]chromen-7-one" "(+)-marmesin" "(7s)-marmesin" "s(+)-marmesin" "s-(+)-marmesin" "marmesin, (+)-" "sdccgmls-0066759.p001" "brd-k36377456-001-02-0" "7h-furo[3, 2,3-dihydro-2-(1-hydroxy-1-methylethyl)-, (+)-" "7h-furo[3, 2,3-dihydro-2-(1-hydroxy-1-methylethyl)-, (s)-" "(2s)-2-(2-hydroxypropan-2-yl)-2,3-dihydrofuro[3,2-g]chromen-7-one" "7h-furo[3, 2,3-dihydro-2-(1-hydroxy-1-methylethyl)-, (s)-(+)-" );
standardThermochemistry
{
    dHf_298   -510550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-208680.0
}
