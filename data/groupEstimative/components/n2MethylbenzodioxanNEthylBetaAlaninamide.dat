/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-methylbenzodioxan)-n'-ethyl-beta-alaninamide  (C13H18N2O3, CAS 102128-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2MethylbenzodioxanNEthylBetaAlaninamide;
formula     C13H18N2O3;
CAS         102128-78-9;
InChIKey    ZTWTVQAXEPWJMT-UHFFFAOYSA-N;
MW          250.298;      // g/mol [origin=calculated method=formula-sum]
Tc          968.59;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       1.1300;      // -   [origin=predictive method=lee-kesler]
Tb          747.82;      // K   [origin=predictive method=joback]
HvapTb      76193.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.317 1.36012 -0.00087206 2.0806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH-O; count 1; } { group FCH2O; count 1; } { group CH2NH; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 2; } { group CdO; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2,3-dihydro-1,4-benzodioxin-3-ylmethylamino)-n-methyl-propanamide" "3-(((1,4-benzodioxan-2-yl)methyl)amino)-n-methylpropionamide" "n-(2-methyl-1,4-benzodioxan)-n'-methyl-beta-alaninamide" "propionamide, 3-(((1,4-benzodioxan-2-yl)methyl)amino)-n-methyl-" "propanamide,3-[[(2,3-dihydro-1,4-benzodioxin-2-yl)methyl]amino]-n-methyl-" "1205 i.s." "3-(2,3-dihydro-1,4-benzodioxin-3-ylmethylamino)-n-methylpropanamide" "propionamide,3-[(1,4-benzodioxan-2-ylmethyl)amino]-n-methyl- (6ci); 1,4-benzodioxin,propanamide deriv." );
gibbsFormation
{
    dHf_298   -289590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87630.0
    phase     gas;
}
