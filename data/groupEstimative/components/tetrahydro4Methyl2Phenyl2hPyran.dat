/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydro-4-methyl-2-phenyl-2h-pyran  (C12H16O, CAS 94201-73-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydro4Methyl2Phenyl2hPyran;
formula     C12H16O;
CAS         94201-73-7;
InChIKey    GDAVABNCFOTAOD-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          780.74;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       0.4128;      // -   [origin=predictive method=lee-kesler]
Tb          542.67;      // K   [origin=predictive method=joback]
HvapTb      49212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.27 1.15752 -0.0006719 1.298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-phenyl-oxane" "4-methyl-2-phenyloxane" "agn-pc-00q1ds" "2h-pyran, tetrahydro-4-methyl-2-phenyl-" );
gibbsFormation
{
    dHf_298   -152500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93190.0
    phase     gas;
}
