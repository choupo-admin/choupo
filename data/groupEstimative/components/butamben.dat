/*--------------------------------*- Choupo -*-----------------------*\
  Component: butamben  (C11H15NO2, CAS 94-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butamben;
formula     C11H15NO2;
CAS         94-25-7;
InChIKey    IUWVALYLNVXWKX-UHFFFAOYSA-N;
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          829.78;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.7746;      // -   [origin=predictive method=lee-kesler]
Tb          613.69;      // K   [origin=predictive method=joback]
HvapTb      61066.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.183 0.91752 -0.00048756 7.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 4-azanylbenzoate" "butyl 4-aminobenzoate" "butylcaine" "butesin" "butyl aminobenzoate" "butesine" "butoform" "planoform" "scuroform" "scuroforme" "butyl keloform" "n-butyl-p-aminobenzoate" );
gibbsFormation
{
    dHf_298   -328800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99400.0
    phase     gas;
}
