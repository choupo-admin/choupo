/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-4-methylbenzoic acid  (C8H8O3, CAS 586-30-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxy4MethylbenzoicAcid;
formula     C8H8O3;
CAS         586-30-1;
InChIKey    ZQLCWPXBHUALQC-UHFFFAOYSA-N;
MW          152.149;      // g/mol [origin=calculated method=formula-sum]
Tc          879.56;      // K   [origin=predictive method=joback]
Pc          48.766;      // bar [origin=predictive method=joback]
omega       0.9531;      // -   [origin=predictive method=lee-kesler]
Tb          640.43;      // K   [origin=predictive method=joback]
HvapTb      66518.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.31 0.83082 -0.00070452 2.457e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-3-oxidanyl-benzoic acid" "3-hydroxy-p-toluic acid" "3,4-cresotic acid" "3-hydroxy-4-methylbenzoicacid" "3-hydroxy-4-methyl-benzoic acid" "benzoic acid, 3-hydroxy-4-methyl-" "3,4-cresotic acid; 3-hydroxy-p-toluic acid" );
gibbsFormation
{
    dHf_298   -510970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-379270.0
    phase     gas;
}
