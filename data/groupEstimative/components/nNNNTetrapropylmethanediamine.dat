/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n',n'-tetrapropylmethanediamine  (C13H30N2, CAS 10333-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNNTetrapropylmethanediamine;
formula     C13H30N2;
CAS         10333-53-6;
InChIKey    NGCFMKFMMGSXJO-UHFFFAOYSA-N;
MW          214.397;      // g/mol [origin=calculated method=formula-sum]
Tc          680.09;      // K   [origin=predictive method=joback]
Pc          16.391;      // bar [origin=predictive method=joback]
omega       0.7445;      // -   [origin=predictive method=lee-kesler]
Tb          521.92;      // K   [origin=predictive method=joback]
HvapTb      48618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.311 1.48668 -0.0009086 2.183e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 9; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methanediamine, n,n,n',n'-tetrapropyl-" "n,n,n',n'-tetrapropylmethylenediamine" );
gibbsFormation
{
    dHf_298   -176590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     694.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=280140.0
    phase     gas;
}
