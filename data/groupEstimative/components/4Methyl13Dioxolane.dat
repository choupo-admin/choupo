/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-1,3-dioxolane  (C4H8O2, CAS 1072-47-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl13Dioxolane;
formula     C4H8O2;
CAS         1072-47-5;
InChIKey    SBUOHGKIOVRDKY-UHFFFAOYSA-N;
MW          88.106;      // g/mol [origin=calculated method=formula-sum]
Tc          560.12;      // K   [origin=predictive method=joback]
Pc          48.225;      // bar [origin=predictive method=joback]
omega       0.2824;      // -   [origin=predictive method=lee-kesler]
Tb          360.30;      // K   [origin=predictive method=joback]
HvapTb      33775.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.59 0.50952 -0.0002934 5.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 4-methyl-" "1,3-dioxolane,4-methyl-" );
standardThermochemistry
{
    dHf_298   -329410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     158.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-152890.0
}
