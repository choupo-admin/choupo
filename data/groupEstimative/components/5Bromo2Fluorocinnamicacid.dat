/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromo-2-fluorocinnamicacid  (C9H6BrFO2, CAS 202865-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Bromo2Fluorocinnamicacid;
formula     C9H6BrFO2;
CAS         202865-71-2;
InChIKey    ROTBALNVXDGIQY-UHFFFAOYSA-N;
MW          245.047;      // g/mol [origin=calculated method=formula-sum]
Tc          894.01;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.9022;      // -   [origin=predictive method=lee-kesler]
Tb          657.26;      // K   [origin=predictive method=joback]
HvapTb      61968.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.9 0.7817 -0.00060712 1.867e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group COOH; count 1; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(5-bromanyl-2-fluoranyl-phenyl)prop-2-enoic acid" "3-(5-bromo-2-fluorophenyl)acrylic acid;" "(e)-3-(5-bromo-2-fluorophenyl)acrylic acid" "2-propenoic acid,3-(5-bromo-2-fluorophenyl)-" );
gibbsFormation
{
    dHf_298   -418330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-326130.0
    phase     gas;
}
