/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[(hexyloxy)methoxy]hexane  (C13H28O2, CAS 54815-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1HexyloxyMethoxyHexane;
formula     C13H28O2;
CAS         54815-12-2;
InChIKey    SMBRWKSIANXXKZ-UHFFFAOYSA-N;
MW          216.365;      // g/mol [origin=calculated method=formula-sum]
Tc          702.35;      // K   [origin=predictive method=joback]
Pc          16.000;      // bar [origin=predictive method=joback]
omega       0.7724;      // -   [origin=predictive method=lee-kesler]
Tb          541.88;      // K   [origin=predictive method=joback]
HvapTb      49352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.071 1.11244 -0.0004614 3.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(hexoxymethoxy)hexane" "hexane, 1,1'-[methylenebis(oxy)]bis-" "1-(hexoxy-methoxy)-hexane" );
standardThermochemistry
{
    dHf_298   -576090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     684.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-151420.0
}
