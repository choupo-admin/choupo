/*--------------------------------*- Choupo -*-----------------------*\
  Component: gyrane  (C11H20O, CAS 24237-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gyrane;
formula     C11H20O;
CAS         24237-00-1;
InChIKey    OSMLMQQJZVENMX-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          694.05;      // K   [origin=predictive method=joback]
Pc          22.893;      // bar [origin=predictive method=joback]
omega       0.4720;      // -   [origin=predictive method=lee-kesler]
Tb          497.25;      // K   [origin=predictive method=joback]
HvapTb      45664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.377 1.02596 -0.00050654 7.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-butyl-2,4-dimethyl-3,6-dihydro-2h-pyran" "2h-pyran, 6-butyl-3,6-dihydro-2,4-dimethyl-" "2-butyl-4,6-dimethyldihydropyran" "6-butyl-2,4-dimethyldihydropyrane" "6-butyl-3,6-dihydro-2,4-dimethyl-2h-pyran" "2h-pyran, 3,6-dihydro-6-butyl-2,4-dimethyl-" "agn-pc-00b3bj" );
standardThermochemistry
{
    dHf_298   -322080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-7310.0
}
