/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyltris(trimethylsiloxy)silane  (C10H30O3Si4, CAS 17928-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H30O3Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methyltrisTrimethylsiloxySilane;
formula     C10H30O3Si4;
CAS         17928-28-8;
InChIKey    RGMZNZABJYWAEC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          310.687;      // g/mol [origin=calculated method=formula-sum]
Tc          684.72;      // K   [origin=predictive method=joback]
Pc          13.626;      // bar [origin=predictive method=joback]
omega       0.3281;      // -   [origin=predictive method=lee-kesler]
Tb          501.26;      // K   [origin=predictive method=joback]
HvapTb      46260.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (233.57 -0.0604 0.001472 -9.254e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group Si; count 1; } { group SiO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[methyl-bis(trimethylsilyloxy)silyl]oxy-silane" "1,1,1,3,5,5,5-heptamethyl-3-((trimethylsilyl)oxy)trisiloxane" "trisiloxane, 1,1,1,3,5,5,5-heptamethyl-3-[(trimethylsilyl)oxy]-" "trisiloxane, 1,1,1,3,5,5,5-heptamethyl-3-((trimethylsilyl)oxy)-" "methyltris(trimethylsiloxy) silane" "methyltris(trimethylsilyloxy)silane" "trimethyl-[methyl-bis(trimethylsilyloxy)silyl]oxysilane" );
standardThermochemistry
{
    dHf_298   -1092870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1085.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-700720.0
}
