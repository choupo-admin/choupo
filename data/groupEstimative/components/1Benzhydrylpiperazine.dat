/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-benzhydrylpiperazine  (C17H20N2, CAS 841-77-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Benzhydrylpiperazine;
formula     C17H20N2;
CAS         841-77-0;
InChIKey    NWVNXDKZIQLBNM-UHFFFAOYSA-N;
MW          252.361;      // g/mol [origin=calculated method=formula-sum]
Tc          982.57;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.7054;      // -   [origin=predictive method=lee-kesler]
Tb          722.42;      // K   [origin=predictive method=joback]
HvapTb      66967.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.25 1.7356 -0.0012014 3.138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(diphenylmethyl)piperazine" "benzhydrylpiperazine" "n-benzhydrylpiperazine" "1-benzhydryl-piperazine" "norcyclizine" "diphenylmethylpiperazine" "normethylcyclizine" "piperazine, 1-(diphenylmethyl)-" "n-(diphenylmethyl)piperazine" "4-benzhydrylpiperazine" "1-benzyhydrylpiperazine" "(diphenylmethyl)piperazine" );
standardThermochemistry
{
    dHf_298   259730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=557390.0
}
