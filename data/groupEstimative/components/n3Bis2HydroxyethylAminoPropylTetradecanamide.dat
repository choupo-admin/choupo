/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-{3-[bis(2-hydroxyethyl)amino]propyl}tetradecanamide  (C21H44N2O3, CAS 66161-64-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3Bis2HydroxyethylAminoPropylTetradecanamide;
formula     C21H44N2O3;
CAS         66161-64-6;
InChIKey    VNRVRVIRWRSXJY-UHFFFAOYSA-N;
MW          372.594;      // g/mol [origin=calculated method=formula-sum]
Tc          1223.70;      // K   [origin=predictive method=joback]
Pc          11.291;      // bar [origin=predictive method=joback]
omega       0.8684;      // -   [origin=predictive method=lee-kesler]
Tb          980.92;      // K   [origin=predictive method=joback]
HvapTb      110923.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.161 2.23892 -0.0013219 2.9716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group OH; count 2; } { group CH2N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } { group OH; count 2; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[3-[bis(2-hydroxyethyl)amino]propyl]tetradecanamide" "tetradecanamide, n-(3-(bis(2-hydroxyethyl)amino)propyl)-" "tetradecanamide, n-[3-[bis(2-hydroxyethyl)amino]propyl]-" "n-(3-(bis(2-hydroxyethyl)amino)propyl)myristamide" "n-myristoylamidopropyl-n,n-bis(2-hydroxyethyl)amine" );
standardThermochemistry
{
    dHf_298   -772810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1159.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76450.0
}
