/*--------------------------------*- Choupo -*-----------------------*\
  Component: docosane, 1-iodo-  (C22H45I, CAS 62127-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        docosane1Iodo;
formula     C22H45I;
CAS         62127-53-1;
InChIKey    QQTWESGWRGHHPL-UHFFFAOYSA-N;
MW          436.502;      // g/mol [origin=calculated method=formula-sum]
Tc          979.67;      // K   [origin=predictive method=joback]
Pc          8.900;      // bar [origin=predictive method=joback]
omega       0.8072;      // -   [origin=predictive method=lee-kesler]
Tb          796.10;      // K   [origin=predictive method=joback]
HvapTb      73939.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.419 2.13282 -0.0012544 2.905e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 21; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 21; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyldocosane" "agn-pc-00lpyz" );
standardThermochemistry
{
    dHf_298   -420540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1068.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192480.0
}
