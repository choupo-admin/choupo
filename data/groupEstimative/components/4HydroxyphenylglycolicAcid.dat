/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxyphenylglycolic acid  (C8H8O4, CAS 1198-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxyphenylglycolicAcid;
formula     C8H8O4;
CAS         1198-84-1;
InChIKey    YHXHKYRQLYQUIH-UHFFFAOYSA-N;
MW          168.148;      // g/mol [origin=calculated method=formula-sum]
Tc          950.51;      // K   [origin=predictive method=joback]
Pc          57.654;      // bar [origin=predictive method=joback]
omega       1.5268;      // -   [origin=predictive method=lee-kesler]
Tb          727.19;      // K   [origin=predictive method=joback]
HvapTb      82147.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.0 0.9302 -0.00080516 2.799e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-hydroxyphenyl)-2-oxidanyl-ethanoic acid" "4-hydroxymandelic acid" "2-hydroxy-2-(4-hydroxyphenyl)acetic acid" "p-hydroxymandelic acid" "4-hydroxymandelate" "dl-4-hydroxymandelic acid" "hydroxy(4-hydroxyphenyl)acetic acid" "alpha,4-dihydroxybenzeneacetic acid" "4-hydroxymandelic acid hydrate" "hydroxy(4-hydroxyphenyl)acetate" "d-p-hydroxymandelate" "l-p-hydroxymandelate" );
standardThermochemistry
{
    dHf_298   -657010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-508900.0
}
