/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxepanemethanol, 3,7,7-trimethyl-  (C10H20O2, CAS 71077-32-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Oxepanemethanol377Trimethyl;
formula     C10H20O2;
CAS         71077-32-2;
InChIKey    NRHSOPLJFZHMIN-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          760.75;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.7754;      // -   [origin=predictive method=lee-kesler]
Tb          562.25;      // K   [origin=predictive method=joback]
HvapTb      57875.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.429 1.33626 -0.0009931 3.302e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,7,7-trimethyloxepan-2-yl)methanol" "3,7,7-trimethyloxepane-2-methanol" "2-oxepanemethanol,3,7,7-trimethyl-" "2-hydroxymethyl-3,7,7-trimethyloxepane" );
gibbsFormation
{
    dHf_298   -511240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198180.0
    phase     gas;
}
