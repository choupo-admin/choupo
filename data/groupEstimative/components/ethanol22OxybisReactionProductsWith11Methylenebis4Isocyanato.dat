/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2,2'-oxybis-, reaction products with 1,1'-methylenebis(4-isocyanatocyclohexane) and tdi  (C28H38N4O7, CAS 70750-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol22OxybisReactionProductsWith11Methylenebis4Isocyanato;
formula     C28H38N4O7;
CAS         70750-06-0;
InChIKey    UFHMJXAAVIIKLE-UHFFFAOYSA-N;
MW          542.633;      // g/mol [origin=calculated method=formula-sum]
Tc          1745.74;      // K   [origin=predictive method=joback]
Pc          11.306;      // bar [origin=predictive method=joback]
omega       0.7550;      // -   [origin=predictive method=lee-kesler]
Tb          1382.90;      // K   [origin=predictive method=joback]
HvapTb      156246.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 4; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group OH; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:4
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCd; count 4; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 2; } { group O; count 1; } { group dO_oth; count 4; } { group Nd; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diisocyanato-2-methyl-benzene;2-(2-hydroxyethyloxy)ethanol;1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane" "1,3-diisocyanato-2-methyl-benzene; 2-(2-hydroxyethoxy)ethanol; 1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane" "1,3-diisocyanato-2-methylbenzene; 2-(2-hydroxyethoxy)ethanol; 1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane" );
