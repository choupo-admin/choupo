/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxyethyl)iminodiacetic acid  (C6H11NO5, CAS 93-62-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2HydroxyethylIminodiaceticAcid;
formula     C6H11NO5;
CAS         93-62-9;
InChIKey    JYXGIOKAKDAARW-UHFFFAOYSA-N;
MW          177.156;      // g/mol [origin=calculated method=formula-sum]
Tc          924.97;      // K   [origin=predictive method=joback]
Pc          42.943;      // bar [origin=predictive method=joback]
omega       1.7735;      // -   [origin=predictive method=lee-kesler]
Tb          732.52;      // K   [origin=predictive method=joback]
HvapTb      82000.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.234 0.8333 -0.0005908 1.634e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group CH2N; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group OH; count 1; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-hydroxyethyl(2-hydroxy-2-oxoethyl)amino]ethanoic acid" "heida" "glycine, n-(carboxymethyl)-n-(2-hydroxyethyl)-" "ethanol diglycine" "usaf do-37" "ethanolamine-n,n-diacetic acid" "hydroxyethylnitrilodiacetic acid" "n-hydroxyethyliminodiacetic acid" "(hydroxyethylimino)diacetic acid" "2-hydroxyethylaminodiacetic acid" "2-hydroxyethylamino diacetic acid" "(2-hydroxyethyl)iminodiacetic acid" );
standardThermochemistry
{
    dHf_298   -952410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-714220.0
}
