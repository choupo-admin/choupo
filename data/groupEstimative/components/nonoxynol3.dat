/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonoxynol-3  (C19H32O3, CAS 20427-84-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonoxynol3;
formula     C19H32O3;
CAS         20427-84-3;
InChIKey    BLXVTZPGEOGTGG-UHFFFAOYSA-N;
MW          308.462;      // g/mol [origin=calculated method=formula-sum]
Tc          989.46;      // K   [origin=predictive method=joback]
Pc          14.048;      // bar [origin=predictive method=joback]
omega       1.1936;      // -   [origin=predictive method=lee-kesler]
Tb          803.00;      // K   [origin=predictive method=joback]
HvapTb      82325.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.302 1.57802 -0.00078236 1.157e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(4-nonylphenoxy)ethoxy]ethanol" "alfenol" "agral" "synperonic nx" "agral plus" "adekatol np" "alcosist pn" "alkasurf np" "lissapol nx" "tergetol np" "antarox co" "nonoxynol-4" );
gibbsFormation
{
    dHf_298   -627100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     856.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-134940.0
    phase     gas;
}
