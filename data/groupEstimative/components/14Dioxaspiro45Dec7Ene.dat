/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dioxaspiro(4.5)dec-7-ene  (C8H12O2, CAS 7092-24-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dioxaspiro45Dec7Ene;
formula     C8H12O2;
CAS         7092-24-2;
InChIKey    AHIKUUYIVLCZGL-UHFFFAOYSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          710.76;      // K   [origin=predictive method=joback]
Pc          42.719;      // bar [origin=predictive method=joback]
omega       0.3582;      // -   [origin=predictive method=lee-kesler]
Tb          471.17;      // K   [origin=predictive method=joback]
HvapTb      42386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.86 1.2836 -0.00121368 4.76e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dioxaspiro[4.5]dec-7-ene" "1,4-dioxaspiro[4.5]dec-7-en" "1,4-dioxaspiro[4.5]dec-8-ene" );
gibbsFormation
{
    dHf_298   -258130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     338.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50480.0
    phase     gas;
}
