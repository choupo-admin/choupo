/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptadecanal  (C17H34O, CAS 629-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptadecanal;
formula     C17H34O;
CAS         629-90-3;
InChIKey    PIYDVAYKYBWPPY-UHFFFAOYSA-N;
MW          254.458;      // g/mol [origin=calculated method=formula-sum]
Tc          801.34;      // K   [origin=predictive method=joback]
Pc          12.977;      // bar [origin=predictive method=joback]
omega       0.8984;      // -   [origin=predictive method=lee-kesler]
Tb          637.22;      // K   [origin=predictive method=joback]
HvapTb      60156.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.165 1.59332 -0.000894 1.89e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-heptadecanal" "heptadecanaldehyde" "heptadecyl aldehyde" "1-heptadecanal;margaric aldehyde; n-heptadecanal" );
standardThermochemistry
{
    dHf_298   -479790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     836.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-7260.0
}
