/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-fluoro-1-indanone  (C9H7FO, CAS 700-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Fluoro1Indanone;
formula     C9H7FO;
CAS         700-84-5;
InChIKey    WVPPBVAMKNQXJA-UHFFFAOYSA-N;
MW          150.152;      // g/mol [origin=calculated method=formula-sum]
Tc          754.11;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       0.4976;      // -   [origin=predictive method=lee-kesler]
Tb          520.66;      // K   [origin=predictive method=joback]
HvapTb      42880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.26 0.6818 -0.00041092 9.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-fluoranyl-2,3-dihydroinden-1-one" "5-fluoroindan-1-one" "5-fluoro-2,3-dihydroinden-1-one" "5-fluoro-2,3-dihydro-1h-inden-1-one" "2,3-dihydro-5-fluoro-1h-inden-1-one" "5-fluoro-l-indanone" "k182" "1h-inden-1-one, 5-fluoro-2,3-dihydro-" "5-fluoro-2,3-dihydroinden-1-one;5-fiuoro-1-indonone;" );
gibbsFormation
{
    dHf_298   -256170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     292.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130890.0
    phase     gas;
}
