/*--------------------------------*- Choupo -*-----------------------*\
  Component: pregn-4-ene-3,20-dione, 17-(acetyloxy)-6-methyl-, (6.alpha.)-  (C24H34O4, CAS 1172-82-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pregn4Ene320Dione17Acetyloxy6Methyl6Alpha;
formula     C24H34O4;
CAS         1172-82-3;
InChIKey    PSGAAPLEWMOORI-UHFFFAOYSA-N;
MW          386.532;      // g/mol [origin=calculated method=formula-sum]
Tc          1215.53;      // K   [origin=predictive method=joback]
Pc          13.546;      // bar [origin=predictive method=joback]
omega       0.9448;      // -   [origin=predictive method=lee-kesler]
Tb          967.79;      // K   [origin=predictive method=joback]
HvapTb      84504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-286.38 3.2691 -0.00292514 1.13166e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 4; } { group C; count 3; } { group CH=C; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(17-ethanoyl-6,10,13-trimethyl-3-oxidanylidene-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthren-17-yl) ethanoate" "agn-pc-00hrq4" "6-methyl-3,20-dioxopregn-4-en-17-yl acetate" "(6beta)-6-methyl-3,20-dioxopregn-4-en-17-yl acetate" "(6beta,8alpha,14beta)-6-methyl-3,20-dioxopregn-4-en-17-yl acetate" "progestin; lutren; lutein; flavolutan; corporin; luteal hormone; 4-pregnene-3,20-dione" "(17-acetyl-6,10,13-trimethyl-3-oxo-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthren-17-yl) acetate" "[(6s,8s,9r,10r,13s,14r,17r)-17-acetyl-6,10,13-trimethyl-3-oxo-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthren-17-yl] acetate" );
standardThermochemistry
{
    dHf_298   -814840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     866.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-247450.0
}
