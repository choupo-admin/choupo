/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl p-cumylphenyl ether  (C22H22O, CAS 68443-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylPCumylphenylEther;
formula     C22H22O;
CAS         68443-34-5;
InChIKey    IZLBYQPKAHATAF-UHFFFAOYSA-N;
MW          302.417;      // g/mol [origin=calculated method=formula-sum]
Tc          1063.11;      // K   [origin=predictive method=joback]
Pc          18.108;      // bar [origin=predictive method=joback]
omega       0.7228;      // -   [origin=predictive method=lee-kesler]
Tb          807.17;      // K   [origin=predictive method=joback]
HvapTb      73170.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.499 1.86024 -0.00126036 3.193e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 14; } { group AC; count 4; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylmethoxy-4-(2-phenylpropan-2-yl)benzene" "1-benzyloxy-4-(1-methyl-1-phenylethyl)benzene" "benzene, 1-(1-methyl-1-phenylethyl)-4-(phenylmethoxy)-" );
gibbsFormation
{
    dHf_298   59740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     659.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=359800.0
    phase     gas;
}
