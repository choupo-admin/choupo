/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxypropyl)-n'-(2-(2-hydroxypropyl)aminoethyl)piperazine  (C12H27N3O2, CAS 68310-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2HydroxypropylN22HydroxypropylAminoethylPiperazine;
formula     C12H27N3O2;
CAS         68310-64-5;
InChIKey    XANQSUUVEHXZHA-UHFFFAOYSA-N;
MW          245.367;      // g/mol [origin=calculated method=formula-sum]
Tc          926.32;      // K   [origin=predictive method=joback]
Pc          25.689;      // bar [origin=predictive method=joback]
omega       1.6534;      // -   [origin=predictive method=lee-kesler]
Tb          748.37;      // K   [origin=predictive method=joback]
HvapTb      85804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.696 1.71544 -0.0011992 3.331e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 2; } { group OH; count 2; } { group CH2NH; count 1; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group CH2_ring; count 4; } { group OH; count 2; } { group NH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[4-(2-oxidanylpropyl)piperazin-1-yl]ethylamino]propan-2-ol" "1-(4-{2-[(2-hydroxypropyl)amino]ethyl}piperazin-1-yl)propan-2-ol" "1-[2-[4-(2-hydroxypropyl)piperazin-1-yl]ethylamino]propan-2-ol" "1-piperazineethanol, 4-(2-((2-hydroxypropyl)amino)ethyl)-alpha-methyl-" "1-piperazineethanol, 4-[2-[(2-hydroxypropyl)amino]ethyl]-.alpha.-methyl-" "4-(2-((2-hydroxypropyl)amino)ethyl)-alpha-methylpiperazine-1-ethanol" );
standardThermochemistry
{
    dHf_298   -330520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     750.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138950.0
}
