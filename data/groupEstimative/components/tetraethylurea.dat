/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraethylurea  (C9H20N2O, CAS 1187-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraethylurea;
formula     C9H20N2O;
CAS         1187-03-7;
InChIKey    UWHSPZZUAYSGTB-UHFFFAOYSA-N;
MW          172.272;      // g/mol [origin=calculated method=formula-sum]
Tc          655.19;      // K   [origin=predictive method=joback]
Pc          24.435;      // bar [origin=predictive method=joback]
omega       0.6993;      // -   [origin=predictive method=lee-kesler]
Tb          484.27;      // K   [origin=predictive method=joback]
HvapTb      46460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.316 1.07868 -0.0006723 1.6166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH2N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3,3-tetraethylurea" "urea, tetraethyl-" "n,n,n',n'-tetraethylurea" "urea, n,n,n',n'-tetraethyl-" "urea, 1,1,3,3-tetraethyl-" "teu" "tetraethyl-urea" "1,1,3,3-tetraethyl urea" "urea,n,n,n',n'-tetraethyl-" "uwhspzzuaysgtb-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -206610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117540.0
}
