/*--------------------------------*- Choupo -*-----------------------*\
  Component: octyl (diethylamino)oxoacetate  (C14H27NO3, CAS 60254-67-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octylDiethylaminoOxoacetate;
formula     C14H27NO3;
CAS         60254-67-3;
InChIKey    XJSRRFWDVFYAIG-UHFFFAOYSA-N;
MW          257.374;      // g/mol [origin=calculated method=formula-sum]
Tc          816.91;      // K   [origin=predictive method=joback]
Pc          16.051;      // bar [origin=predictive method=joback]
omega       0.9805;      // -   [origin=predictive method=lee-kesler]
Tb          644.45;      // K   [origin=predictive method=joback]
HvapTb      62954.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.239 1.37496 -0.0007371 1.2666e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group COO; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group CdO; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octyl 2-(diethylamino)-2-oxidanylidene-ethanoate" "octyl n,n-diethyloxamate" "acetic acid, (diethylamino)oxo-, octyl ester" "octyl 2-(diethylamino)-2-oxoacetate" );
standardThermochemistry
{
    dHf_298   -694620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     795.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-261510.0
}
