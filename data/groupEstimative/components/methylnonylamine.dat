/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylnonylamine  (C10H23N, CAS 39093-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylnonylamine;
formula     C10H23N;
CAS         39093-27-1;
InChIKey    OZIXTIPURXIEMB-UHFFFAOYSA-N;
MW          157.301;      // g/mol [origin=calculated method=formula-sum]
Tc          645.02;      // K   [origin=predictive method=joback]
Pc          21.335;      // bar [origin=predictive method=joback]
omega       0.6509;      // -   [origin=predictive method=lee-kesler]
Tb          478.57;      // K   [origin=predictive method=joback]
HvapTb      44290.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.412 1.03004 -0.0005688 1.183e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylnonan-1-amine" "methyl-nonyl-amine" "1-nonanamine, n-methyl-" "n-methyl n-nonylamine" );
gibbsFormation
{
    dHf_298   -196260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122710.0
    phase     gas;
}
