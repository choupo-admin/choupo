/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dimethyltetralin  (C12H16, CAS 4175-54-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dimethyltetralin;
formula     C12H16;
CAS         4175-54-6;
InChIKey    KNQXALMJMHIHQH-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          736.55;      // K   [origin=predictive method=joback]
Pc          26.791;      // bar [origin=predictive method=joback]
omega       0.3899;      // -   [origin=predictive method=lee-kesler]
Tb          512.16;      // K   [origin=predictive method=joback]
HvapTb      45020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.05 1.12024 -0.00071156 1.734e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethyl-1,2,3,4-tetrahydronaphthalene" "naphthalene, 1,2,3,4-tetrahydro-1,4-dimethyl-" "1,4-dimethyl-1,2,3,4-tetrahydro-naphthalene" );
gibbsFormation
{
    dHf_298   -19650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193880.0
    phase     gas;
}
