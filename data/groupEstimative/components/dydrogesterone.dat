/*--------------------------------*- Choupo -*-----------------------*\
  Component: dydrogesterone  (C21H28O2, CAS 152-62-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dydrogesterone;
formula     C21H28O2;
CAS         152-62-5;
InChIKey    JGMOKGBVKVMRFX-HQZYFCCVSA-N;
MW          312.453;      // g/mol [origin=calculated method=formula-sum]
Tc          1097.62;      // K   [origin=predictive method=joback]
Pc          17.217;      // bar [origin=predictive method=joback]
omega       0.7980;      // -   [origin=predictive method=lee-kesler]
Tb          844.52;      // K   [origin=predictive method=joback]
HvapTb      72171.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-257.23 2.71746 -0.00236662 8.8746e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 4; } { group C; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9r,10s,13s,14s,17s)-17-ethanoyl-10,13-dimethyl-1,2,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-3-one" "isopregnenone" "hydrogesterone" "duphaston" "hydrogestrone" "dufaston" "gestatron" "terolut" "diphaston" "duvaron" "gynorest" "retrone" );
standardThermochemistry
{
    dHf_298   -372760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80820.0
}
