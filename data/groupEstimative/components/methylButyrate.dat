/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl butyrate  (C5H10O2, CAS 623-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylButyrate;
formula     C5H10O2;
CAS         623-42-7;
InChIKey    UUIQMZJEGPQKFD-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          546.51;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.4006;      // -   [origin=predictive method=lee-kesler]
Tb          372.22;      // K   [origin=predictive method=joback]
HvapTb      34131.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.752 0.42404 -0.0001536 -8.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl butanoate" "butanoic acid, methyl ester" "butyric acid, methyl ester" "butyric acid methyl ester" "methyl n-butyrate" "methyl-n-butyrate" "methyl n-butanoate" "methyl butyrate (natural)" "butanoic acid methyl ester" "n-butyric acid methyl ester" "we(1:0/4:0)" "5adc8486-f8c0-4a7a-acd5-2234d52de6e0" );
standardThermochemistry
{
    dHf_298   -463810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319150.0
}
