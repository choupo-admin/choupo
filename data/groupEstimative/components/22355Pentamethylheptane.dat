/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,3,5,5-pentamethylheptane  (C12H26, CAS 62198-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22355Pentamethylheptane;
formula     C12H26;
CAS         62198-86-1;
InChIKey    OSZLORKBJVWZNT-UHFFFAOYSA-N;
MW          170.34;      // g/mol [origin=calculated method=formula-sum]
Tc          651.85;      // K   [origin=predictive method=joback]
Pc          18.515;      // bar [origin=predictive method=joback]
omega       0.3733;      // -   [origin=predictive method=lee-kesler]
Tb          467.26;      // K   [origin=predictive method=joback]
HvapTb      39326.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.648 1.40144 -0.0009758 2.749e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -313790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53400.0
    phase     gas;
}
