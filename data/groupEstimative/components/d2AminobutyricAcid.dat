/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-2-aminobutyric acid  (C4H9NO2, CAS 2623-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        d2AminobutyricAcid;
formula     C4H9NO2;
CAS         2623-91-8;
InChIKey    QWCKQJZIFLGMSD-GSVOUGTGSA-N;
MW          103.121;      // g/mol [origin=calculated method=formula-sum]
Tc          718.43;      // K   [origin=predictive method=joback]
Pc          47.694;      // bar [origin=predictive method=joback]
omega       0.7442;      // -   [origin=predictive method=lee-kesler]
Tb          508.72;      // K   [origin=predictive method=joback]
HvapTb      51915.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.661 0.50242 -0.000313 7.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanylbutanoic acid" "(r)-2-aminobutanoic acid" "d-(-)-2-aminobutyric acid" "d-alpha-aminobutyric acid" "(2r)-2-aminobutanoic acid" "d-2-aminobutyrate" "(r)-(-)-2-aminobutyric acid" "d-2-aminobuttersaeure" "d-2-aminobutanoic acid" "alpha-aminobutyric acid" "h-abu-oh" "d-ethylglycine" );
standardThermochemistry
{
    dHf_298   -447650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-297100.0
}
