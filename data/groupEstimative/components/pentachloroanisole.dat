/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentachloroanisole  (C7H3Cl5O, CAS 1825-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentachloroanisole;
formula     C7H3Cl5O;
CAS         1825-21-4;
InChIKey    BBABSCYTNHOKOG-UHFFFAOYSA-N;
MW          280.35;      // g/mol [origin=calculated method=formula-sum]
Tc          864.00;      // K   [origin=predictive method=joback]
Pc          29.666;      // bar [origin=predictive method=joback]
omega       0.6145;      // -   [origin=predictive method=lee-kesler]
Tb          620.91;      // K   [origin=predictive method=joback]
HvapTb      61097.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (124.07 0.26322 -4.4e-05 -3.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group CH3O; count 1; } { group ACCl; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dC_ring; count 6; } { group Cl; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(chloranyl)-6-methoxy-benzene" "benzene, pentachloromethoxy-" "pentachloranisole" "pentachloromethoxybenzene" "methyl pentachlorophenate" "anisole, 2,3,4,5,6-pentachloro-" "methyl pentachlorophenyl ester" "methyl pentachlorophenyl ether" "pentachlorophenyl methyl ether" "ether, methyl pentachlorophenyl" "2,3,4,5,6-pentachloroanisole" "1,2,3,4,5-pentachloro-6-methoxybenzene" );
standardThermochemistry
{
    dHf_298   -219550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-92330.0
}
