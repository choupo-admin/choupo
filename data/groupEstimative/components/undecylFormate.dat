/*--------------------------------*- Choupo -*-----------------------*\
  Component: undecyl formate  (C12H24O2, CAS 5454-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H24O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        undecylFormate;
formula     C12H24O2;
CAS         5454-24-0;
InChIKey    OASFNORBKVGDRW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          200.322;      // g/mol [origin=calculated method=formula-sum]
Tc          609.93;      // K   [origin=predictive method=joback]
Pc          17.985;      // bar [origin=predictive method=joback]
omega       0.5284;      // -   [origin=predictive method=lee-kesler]
Tb          450.58;      // K   [origin=predictive method=joback]
HvapTb      39933.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.52 1.15192 -0.000782 2.283e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecyl methanoate" "1-undecanol, formate" );
standardThermochemistry
{
    dHf_298   -214560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     806.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94120.0
}
