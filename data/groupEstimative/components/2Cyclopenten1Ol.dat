/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopenten-1-ol  (C5H8O, CAS 3212-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopenten1Ol;
formula     C5H8O;
CAS         3212-60-0;
InChIKey    PSBABBDEUFNFKJ-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          611.94;      // K   [origin=predictive method=joback]
Pc          51.757;      // bar [origin=predictive method=joback]
omega       0.6029;      // -   [origin=predictive method=lee-kesler]
Tb          420.62;      // K   [origin=predictive method=joback]
HvapTb      43952.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.07 0.5885 -0.00039328 1.018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopent-2-en-1-ol" "2-cyclopentenol" "cyclopent-2-enol" );
gibbsFormation
{
    dHf_298   -180500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     313.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79090.0
    phase     gas;
}
