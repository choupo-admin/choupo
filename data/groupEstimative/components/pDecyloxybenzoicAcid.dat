/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-decyloxybenzoic acid  (C17H26O3, CAS 5519-23-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pDecyloxybenzoicAcid;
formula     C17H26O3;
CAS         5519-23-3;
InChIKey    NZNICZRIRMGOFG-UHFFFAOYSA-N;
MW          278.392;      // g/mol [origin=calculated method=formula-sum]
Tc          988.99;      // K   [origin=predictive method=joback]
Pc          16.498;      // bar [origin=predictive method=joback]
omega       1.1105;      // -   [origin=predictive method=lee-kesler]
Tb          788.15;      // K   [origin=predictive method=joback]
HvapTb      75948.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.071 1.46802 -0.00082676 1.649e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-decoxybenzoic acid" "4-(decyloxy)benzoic acid" "4-n-decyloxybenzoic acid" "4-decyloxybenzoic acid" "t520" "benzoicacid, p-(decyloxy)- (6ci,7ci,8ci);4-(decyloxy)benzoic acid;4-(n-decyloxy)benzoic acid;p-(decyloxy)benzoic acid;p-(n-decyloxy)benzoicacid;" );
gibbsFormation
{
    dHf_298   -651640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     770.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253870.0
    phase     gas;
}
