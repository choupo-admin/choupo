/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propylpiperidine  (C8H17N, CAS 5470-02-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propylpiperidine;
formula     C8H17N;
CAS         5470-02-0;
InChIKey    VTDIWMPYBAVEDY-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          606.30;      // K   [origin=predictive method=joback]
Pc          31.740;      // bar [origin=predictive method=joback]
omega       0.3863;      // -   [origin=predictive method=lee-kesler]
Tb          415.03;      // K   [origin=predictive method=joback]
HvapTb      36011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.498 1.04592 -0.0007068 1.891e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-propylpiperidine" "propylpiperidine" "piperidine, n-propyl-" "piperidine, 1-propyl-" "1-propyl-piperidine" );
gibbsFormation
{
    dHf_298   -60100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=171520.0
    phase     gas;
}
