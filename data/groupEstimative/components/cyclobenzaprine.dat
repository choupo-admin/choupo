/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobenzaprine  (C20H21N, CAS 303-53-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobenzaprine;
formula     C20H21N;
CAS         303-53-7;
InChIKey    JURKNVYFZMSNLP-UHFFFAOYSA-N;
MW          275.395;      // g/mol [origin=calculated method=formula-sum]
Tc          983.93;      // K   [origin=predictive method=joback]
Pc          19.237;      // bar [origin=predictive method=joback]
omega       0.7938;      // -   [origin=predictive method=lee-kesler]
Tb          750.17;      // K   [origin=predictive method=joback]
HvapTb      69334.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.498 1.79484 -0.0013365 3.98e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dibenzo[1,2-a:1',2'-e][7]annulen-11-ylidene)-n,n-dimethyl-propan-1-amine" "flexeril" "lisseril" "proheptatriene" "ciclobenzaprina" "proeptatriene" "proheptatrien" "yurelax" "cyclobenzaprinum" "cyclobenz" "fexmid" "10,11-dehydroamitriptyline" );
gibbsFormation
{
    dHf_298   288470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=577740.0
    phase     gas;
}
