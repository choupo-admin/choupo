/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-isopropenylanisole  (C10H12O, CAS 1712-69-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pIsopropenylanisole;
formula     C10H12O;
CAS         1712-69-2;
InChIKey    XCTSGGVBLWBSIJ-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          692.13;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       0.4122;      // -   [origin=predictive method=lee-kesler]
Tb          479.04;      // K   [origin=predictive method=joback]
HvapTb      42612.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.99 0.73214 -0.00039856 7.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-4-prop-1-en-2-yl-benzene" "1-isopropenyl-4-methoxybenzene" "1-methoxy-4-prop-1-en-2-ylbenzene" "1-methoxy-4-(prop-1-en-2-yl)benzene" "pseudoestragole" "ps-estragole" "anisole, p-isopropenyl-" "2-(p-methoxyphenyl)propene" "ghl.pd_mitscher_leg0.11" "2-(p-methoxyphenyl)propylene" "p-methoxy-.alpha.-methylstyrene" "1-isopropenyl-4-methoxy-benzene" );
gibbsFormation
{
    dHf_298   -41250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110390.0
    phase     gas;
}
