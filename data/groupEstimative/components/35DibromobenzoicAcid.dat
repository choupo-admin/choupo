/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dibromobenzoic acid  (C7H4Br2O2, CAS 618-58-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35DibromobenzoicAcid;
formula     C7H4Br2O2;
CAS         618-58-6;
InChIKey    SFTFNJZWZHASAQ-UHFFFAOYSA-N;
MW          279.915;      // g/mol [origin=calculated method=formula-sum]
Tc          934.95;      // K   [origin=predictive method=joback]
Pc          53.907;      // bar [origin=predictive method=joback]
omega       0.9293;      // -   [origin=predictive method=lee-kesler]
Tb          674.23;      // K   [origin=predictive method=joback]
HvapTb      64810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.2 0.5981 -0.00046952 1.44e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group COOH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-bis(bromanyl)benzoic acid" "benzoic acid, 3,5-dibromo-" "3,5-dibromobenzoicacid" "benzoicacid, 3,5-dibromo-" "buttpark 99\57-19" "q650" );
gibbsFormation
{
    dHf_298   -271830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-214060.0
    phase     gas;
}
