/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-bis(3-aminopropyl)-n-(3-(dimethylamino)propyl)propane-1,3-diamine  (C14H35N5, CAS 68527-65-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis3AminopropylN3DimethylaminoPropylPropane13Diamine;
formula     C14H35N5;
CAS         68527-65-1;
InChIKey    CHTMDIPJWQYHKG-UHFFFAOYSA-N;
MW          273.469;      // g/mol [origin=calculated method=formula-sum]
Tc          921.07;      // K   [origin=predictive method=joback]
Pc          16.810;      // bar [origin=predictive method=joback]
omega       1.2215;      // -   [origin=predictive method=lee-kesler]
Tb          740.03;      // K   [origin=predictive method=joback]
HvapTb      78562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.448 1.78164 -0.0010984 2.627e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH2NH2; count 2; } { group CH2NH; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group NH2; count 2; } { group NH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-[3-[3-azanylpropyl-[3-(dimethylamino)propyl]amino]propyl]propane-1,3-diamine" "1,3-propanediamine, n,n'-bis(3-aminopropyl)-n-(3-(dimethylamino)propyl)-" "1,3-propanediamine, n,n'-bis(3-aminopropyl)-n-[3-(dimethylamino)propyl]-" "1,3-propanediamine, n1,n3-bis(3-aminopropyl)-n1-(3-(dimethylamino)propyl)-" "1,3-propanediamine, n1,n3-bis(3-aminopropyl)-n1-[3-(dimethylamino)propyl]-" "n'-[3-[3-aminopropyl-[3-(dimethylamino)propyl]amino]propyl]propane-1,3-diamine" "n-(3-aminopropyl)-n-{3-[(3-aminopropyl)amino]propyl}-n',n'-dimethylpropane-1,3-diamine" );
standardThermochemistry
{
    dHf_298   -76180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     877.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=510850.0
}
