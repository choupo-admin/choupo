/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylvinylethinyl-p-hydroxyphenylmethane  (C13H14O, CAS 63141-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylvinylethinylPHydroxyphenylmethane;
formula     C13H14O;
CAS         63141-79-7;
InChIKey    JOMYANSJBFOTPO-UHFFFAOYSA-N;
MW          186.254;      // g/mol [origin=calculated method=formula-sum]
Tc          839.56;      // K   [origin=predictive method=joback]
Pc          31.811;      // bar [origin=predictive method=joback]
omega       0.5946;      // -   [origin=predictive method=lee-kesler]
Tb          598.06;      // K   [origin=predictive method=joback]
HvapTb      59330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.53 1.24644 -0.00105619 3.6919e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(5-methylhex-4-en-1-yn-3-yl)phenol" "alpha-(2,2-dimethylvinyl)-alpha-ethynyl-p-cresol" "p-cresol, alpha-(2,2-dimethylvinyl)-alpha-ethynyl-" );
gibbsFormation
{
    dHf_298   141620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=308670.0
    phase     gas;
}
