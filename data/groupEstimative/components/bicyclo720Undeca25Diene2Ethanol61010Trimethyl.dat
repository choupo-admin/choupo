/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[7.2.0]undeca-2,5-diene-2-ethanol, 6,10,10-trimethyl-  (C16H26O, CAS 68039-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo720Undeca25Diene2Ethanol61010Trimethyl;
formula     C16H26O;
CAS         68039-25-8;
InChIKey    NCTFJDPCYOHLOD-UHFFFAOYSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          903.76;      // K   [origin=predictive method=joback]
Pc          20.236;      // bar [origin=predictive method=joback]
omega       0.9199;      // -   [origin=predictive method=lee-kesler]
Tb          696.54;      // K   [origin=predictive method=joback]
HvapTb      69023.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.348 1.84606 -0.00140308 4.665e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4,11,11-trimethyl-8-bicyclo[7.2.0]undeca-4,7-dienyl)ethanol" );
gibbsFormation
{
    dHf_298   -323480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35480.0
    phase     gas;
}
