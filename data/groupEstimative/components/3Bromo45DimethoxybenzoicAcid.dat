/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-4,5-dimethoxybenzoic acid  (C9H9BrO4, CAS 20731-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo45DimethoxybenzoicAcid;
formula     C9H9BrO4;
CAS         20731-48-0;
InChIKey    ZODURELBYVOPGP-UHFFFAOYSA-N;
MW          261.071;      // g/mol [origin=calculated method=formula-sum]
Tc          935.79;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       1.0533;      // -   [origin=predictive method=lee-kesler]
Tb          703.65;      // K   [origin=predictive method=joback]
HvapTb      68309.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.49 0.56404 -0.00021788 -8e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 2; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-4,5-dimethoxy-benzoic acid" "5-bromo-3,4-dimethoxybenzoic acid" "benzoic acid,3-bromo-4,5-dimethoxy-" "3-bromo-4,5-dimethoxybenzoic acid;veratricacid, 5-bromo- (6ci,7ci,8ci);" );
standardThermochemistry
{
    dHf_298   -615350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-431170.0
}
