/*--------------------------------*- Choupo -*-----------------------*\
  Component: aziridine, 1-methyl-  (C3H7N, CAS 1072-44-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aziridine1Methyl;
formula     C3H7N;
CAS         1072-44-2;
InChIKey    XLJQPXVBQNJNLW-UHFFFAOYSA-N;
MW          57.096;      // g/mol [origin=calculated method=formula-sum]
Tc          456.41;      // K   [origin=predictive method=joback]
Pc          53.279;      // bar [origin=predictive method=joback]
omega       0.2442;      // -   [origin=predictive method=lee-kesler]
Tb          287.82;      // K   [origin=predictive method=joback]
HvapTb      24365.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.59 0.59972 -0.000574 2.193e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylaziridine" "n-methylaziridine" "n-methylethylenimine" "1-methylethylenimine" "tl 37" "1-methylaziridine;1-methylethylenimine; n-methylaziridine; n-methylethylenimine" );
gibbsFormation
{
    dHf_298   61580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     221.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165720.0
    phase     gas;
}
