/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(diethoxymethyl)benzaldehyde  (C12H16O3, CAS 81172-89-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H16O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4DiethoxymethylBenzaldehyde;
formula     C12H16O3;
CAS         81172-89-6;
InChIKey    HTMXMFARWHNJDW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          208.257;      // g/mol [origin=calculated method=formula-sum]
Tc          727.68;      // K   [origin=predictive method=joback]
Pc          24.124;      // bar [origin=predictive method=joback]
omega       0.5556;      // -   [origin=predictive method=lee-kesler]
Tb          526.64;      // K   [origin=predictive method=joback]
HvapTb      47303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.192 0.89304 -0.00052736 1.188e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CHO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "terephthalaldehyde mono(diethyl acetal)" "terephthalaldehyde diethyl acetal" "terephthaldialdehyde monodiethyl acetal" "terephthalaldehyde mono-(diethyl acetal)" );
standardThermochemistry
{
    dHf_298   -259220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15540.0
}
