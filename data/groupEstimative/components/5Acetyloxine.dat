/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-acetyloxine  (C11H9NO2, CAS 2598-31-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Acetyloxine;
formula     C11H9NO2;
CAS         2598-31-4;
InChIKey    HZTCLDNADGMACV-UHFFFAOYSA-N;
MW          187.198;      // g/mol [origin=calculated method=formula-sum]
Tc          949.28;      // K   [origin=predictive method=joback]
Pc          44.444;      // bar [origin=predictive method=joback]
omega       0.8937;      // -   [origin=predictive method=lee-kesler]
Tb          690.11;      // K   [origin=predictive method=joback]
HvapTb      70628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.66 1.06708 -0.0009224 3.2726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 1; } { group CH3CO; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group CdO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(8-oxidanylquinolin-5-yl)ethanone" "5-acetyl-8-hydroxyquinoline" "quinacetol sulfate" "8-hydroxy-5-quinolyl methyl ketone" "1-(8-hydroxyquinolin-5-yl)ethanone" "1-(8-hydroxy-5-quinolinyl)ethanone" "quinacetol sulfate [iso]" "ethanone, 1-(8-hydroxy-5-quinolinyl)-" "ketone, 8-hydroxy-5-quinolyl methyl" "5-acetyl-8-quinolinol" "1-(8-hydroxy-5-quinolinyl)-ethanone" "1-(8-hydroxy(quinolin-5-yl))ethanone" );
gibbsFormation
{
    dHf_298   -111340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=44680.0
    phase     gas;
}
