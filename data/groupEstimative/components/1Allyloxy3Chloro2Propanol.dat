/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-allyloxy-3-chloro-2-propanol  (C6H11ClO2, CAS 4638-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Allyloxy3Chloro2Propanol;
formula     C6H11ClO2;
CAS         4638-03-3;
InChIKey    DLVRPVNJFWEIFV-UHFFFAOYSA-N;
MW          150.602;      // g/mol [origin=calculated method=formula-sum]
Tc          658.94;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       0.8555;      // -   [origin=predictive method=lee-kesler]
Tb          485.15;      // K   [origin=predictive method=joback]
HvapTb      51366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.443 0.5373 -0.0002685 4.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2Cl; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-prop-2-enoxy-propan-2-ol" "allyl-chlorhydrinether" "1-(allyloxy)-3-chloropropan-2-ol" "allyl 3-chloro-2-hydroxypropyl ether" "2-propanol, 1-(allyloxy)-3-chloro-" "ether, allyl (3-chloro-2-hydroxypropyl)" "2-propanol, 1-chloro-3-(2-propenyloxy)-" "2-propanol, 1-propenyloxy-3-chloro-" "1-chloro-3-(2'-propenoxy)-2-propanol" "1-allyl-oxy-3-chloro-2-propanol" "1-chloro-3-prop-2-enoxypropan-2-ol" );
gibbsFormation
{
    dHf_298   -347210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-168710.0
    phase     gas;
}
