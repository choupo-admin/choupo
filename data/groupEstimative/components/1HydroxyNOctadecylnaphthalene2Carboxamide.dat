/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hydroxy-n-octadecylnaphthalene-2-carboxamide  (C29H45NO2, CAS 20043-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1HydroxyNOctadecylnaphthalene2Carboxamide;
formula     C29H45NO2;
CAS         20043-92-9;
InChIKey    BKWIMUORHSANHY-UHFFFAOYSA-N;
MW          439.684;      // g/mol [origin=calculated method=formula-sum]
Tc          1349.04;      // K   [origin=predictive method=joback]
Pc          9.669;      // bar [origin=predictive method=joback]
omega       0.9020;      // -   [origin=predictive method=lee-kesler]
Tb          1098.42;      // K   [origin=predictive method=joback]
HvapTb      110922.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.293 2.81952 -0.00194094 5.5016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group ACH; count 6; } { group AC; count 3; } { group ACOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-octadecyl-1-oxidanyl-naphthalene-2-carboxamide" "1-hydroxy-n-octadecyl-2-naphthamide" "2-naphthamide, 1-hydroxy-n-octadecyl-" "2-naphthalenecarboxamide,1-hydroxy-n-octadecyl-" );
gibbsFormation
{
    dHf_298   -462180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1157.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=208580.0
    phase     gas;
}
