/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dichloroiodobenzene  (C6H3Cl2I, CAS 19230-28-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dichloroiodobenzene;
formula     C6H3Cl2I;
CAS         19230-28-5;
InChIKey    ZMPGXSFTXBOKFM-UHFFFAOYSA-N;
MW          272.89;      // g/mol [origin=calculated method=formula-sum]
Tc          812.02;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       0.3560;      // -   [origin=predictive method=lee-kesler]
Tb          541.52;      // K   [origin=predictive method=joback]
HvapTb      50693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.6 0.4285 -0.00032192 9.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCl; count 2; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)-2-iodanyl-benzene" "1,3-dichloro-2-iodobenzene" "benzene, 1,3-dichloro-2-iodo-" "1,3-dichloro-2-iodobenzene;1-iodo-2,6-dichlorobenzene;2,6-dichloro-1-iodobenzene;2,6-dichloroiodobenzene;2,6-dichlorophenyl iodide;" );
gibbsFormation
{
    dHf_298   91810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127050.0
    phase     gas;
}
