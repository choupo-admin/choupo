/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-indanone  (C9H8O, CAS 83-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Indanone;
formula     C9H8O;
CAS         83-33-0;
InChIKey    QNXSIUBBGPHDDE-UHFFFAOYSA-N;
MW          132.162;      // g/mol [origin=calculated method=formula-sum]
Tc          761.78;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.4382;      // -   [origin=predictive method=lee-kesler]
Tb          516.41;      // K   [origin=predictive method=joback]
HvapTb      43035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.65 0.7295 -0.00046156 1.11e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydroinden-1-one" "indan-1-one" "indanone" "alpha-hydrindone" "1h-inden-1-one, 2,3-dihydro-" "hydrindone" "2,3-dihydro-1h-inden-1-one" "alpha-indanone" "1-indone" ".alpha.-indanone" "indan-1-on" ".alpha.-hydrindone" );
gibbsFormation
{
    dHf_298   -48590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     267.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=73550.0
    phase     gas;
}
