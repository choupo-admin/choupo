/*--------------------------------*- Choupo -*-----------------------*\
  Component: equilenin  (C18H18O2, CAS 517-09-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        equilenin;
formula     C18H18O2;
CAS         517-09-9;
InChIKey    PDRGHUMCVRDZLQ-WMZOPIPTSA-N;
MW          266.34;      // g/mol [origin=calculated method=formula-sum]
Tc          1102.87;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.9540;      // -   [origin=predictive method=lee-kesler]
Tb          833.49;      // K   [origin=predictive method=joback]
HvapTb      77010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-178.31 2.08262 -0.0019282 7.466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(13s,14s)-13-methyl-3-oxidanyl-12,14,15,16-tetrahydro-11h-cyclopenta[a]phenanthren-17-one" "equilenin solution" "equilenina" "3-hydroxyestra-1,3,5(10),6,8-pentaen-17-one" "d-equilenin" "equ" "3-hydroxy-1,3,5(10),6,8-estrapentaen-17-one" "3-hydroxyoestra-1,3,5(10),6,8-pentaen-17-one" "estra-1,3,5(10),6,8-pentaen-17-one, 3-hydroxy-" "ambap517-09-9" "3-hydroxy-estra-1,3,5(10),6,8-pentaen-17-one" "(13s,14s)-3-hydroxy-13-methyl-12,14,15,16-tetrahydro-11h-cyclopenta[a]phenanthren-17-one" );
gibbsFormation
{
    dHf_298   -170520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127180.0
    phase     gas;
}
