/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclohexene-1-methanol  (C7H12O, CAS 1679-51-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclohexene1Methanol;
formula     C7H12O;
CAS         1679-51-2;
InChIKey    VEIYJWQZNGASMA-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          665.41;      // K   [origin=predictive method=joback]
Pc          41.250;      // bar [origin=predictive method=joback]
omega       0.6713;      // -   [origin=predictive method=lee-kesler]
Tb          470.65;      // K   [origin=predictive method=joback]
HvapTb      48576.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.009 0.7689 -0.00045568 9.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohex-3-en-1-ylmethanol" "3-cyclohexene-1-carbinol" "cyclohexen-4-ylmethanol" "1,2,3,6-tetrahydrobenzyl alcohol" "4-(hydroxymethyl)cyclohexene" "1-cyclohex-3-enylmethanol" "cyclohex-3-ene-1-methanol" "agn-pc-0cr07h" "cyclohex-3-enylmethan-1-ol" "cyclohex-3-en-1-yl-methanol" );
gibbsFormation
{
    dHf_298   -227940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74350.0
    phase     gas;
}
