/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexen-3-ol  (C6H12O, CAS 4798-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexen3Ol;
formula     C6H12O;
CAS         4798-58-7;
InChIKey    KWUXUOPPQQMMIL-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          605.30;      // K   [origin=predictive method=joback]
Pc          37.090;      // bar [origin=predictive method=joback]
omega       0.6894;      // -   [origin=predictive method=lee-kesler]
Tb          432.78;      // K   [origin=predictive method=joback]
HvapTb      45199.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.139 0.63374 -0.00042 1.169e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-4-en-3-ol" ".alpha.-ethyl-.gamma.-methylallyl alcohol" );
gibbsFormation
{
    dHf_298   -207460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-59400.0
    phase     gas;
}
