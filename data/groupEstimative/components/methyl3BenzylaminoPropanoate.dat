/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-(benzylamino)propanoate  (C11H15NO2, CAS 23574-01-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3BenzylaminoPropanoate;
formula     C11H15NO2;
CAS         23574-01-8;
InChIKey    MVZIUHUSHIYYGP-UHFFFAOYSA-N;
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          793.35;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.7530;      // -   [origin=predictive method=lee-kesler]
Tb          586.35;      // K   [origin=predictive method=joback]
HvapTb      56199.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.817 0.99132 -0.0005598 9.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-[(phenylmethyl)amino]propanoate" "methyl n-benzyl-beta-alaninate" "methyl-beta-benzylamino propionate" "b-alanine, n-benzyl-, methyl ester(8ci); methyl 3-(benzylamino)propionate; methyl n-(benzyl)-3-aminopropionate;methyl n-benzyl-b-alaninate;n-benzyl-b-alanine methyl ester" );
standardThermochemistry
{
    dHf_298   -297650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66830.0
}
