/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-bromotetradecanoate  (C16H31BrO2, CAS 14980-92-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Bromotetradecanoate;
formula     C16H31BrO2;
CAS         14980-92-8;
InChIKey    JQQZIRFEGUUJBP-UHFFFAOYSA-N;
MW          335.326;      // g/mol [origin=calculated method=formula-sum]
Tc          868.11;      // K   [origin=predictive method=joback]
Pc          14.006;      // bar [origin=predictive method=joback]
omega       0.9477;      // -   [origin=predictive method=lee-kesler]
Tb          689.62;      // K   [origin=predictive method=joback]
HvapTb      64664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.262 1.51314 -0.0008266 1.557e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-bromanyltetradecanoate" "ethyl 2-bromomyristate" "tetradecanoic acid, 2-bromo-, ethyl ester" "ethyl " "a-bromomyristate" "ethyl-2-bromomyristate" "ethyl alpha-bromomyristate" "ethyl .alpha.-bromomyristate" "tetradecanoic acid,2-bromo-, ethyl ester" "u510" );
gibbsFormation
{
    dHf_298   -669800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     872.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-214650.0
    phase     gas;
}
