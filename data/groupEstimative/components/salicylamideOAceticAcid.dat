/*--------------------------------*- Choupo -*-----------------------*\
  Component: salicylamide o-acetic acid  (C9H9NO4, CAS 25395-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        salicylamideOAceticAcid;
formula     C9H9NO4;
CAS         25395-22-6;
InChIKey    RLISWLLILOTWGG-UHFFFAOYSA-N;
MW          195.174;      // g/mol [origin=calculated method=formula-sum]
Tc          965.98;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       1.1927;      // -   [origin=predictive method=lee-kesler]
Tb          731.51;      // K   [origin=predictive method=joback]
HvapTb      75527.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.051 0.7419 -0.00041626 7.166e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-aminocarbonylphenoxy)ethanoic acid" "(2-carbamoylphenoxy)acetic acid" "2-(2-carbamoylphenoxy)acetic acid" "2-(carboxymethoxy)benzamide" "2-carbamoylphenoxyacetic acid" "o-(carbamylphenoxy)acetic acid" "(o-carbamoylphenoxy)acetic acid" "o-carboxyamidophenoxyacetic acid" "2-aminocarbonyl-phenoxyacetic acid" "acetic acid, (o-carbamoylphenoxy)-" "salicylamide-2-acetic acid" "o-(carboxymethoxy)benzamide" );
standardThermochemistry
{
    dHf_298   -565310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-383700.0
}
