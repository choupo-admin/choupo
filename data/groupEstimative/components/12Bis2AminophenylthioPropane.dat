/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(2-aminophenylthio)propane  (C15H18N2S2, CAS 57545-80-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bis2AminophenylthioPropane;
formula     C15H18N2S2;
CAS         57545-80-9;
InChIKey    JUNGPRNTMDWRKG-UHFFFAOYSA-N;
MW          290.443;      // g/mol [origin=calculated method=formula-sum]
Tc          1168.49;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       1.0171;      // -   [origin=predictive method=lee-kesler]
Tb          888.30;      // K   [origin=predictive method=joback]
HvapTb      89388.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.541 1.2705 -0.00073012 1.348e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACNH2; count 2; } { group CH2S; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH2; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-aminophenyl)sulfanylpropylsulfanyl]aniline" "benzenamine, 2,2'-((1-methyl-1,2-ethanediyl)bis(thio))bis-" "benzenamine, 2,2'-[(1-methyl-1,2-ethanediyl)bis(thio)]bis-" "1,2-bis(o-aminophenylthio)propane" "2,2'-((1-methylethylene)bis(thio))dianiline" "benzenamine,2,2'-[(1-methyl-1,2-ethanediyl)bis(thio)]bis-" );
gibbsFormation
{
    dHf_298   243230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     731.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=477680.0
    phase     gas;
}
