/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(8-chlorooctoxy)oxane  (C13H25ClO2, CAS 19754-57-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        28ChlorooctoxyOxane;
formula     C13H25ClO2;
CAS         19754-57-5;
InChIKey    KTZCUNASYOHWBD-UHFFFAOYSA-N;
MW          248.791;      // g/mol [origin=calculated method=formula-sum]
Tc          795.77;      // K   [origin=predictive method=joback]
Pc          18.515;      // bar [origin=predictive method=joback]
omega       0.7263;      // -   [origin=predictive method=lee-kesler]
Tb          603.39;      // K   [origin=predictive method=joback]
HvapTb      56266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.822 1.3015 -0.0006599 9.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Cl; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(8-chloranyloctoxy)oxane" "2-[(8-chlorooctyl)oxy]tetrahydro-2h-pyran" "2h-pyran, 2-((8-chlorooctyl)oxy)tetrahydro-" "2h-pyran, 2-[(8-chlorooctyl)oxy]tetrahydro-" );
gibbsFormation
{
    dHf_298   -537290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-120020.0
    phase     gas;
}
