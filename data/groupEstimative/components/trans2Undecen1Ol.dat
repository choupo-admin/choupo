/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-2-undecen-1-ol  (C11H22O, CAS 75039-84-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans2Undecen1Ol;
formula     C11H22O;
CAS         75039-84-8;
InChIKey    SKBIQKQBLQHOSU-MDZDMXLPSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          711.58;      // K   [origin=predictive method=joback]
Pc          22.041;      // bar [origin=predictive method=joback]
omega       0.9631;      // -   [origin=predictive method=lee-kesler]
Tb          547.62;      // K   [origin=predictive method=joback]
HvapTb      56717.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.002 1.10282 -0.0006888 1.769e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-undec-2-en-1-ol" "(2e)-2-undecen-1-ol" "2-undecen-1-ol, (2z)-" "undec-2-enol" "cis-2-undecen-1-ol" "1-hydroxy-2-undecene" "(z)-2-undecen-1-ol" "2-undecen-1-ol, (e)-" "2-undecen-1-ol, (z)-" );
gibbsFormation
{
    dHf_298   -305380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14860.0
    phase     gas;
}
