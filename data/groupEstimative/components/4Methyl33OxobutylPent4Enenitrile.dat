/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-3-(3-oxobutyl)pent-4-enenitrile  (C10H15NO, CAS 131447-88-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl33OxobutylPent4Enenitrile;
formula     C10H15NO;
CAS         131447-88-6;
InChIKey    DTWKKDUYCIPQFZ-UHFFFAOYSA-N;
MW          165.236;      // g/mol [origin=calculated method=formula-sum]
Tc          780.64;      // K   [origin=predictive method=joback]
Pc          23.003;      // bar [origin=predictive method=joback]
omega       0.7084;      // -   [origin=predictive method=lee-kesler]
Tb          580.47;      // K   [origin=predictive method=joback]
HvapTb      54100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.793 0.84644 -0.0004989 1.1116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group CH3CO; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CdO; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-oxidanylidene-3-prop-1-en-2-yl-heptanenitrile" "6-oxo-3-prop-1-en-2-ylheptanenitrile" "6-oxo-3-(prop-1-en-2-yl)heptanenitrile" "4-methyl-3-(3-oxobutyl)-4-pentenenitrile" );
standardThermochemistry
{
    dHf_298   -87070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114430.0
}
