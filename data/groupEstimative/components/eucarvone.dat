/*--------------------------------*- Choupo -*-----------------------*\
  Component: eucarvone  (C10H14O, CAS 503-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eucarvone;
formula     C10H14O;
CAS         503-93-5;
InChIKey    QNGQIURXCUHNAT-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          760.86;      // K   [origin=predictive method=joback]
Pc          30.490;      // bar [origin=predictive method=joback]
omega       0.3944;      // -   [origin=predictive method=lee-kesler]
Tb          523.58;      // K   [origin=predictive method=joback]
HvapTb      42797.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.63 1.01846 -0.00075092 2.56e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6,6-trimethylcyclohepta-2,4-dien-1-one" "2,6,6-trimethyl-2,4-cycloheptadien-1-one" "2,4-cycloheptadien-1-one, 2,6,6-trimethyl-" "2, 2,6,6-trimethyl-" "2,6,6-trimethyl-cyclohepta-2,4-dien-1-one" );
gibbsFormation
{
    dHf_298   -219940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32120.0
    phase     gas;
}
