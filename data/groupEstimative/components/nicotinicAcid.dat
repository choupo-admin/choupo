/*--------------------------------*- Choupo -*-----------------------*\
  Component: nicotinic acid  (C6H5NO2, CAS 59-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nicotinicAcid;
formula     C6H5NO2;
CAS         59-67-6;
InChIKey    PVNIIMVLHYAWGP-UHFFFAOYSA-N;
MW          123.111;      // g/mol [origin=calculated method=formula-sum]
Tc          808.76;      // K   [origin=predictive method=joback]
Pc          53.047;      // bar [origin=predictive method=joback]
omega       0.6830;      // -   [origin=predictive method=lee-kesler]
Tb          562.77;      // K   [origin=predictive method=joback]
HvapTb      54600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.81 0.57946 -0.00041566 1.155e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C5H4N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COOH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridine-3-carboxylic acid" "niacin" "3-pyridinecarboxylic acid" "apelagrin" "pellagrin" "acidum nicotinicum" "pelonin" "3-carboxypyridine" "akotin" "daskil" "wampocap" "enduracin" );
standardThermochemistry
{
    dHf_298   -248120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154810.0
}
