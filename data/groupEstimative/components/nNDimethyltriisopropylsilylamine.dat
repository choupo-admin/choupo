/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyltriisopropylsilylamine  (C11H27NSi, CAS 181231-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H27NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nNDimethyltriisopropylsilylamine;
formula     C11H27NSi;
CAS         181231-66-3;
InChIKey    RDGLSXXPVKFUJI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          201.429;      // g/mol [origin=calculated method=formula-sum]
Tc          640.05;      // K   [origin=predictive method=joback]
Pc          17.773;      // bar [origin=predictive method=joback]
omega       0.4101;      // -   [origin=predictive method=lee-kesler]
Tb          463.80;      // K   [origin=predictive method=joback]
HvapTb      41253.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.97 0.98436 -0.000282 -6.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH; count 3; } { group CH3N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-n-tri(propan-2-yl)silyl-methanamine" "(dimethylamino)triisopropylsilane" "n-methyl-n-tri(propan-2-yl)silylmethanamine" "silanamine,n,n-dimethyl-1,1,1-tris(1-methylethyl)-" "(dimethylamino)triisopropylsilane  96;n,n-dimethyltriisopropylsilylamine" );
gibbsFormation
{
    dHf_298   -330300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     698.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40440.0
    phase     gas;
}
