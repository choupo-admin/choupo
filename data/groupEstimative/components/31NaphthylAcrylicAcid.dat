/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(1-naphthyl)acrylic acid  (C13H10O2, CAS 13026-12-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        31NaphthylAcrylicAcid;
formula     C13H10O2;
CAS         13026-12-5;
InChIKey    WPXMLUUYWNHQOR-CMDGGOBGSA-N;
MW          198.221;      // g/mol [origin=calculated method=formula-sum]
Tc          942.48;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.8572;      // -   [origin=predictive method=lee-kesler]
Tb          697.35;      // K   [origin=predictive method=joback]
HvapTb      66232.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.56 1.1675 -0.00094068 3.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 7; } { group AC; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-naphthalen-1-ylprop-2-enoic acid" ".beta.-(1-naphthyl)acrylic acid" "1-naphthylacrylic acid" "(2e)-3-(naphthalen-1-yl)prop-2-enoic acid" "(2e)-3-naphthylprop-2-enoic acid" "1-naphthaleneacrylic acid" "3-(naphthalen-1-yl)acrylic acid" "naphthylacrylicacid" "(e)-3-(1-naphthyl)-2-propenoic acid" "(e)-3-(naphth-1-yl)acrylic acid" "(e)-3-(naphthalen-1-yl)acrylic acid" "3-(naphthalen-1-yl)prop-2-enoic acid" );
standardThermochemistry
{
    dHf_298   -128570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4320.0
}
