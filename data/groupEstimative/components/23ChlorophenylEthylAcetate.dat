/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-chlorophenyl)ethyl acetate  (C10H11ClO2, CAS 33709-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23ChlorophenylEthylAcetate;
formula     C10H11ClO2;
CAS         33709-41-0;
InChIKey    AINURQUNOQXLRL-UHFFFAOYSA-N;
MW          198.646;      // g/mol [origin=calculated method=formula-sum]
Tc          771.46;      // K   [origin=predictive method=joback]
Pc          27.877;      // bar [origin=predictive method=joback]
omega       0.5986;      // -   [origin=predictive method=lee-kesler]
Tb          555.71;      // K   [origin=predictive method=joback]
HvapTb      52584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.492 0.76742 -0.00041016 6.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group CH3COO; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-chlorophenyl)ethyl ethanoate" "phenethyl alcohol, m-chloro-, acetate" "phenethyl alcohol,m-chloro-,acetate" );
gibbsFormation
{
    dHf_298   -357690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-186200.0
    phase     gas;
}
