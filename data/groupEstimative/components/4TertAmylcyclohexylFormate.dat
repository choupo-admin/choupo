/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-amylcyclohexyl formate  (C12H22O2, CAS 67874-73-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H22O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4TertAmylcyclohexylFormate;
formula     C12H22O2;
CAS         67874-73-1;
InChIKey    DYSYPCUGLFVYAR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          665.88;      // K   [origin=predictive method=joback]
Pc          21.295;      // bar [origin=predictive method=joback]
omega       0.2854;      // -   [origin=predictive method=lee-kesler]
Tb          462.23;      // K   [origin=predictive method=joback]
HvapTb      38757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.659 1.37336 -0.0009794 2.816e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2-methylbutan-2-yl)cyclohexyl] methanoate" "4-(1,1-dimethylpropyl)cyclohexyl formate" "cyclohexanol, 4-(1,1-dimethylpropyl)-, formate" "cyclohexanol, 4-(1,1-dimethylpropyl)-, 1-formate" "[4-(2-methylbutan-2-yl)cyclohexyl] formate" );
gibbsFormation
{
    dHf_298   -189330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113700.0
    phase     gas;
}
