/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-(1-piperazinyl)ethyl)ethylenediamine  (C8H20N4, CAS 24028-46-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n21PiperazinylEthylEthylenediamine;
formula     C8H20N4;
CAS         24028-46-4;
InChIKey    WBIWIXJUBVWKLS-UHFFFAOYSA-N;
MW          172.276;      // g/mol [origin=calculated method=formula-sum]
Tc          795.92;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       0.8756;      // -   [origin=predictive method=lee-kesler]
Tb          586.28;      // K   [origin=predictive method=joback]
HvapTb      59846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.296 1.1706 -0.0007382 1.777e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2NH2; count 1; } { group CH2NH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 4; } { group NH2; count 1; } { group NH; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(2-piperazin-1-ylethyl)ethane-1,2-diamine" "1,2-ethanediamine, n-(2-(1-piperazinyl)ethyl)-" "1,2-ethanediamine, n-[2-(1-piperazinyl)ethyl]-" "piperazinylethylethylenediamine" "n-[(2-aminoethyl)2-aminoethyl]piperazine" "1,2-ethanediamine,n1-[2-(1-piperazinyl)ethyl]-" "1,2-ethanediamine,n-[2-(1-piperazinyl)ethyl]- (9ci); piperazine,1-[2-[(2-aminoethyl)amino]ethyl]- (8ci)" );
standardThermochemistry
{
    dHf_298   64970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=415070.0
}
