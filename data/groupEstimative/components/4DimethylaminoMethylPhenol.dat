/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[(dimethylamino)methyl]phenol  (C9H13NO, CAS 103-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4DimethylaminoMethylPhenol;
formula     C9H13NO;
CAS         103-87-7;
InChIKey    NFVPEIKDMMISQO-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          744.15;      // K   [origin=predictive method=joback]
Pc          38.868;      // bar [origin=predictive method=joback]
omega       0.6320;      // -   [origin=predictive method=lee-kesler]
Tb          525.26;      // K   [origin=predictive method=joback]
HvapTb      52961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.809 1.05844 -0.00086596 2.919e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-((dimethylamino)methyl)phenol" "phenol, 4-((dimethylamino)methyl)-" "phenol, 4-[(dimethylamino)methyl]-" "alpha-dimethylamino-p-cresol" "4-(dimethylaminomethyl)phenol" ".alpha.-(dimethylamino)-cresol" "o/p-dimethylaminomethyl phenol" );
standardThermochemistry
{
    dHf_298   -102340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93470.0
}
