/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetramethylsuccinic acid  (C8H14O4, CAS 630-51-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetramethylsuccinicAcid;
formula     C8H14O4;
CAS         630-51-3;
InChIKey    CDPPYCZVWYZBJH-UHFFFAOYSA-N;
MW          174.196;      // g/mol [origin=calculated method=formula-sum]
Tc          887.19;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.9871;      // -   [origin=predictive method=lee-kesler]
Tb          667.20;      // K   [origin=predictive method=joback]
HvapTb      65138.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.13 1.11708 -0.0009002 2.838e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3-tetramethylbutanedioic acid" "tetramethylbutanedioic acid" "butanedioic acid, tetramethyl-" "2,2,3,3-tetramethylsuccinic acid" "2,2,3,3-tetramethylbutane-1,4-dioic acid" "succinic acid, tetramethyl-" "butanedioic acid,2,2,3,3-tetramethyl-" "2,2,3,3-tetramethyl-1,4-butanedioic acid" );
gibbsFormation
{
    dHf_298   -926490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-665660.0
    phase     gas;
}
