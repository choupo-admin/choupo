/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-dimethylaminonaphthalene-1-carboxylic acid  (C13H13NO2, CAS 78062-03-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Dimethylaminonaphthalene1CarboxylicAcid;
formula     C13H13NO2;
CAS         78062-03-0;
InChIKey    LZQKNRRVTOJUHQ-UHFFFAOYSA-N;
MW          215.252;      // g/mol [origin=calculated method=formula-sum]
Tc          943.26;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       0.9607;      // -   [origin=predictive method=lee-kesler]
Tb          710.61;      // K   [origin=predictive method=joback]
HvapTb      68979.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.77 1.21194 -0.00090244 2.657e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 6; } { group AC; count 4; } { group CH3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(dimethylamino)naphthalene-1-carboxylic acid" "4-(dimethylamino)-1-naphthoic acid" "4-(dimethylamino)naphthalenecarboxylic acid" "4-(dimethylamino)-1-naphthalenecarboxylic acid" "1-naphthalenecarboxylicacid, 4-(dimethylamino)-" "1-naphthoicacid, 4-(dimethylamino)- (6ci,7ci); 4-dimethylamino-1-naphthoic acid;4-dimethylaminonaphthalene-1-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -189730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25250.0
}
