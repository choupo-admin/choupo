/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chlorotetradecane  (C14H29Cl, CAS 2425-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chlorotetradecane;
formula     C14H29Cl;
CAS         2425-54-9;
InChIKey    RNHWYOLIEJIAMV-UHFFFAOYSA-N;
MW          232.836;      // g/mol [origin=calculated method=formula-sum]
Tc          722.16;      // K   [origin=predictive method=joback]
Pc          14.804;      // bar [origin=predictive method=joback]
omega       0.7231;      // -   [origin=predictive method=lee-kesler]
Tb          557.35;      // K   [origin=predictive method=joback]
HvapTb      51143.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.053 1.34062 -0.0007582 1.644e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyltetradecane" "myristyl chloride" "tetradecane, 1-chloro-" "tetradecyl chloride" "chlorotetradecane" "1-chloro-tetradecane" "tetradecylmagnesium chloride" "1-chlorotetradecane;myristyl chloride;tetradecyl chloride;" );
standardThermochemistry
{
    dHf_298   -348030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     734.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55070.0
}
