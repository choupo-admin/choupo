/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-4-decanol  (C11H24O, CAS 55816-17-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl4Decanol;
formula     C11H24O;
CAS         55816-17-6;
InChIKey    SBMFCRFCWMMVQC-UHFFFAOYSA-N;
MW          172.312;      // g/mol [origin=calculated method=formula-sum]
Tc          706.07;      // K   [origin=predictive method=joback]
Pc          21.315;      // bar [origin=predictive method=joback]
omega       0.9275;      // -   [origin=predictive method=lee-kesler]
Tb          542.58;      // K   [origin=predictive method=joback]
HvapTb      55983.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.184 1.09466 -0.0006114 1.285e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyldecan-4-ol" "4-decanol, 3-methyl-" "2-butyl n-hexyl carbinol" "3-methyl-4-decanol, erythro + threo" "2-butyl n-hexyl carbinol;3-methyl-4-decanol;methyldecanolthreoerythro;3-methyl-4-decanol, threo + erythro, 97%;3-methyl-4-decanol, erythro + threo, 97%" );
standardThermochemistry
{
    dHf_298   -433160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     616.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99960.0
}
