/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenaldehyde  (C14H10O2, CAS 1210-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H10O2 (delta C+2H+2O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diphenaldehyde;
formula     C14H10O2;
CAS         1210-05-5;
InChIKey    HJFGULDHUDIPDA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          210.232;      // g/mol [origin=calculated method=formula-sum]
Tc          779.84;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       0.3759;      // -   [origin=predictive method=lee-kesler]
Tb          536.08;      // K   [origin=predictive method=joback]
HvapTb      47888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.05 1.0732 -0.00097212 3.5e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methanoylphenyl)benzaldehyde" "diphenic dialdehyde" "biphenyl-2,2'-dialdehyde" "2,2'-diformylbiphenyl" "biphenyl-2,2'-dicarboxaldehyde" "2,2'-biphenyldicarbaldehyde" "2,2'-biphenyldicarboxaldehyde" "(1,1'-biphenyl)-2,2'-dicarboxaldehyde" "2-(2-formylphenyl)benzaldehyde" "[1,1'-biphenyl]-2,2'-dicarboxaldehyde" "[1,2'-dicarboxaldehyde" "diphenyl-2,2'-dicarboxaldehyde" );
standardThermochemistry
{
    dHf_298   270730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     637.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=360480.0
}
