/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentyl trifluoroacetate  (C7H9F3O2, CAS 703-13-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentylTrifluoroacetate;
formula     C7H9F3O2;
CAS         703-13-9;
InChIKey    QCONYJQZFUESJD-UHFFFAOYSA-N;
MW          182.141;      // g/mol [origin=calculated method=formula-sum]
Tc          611.46;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.4715;      // -   [origin=predictive method=lee-kesler]
Tb          427.84;      // K   [origin=predictive method=joback]
HvapTb      35093.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.75 0.9069 -0.0006108 1.432e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentyl 2,2,2-tris(fluoranyl)ethanoate" "cyclopentyl 2,2,2-trifluoroacetate" "trifluoroacetic acid, cyclopentyl ester" "1-[(trifluoroacetyl)oxy]cyclopentane" );
standardThermochemistry
{
    dHf_298   -1041690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-847350.0
}
