/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-deoxygrayanotoxin iii  (C20H34O5, CAS 501-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10DeoxygrayanotoxinIii;
formula     C20H34O5;
CAS         501-22-4;
InChIKey    IGKWESNBSFVVHE-VYIUWCHKSA-N;
MW          354.487;      // g/mol [origin=calculated method=formula-sum]
Tc          1399.93;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       1.5321;      // -   [origin=predictive method=lee-kesler]
Tb          1130.41;      // K   [origin=predictive method=joback]
HvapTb      137082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-368.68 3.62118 -0.003654 1.548e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 7; } { group C; count 4; } { group OH; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 7; } { group C_ring; count 4; } { group OH; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3" "a,6" "a,10" "a,14s)-grayanotoxane-3,5,6,14,16-pentol" "grayanotoxane-3,5,6,14,16-pentol, (3-beta,6-beta,14r)-" "7,9a-methano-9ah-cyclopenta(b)heptalene-2,8,11,11a,12(1h)-pentol, dodecahydro-1,1,4,8-tetramethyl-, (2s,3as,4r,4ar,7r,8r,9as,11r,11ar,12r)-" );
standardThermochemistry
{
    dHf_298   -1032140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     889.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-447910.0
}
