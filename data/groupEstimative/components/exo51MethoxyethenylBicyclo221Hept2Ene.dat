/*--------------------------------*- Choupo -*-----------------------*\
  Component: exo-5-(1-methoxyethenyl)bicyclo[2.2.1]hept-2-ene  (C10H14O, CAS 103582-46-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        exo51MethoxyethenylBicyclo221Hept2Ene;
formula     C10H14O;
CAS         103582-46-3;
InChIKey    UHVCEHVDJBKVEQ-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          665.77;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       0.3876;      // -   [origin=predictive method=lee-kesler]
Tb          459.62;      // K   [origin=predictive method=joback]
HvapTb      39655.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.27 1.08022 -0.00076028 2.169e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(1-methoxyethenyl)bicyclo[2.2.1]hept-2-ene" "exo-5-(1-methoxyethenyl)bicyclo(2.2.1)hept-2-ene" "(1r,4r,5s)-5-(1-methoxyethenyl)bicyclo[2.2.1]hept-2-ene" "bicyclo[2.2.1]hept-2-ene, 5-(1-methoxyethylidene)-, (e)-" );
standardThermochemistry
{
    dHf_298   -89430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     307.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139260.0
}
