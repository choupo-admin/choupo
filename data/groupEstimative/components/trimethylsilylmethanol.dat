/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylsilylmethanol  (C4H12OSi, CAS 3219-63-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H12OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylsilylmethanol;
formula     C4H12OSi;
CAS         3219-63-4;
InChIKey    ZQKNBDOVPOZPLY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          104.224;      // g/mol [origin=calculated method=formula-sum]
Tc          552.52;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.5406;      // -   [origin=predictive method=lee-kesler]
Tb          384.70;      // K   [origin=predictive method=joback]
HvapTb      41471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.361 0.21166 0.0001906 -1.71e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group OH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(trimethylsilyl)methanol" "1-trimethylsilylmethanol" "methanol, (trimethylsilyl)-" "(hydroxymethyl)trimethylsilane" "hydroxymethyltrimethylsilane" "trimethylhydroxymethylsilane" "methanol, 1-(trimethylsilyl)-" "silane, (hydroxymethyl)trimethyl-" "trimethylsilylmethanol_ragusa" "methanol,1-(trimethylsilyl)-" "zqknbdovpozply-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -389740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258780.0
}
