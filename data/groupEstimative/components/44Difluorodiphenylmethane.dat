/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-difluorodiphenylmethane  (C13H10F2, CAS 457-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Difluorodiphenylmethane;
formula     C13H10F2;
CAS         457-68-1;
InChIKey    DXQVFHQUHOFROC-UHFFFAOYSA-N;
MW          204.219;      // g/mol [origin=calculated method=formula-sum]
Tc          781.35;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.5418;      // -   [origin=predictive method=lee-kesler]
Tb          558.90;      // K   [origin=predictive method=joback]
HvapTb      48774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.959 0.9856 -0.00064452 1.559e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-4-[(4-fluorophenyl)methyl]benzene" "bis(4-fluorophenyl)methane" "1,1'-methylenebis(4-fluorobenzene)" "1-fluoro-4-[(4-fluorophenyl)methyl]benzene" "4-fluoro-1-[(4-fluorophenyl)methyl]benzene" "bis-(4-fluorophenyl)methane" "4,4'-difluorodiphenyl methane" "1,1-methylenebis[4-fluorobenzene]" "u564" "1,1'-methylenebis(4-fluorobenzene), 1,1'-methanediylbis(4-fluorobenzene)" );
standardThermochemistry
{
    dHf_298   -253750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125480.0
}
