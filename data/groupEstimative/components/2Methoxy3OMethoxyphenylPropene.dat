/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-3-(o-methoxyphenyl)propene  (C11H14O2, CAS 101968-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy3OMethoxyphenylPropene;
formula     C11H14O2;
CAS         101968-77-8;
InChIKey    LMZLAMAUGKFQPX-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          732.25;      // K   [origin=predictive method=joback]
Pc          26.434;      // bar [origin=predictive method=joback]
omega       0.5376;      // -   [origin=predictive method=lee-kesler]
Tb          524.34;      // K   [origin=predictive method=joback]
HvapTb      47248.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.601 0.76394 -0.00034196 2.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2-(2-methoxyprop-2-enyl)benzene" );
gibbsFormation
{
    dHf_298   -194110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13810.0
    phase     gas;
}
