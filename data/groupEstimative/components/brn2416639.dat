/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2416639  (C20H14, CAS 66788-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2416639;
formula     C20H14;
CAS         66788-01-0;
InChIKey    LFFOMFJFZJWEHC-UHFFFAOYSA-N;
MW          254.332;      // g/mol [origin=calculated method=formula-sum]
Tc          1029.33;      // K   [origin=predictive method=joback]
Pc          25.151;      // bar [origin=predictive method=joback]
omega       0.7829;      // -   [origin=predictive method=lee-kesler]
Tb          767.88;      // K   [origin=predictive method=joback]
HvapTb      70008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.39 1.7628 -0.0015594 5.534e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 7; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11,12-dihydrobenzo[e]pyrene" "9,10-h2 b(e)p" "benzo(e)pyrene, 9,10-dihydro-" );
gibbsFormation
{
    dHf_298   407030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=591920.0
    phase     gas;
}
