/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6,10-trimethylhexadecane  (C19H40, CAS 55000-52-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2610Trimethylhexadecane;
formula     C19H40;
CAS         55000-52-7;
InChIKey    MHLZUZMLIFKALI-UHFFFAOYSA-N;
MW          268.529;      // g/mol [origin=calculated method=formula-sum]
Tc          798.42;      // K   [origin=predictive method=joback]
Pc          10.979;      // bar [origin=predictive method=joback]
omega       0.7400;      // -   [origin=predictive method=lee-kesler]
Tb          633.00;      // K   [origin=predictive method=joback]
HvapTb      56724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.429 1.8266 -0.0010194 2.134e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecane, 2,6,10-trimethyl-" );
standardThermochemistry
{
    dHf_298   -451330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     867.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101780.0
}
