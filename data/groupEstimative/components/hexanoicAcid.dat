/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanoic acid  (C6H12O2, CAS 142-62-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanoicAcid;
formula     C6H12O2;
CAS         142-62-1;
InChIKey    FUZZWVXGSFPDMH-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          671.48;      // K   [origin=predictive method=joback]
Pc          34.399;      // bar [origin=predictive method=joback]
omega       0.6839;      // -   [origin=predictive method=lee-kesler]
Tb          482.39;      // K   [origin=predictive method=joback]
HvapTb      46114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.034 0.62462 -0.0003752 8.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "caproic acid" "n-caproic acid" "capronic acid" "n-hexanoic acid" "hexoic acid" "butylacetic acid" "n-hexylic acid" "n-hexoic acid" "pentylformic acid" "1-hexanoic acid" "pentiformic acid" "1-pentanecarboxylic acid" );
standardThermochemistry
{
    dHf_298   -517440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-344270.0
}
