/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-pentadiyne, 1-bromo-  (C5H3Br, CAS 40201-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Pentadiyne1Bromo;
formula     C5H3Br;
CAS         40201-94-3;
InChIKey    YBWNEWXRSMOCQW-UHFFFAOYSA-N;
MW          142.983;      // g/mol [origin=calculated method=formula-sum]
Tc          645.41;      // K   [origin=predictive method=joback]
Pc          58.361;      // bar [origin=predictive method=joback]
omega       0.2002;      // -   [origin=predictive method=lee-kesler]
Tb          398.16;      // K   [origin=predictive method=joback]
HvapTb      37463.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.65 0.21742 -0.00013532 4.036e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group Br; count 1; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tC; count 4; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylpenta-1,3-diyne" "1-bromopenta-1,3-diyne" );
gibbsFormation
{
    dHf_298   424400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=411140.0
    phase     gas;
}
