/*--------------------------------*- Choupo -*-----------------------*\
  Component: galoxolide  (C18H26O, CAS 1222-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        galoxolide;
formula     C18H26O;
CAS         1222-05-5;
InChIKey    ONKNPOPIGWHAQC-UHFFFAOYSA-N;
MW          258.405;      // g/mol [origin=calculated method=formula-sum]
Tc          920.60;      // K   [origin=predictive method=joback]
Pc          17.955;      // bar [origin=predictive method=joback]
omega       0.6119;      // -   [origin=predictive method=lee-kesler]
Tb          688.90;      // K   [origin=predictive method=joback]
HvapTb      61512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-180.87 2.27652 -0.00211998 8.534e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 1; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,6,6,7,8,8-hexamethyl-1,3,4,7-tetrahydrocyclopenta[g]isochromene" "galaxolide" "abbalide" "pearlide" "galaxolide white" "hhcb" "galaxolide 1+2" "cyclopenta[g]-2-benzopyran, 1,3,4,6,7,8-hexahydro-4,6,6,7,8,8-hexamethyl-" "4,6,6,7,8,8-hexamethyl-1,3,4,6,7,8-hexahydrocyclopenta[g]isochromene" "hexahydrohexamethyl cyclopentabenzopyran" "1,3,4,6,7,8-hexahydro-4,6,6,7,8,8-hexamethyl-cyclopenta-gamma-2-benzopyran" "indeno[5,6-c]pyran, 1,3,4,6,7,8-hexahydro-4,6,6,7,8,8-hexamethyl-" );
standardThermochemistry
{
    dHf_298   -215490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181080.0
}
