/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-79401  (C15H24O6, CAS 71348-43-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG79401;
formula     C15H24O6;
CAS         71348-43-1;
InChIKey    XNASOZGGRNSFGK-UHFFFAOYSA-N;
MW          300.351;      // g/mol [origin=calculated method=formula-sum]
Tc          975.32;      // K   [origin=predictive method=joback]
Pc          20.831;      // bar [origin=predictive method=joback]
omega       0.9002;      // -   [origin=predictive method=lee-kesler]
Tb          748.45;      // K   [origin=predictive method=joback]
HvapTb      71202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.358 2.15084 -0.0018488 6.808e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group C; count 2; } { group FCH2O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 7; } { group C_ring; count 2; } { group O_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 1,5-dioxaspiro[5.5]undecane-3,3-dicarboxylate" "1,5-dioxaspiro(5.5)undecane-3,3-dicarboxylic acid, diethyl ester" "1,5-dioxaspiro[5.5]undecane-3,3-dicarboxylic acid, diethyl ester" "1,5-dioxaspiro(5.5)undecane-3,3-dicarboxylic acid, 3,3-diethyl ester" "1,5-dioxaspiro[5.5]undecane-3,3-dicarboxylic acid, 3,3-diethyl ester" "diethyl 7,11-dioxaspiro[5.5]undecane-9,9-dicarboxylate" );
gibbsFormation
{
    dHf_298   -1106210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     798.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-667540.0
    phase     gas;
}
