/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridecanoic acid, (1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl) ester  (C49H80O8, CAS 105589-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridecanoicAcid1MethylethylideneBis41Phenyleneoxy21Ethanediy;
formula     C49H80O8;
CAS         105589-05-7;
InChIKey    GJILMYBSXISKJI-UHFFFAOYSA-N;
MW          797.171;      // g/mol [origin=calculated method=formula-sum]
Tc          2524.45;      // K   [origin=predictive method=joback]
Pc          3.521;      // bar [origin=predictive method=joback]
omega       -0.5600;      // -   [origin=predictive method=lee-kesler]
Tb          1586.93;      // K   [origin=predictive method=joback]
HvapTb      153702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.48 4.14548 -0.00210872 3.116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 24; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH2COO; count 2; } { group CH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 30; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[4-[2-[4-[2-(2-tridecanoyloxyethoxy)ethoxy]phenyl]propan-2-yl]phenoxy]ethoxy]ethyl tridecanoate" "tridecanoic acid, 1,1'-((1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl)) ester" "tridecanoic acid, 1,1'-[(1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl)] ester" );
gibbsFormation
{
    dHf_298   -1776760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1948.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-470640.0
    phase     gas;
}
