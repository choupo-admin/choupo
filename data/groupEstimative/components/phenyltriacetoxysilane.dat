/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyltriacetoxysilane  (C12H14O6Si, CAS 18042-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H14O6Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        phenyltriacetoxysilane;
formula     C12H14O6Si;
CAS         18042-54-1;
InChIKey    VLFKGWCMFMCFRM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          282.323;      // g/mol [origin=calculated method=formula-sum]
Tc          891.93;      // K   [origin=predictive method=joback]
Pc          21.755;      // bar [origin=predictive method=joback]
omega       0.8327;      // -   [origin=predictive method=lee-kesler]
Tb          676.90;      // K   [origin=predictive method=joback]
HvapTb      67097.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (75.12 0.69436 3.84e-05 -2.314e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH3COO; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[diacetyloxy(phenyl)silyl] ethanoate" "silanetriol, phenyl-, triacetate" "silanetriol, 1-phenyl-, 1,1,1-triacetate" "triacetoxyphenylsilane" "[diacetyloxy(phenyl)silyl] acetate" "silanetriol, 1-phenyl-,1,1,1-triacetate" "silanetriol,phenyl-, triacetate (6ci,7ci,8ci,9ci);monophenyltriacetoxysilane;phenyltriacetoxysilane;triacetoxyphenylsilane;" );
standardThermochemistry
{
    dHf_298   -1117940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     797.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-873300.0
}
