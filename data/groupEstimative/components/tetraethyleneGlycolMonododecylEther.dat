/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraethylene glycol monododecyl ether  (C20H42O5, CAS 5274-68-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraethyleneGlycolMonododecylEther;
formula     C20H42O5;
CAS         5274-68-0;
InChIKey    WPMWEFXCIYCJSA-UHFFFAOYSA-N;
MW          362.551;      // g/mol [origin=calculated method=formula-sum]
Tc          1028.53;      // K   [origin=predictive method=joback]
Pc          10.312;      // bar [origin=predictive method=joback]
omega       0.9817;      // -   [origin=predictive method=lee-kesler]
Tb          839.06;      // K   [origin=predictive method=joback]
HvapTb      86433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (91.999 1.68502 -0.0006506 1.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH2O; count 3; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } { group OH; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-(2-dodecoxyethoxy)ethoxy]ethoxy]ethanol" "dodecyltetraglycol" "3,6,9,12-tetraoxatetracosan-1-ol" "polyoxyethylene (4) lauryl ether" "la 4" "polyoxyethylene(4) lauryl ether" "tetra(oxyethylene) dodecyl ether" "polyethylene glycol dodecyl ether" "dodecyl tetraethylene glycol ether" "tetraethylene glycol dodecyl ether" "c12e4" "tetra(oxydiethanol) monodecyl ether" );
gibbsFormation
{
    dHf_298   -1137240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1031.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-439300.0
    phase     gas;
}
