  Component: 2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane-1-propanamine,n-phenyl-  (C15H24N2O3Si, CAS 85952-93-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H24N2O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        289Trioxa5Aza1Silabicyclo333Undecane1PropanamineNPhenyl;
formula     C15H24N2O3Si;
CAS         85952-93-8;
InChIKey    MQUNDDCBMDSQQJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          308.453;      // g/mol [origin=calculated method=formula-sum]
Tc          984.57;      // K   [origin=predictive method=joback]
Pc          23.519;      // bar [origin=predictive method=joback]
omega       0.9126;      // -   [origin=predictive method=lee-kesler]
Tb          749.97;      // K   [origin=predictive method=joback]
HvapTb      74523.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.497 1.6608 -0.0009401 1.627e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 3; } { group CH2NH; count 1; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 3; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[3-(4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecan-5-yl)propyl]aniline" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane-1-propanamine, n-phenyl-" );
standardThermochemistry
{
    dHf_298   -335220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125500.0
}
