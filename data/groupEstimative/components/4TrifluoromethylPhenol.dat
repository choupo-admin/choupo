/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(trifluoromethyl)phenol  (C7H5F3O, CAS 402-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TrifluoromethylPhenol;
formula     C7H5F3O;
CAS         402-45-9;
InChIKey    BAYGVMXZJBFEMB-UHFFFAOYSA-N;
MW          162.11;      // g/mol [origin=calculated method=formula-sum]
Tc          669.74;      // K   [origin=predictive method=joback]
Pc          42.943;      // bar [origin=predictive method=joback]
omega       0.5421;      // -   [origin=predictive method=lee-kesler]
Tb          461.64;      // K   [origin=predictive method=joback]
HvapTb      42719.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.5 0.9057 -0.00086556 3.194e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-hydroxybenzotrifluoride" "4-trifluoromethylphenol" "alpha,alpha,alpha-trifluoro-p-cresol" "p-trifluoromethylphenol" "a,a,a-trifluoro-p-cresol" "p-hydroxybenzotrifluoride" "4-(trifluoromethyl)-phenol" "4-hydroxy-alpha,alpha,alpha-trifluorotoluene" ".alpha.,.alpha.,.alpha.-trifluoro-p-cresol" "fcr" "phenol, 4-(trifluoromethyl)-" "p-trifluoromethyl-phenol" );
gibbsFormation
{
    dHf_298   -725670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-615740.0
    phase     gas;
}
