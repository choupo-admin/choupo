/*--------------------------------*- Choupo -*-----------------------*\
  Component: mercaptoacetaldehyde  (C2H4OS, CAS 4124-63-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mercaptoacetaldehyde;
formula     C2H4OS;
CAS         4124-63-4;
InChIKey    FLJWVVUJGVNXMZ-UHFFFAOYSA-N;
MW          76.113;      // g/mol [origin=calculated method=formula-sum]
Tc          559.18;      // K   [origin=predictive method=joback]
Pc          61.805;      // bar [origin=predictive method=joback]
omega       0.3311;      // -   [origin=predictive method=lee-kesler]
Tb          356.88;      // K   [origin=predictive method=joback]
HvapTb      33503.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.361 0.1956 -0.0001004 1.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group OdCH_al; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-sulfanylethanal" "2-sulfanylacetaldehyde" );
standardThermochemistry
{
    dHf_298   -131710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104170.0
}
