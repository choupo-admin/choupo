/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxyphenylacetic acid  (C9H10O3, CAS 93-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethoxyphenylaceticAcid;
formula     C9H10O3;
CAS         93-25-4;
InChIKey    IVEWTCACRDEAOB-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          827.30;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.8137;      // -   [origin=predictive method=lee-kesler]
Tb          605.11;      // K   [origin=predictive method=joback]
HvapTb      58140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.201 0.70802 -0.00039156 6.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methoxyphenyl)ethanoic acid" "benzeneacetic acid, 2-methoxy-" "2-(2-methoxyphenyl)acetic acid" "acetic acid, (o-methoxyphenyl)-" "2-methoxyphenylaceticacid" "(o-methoxyphenyl)acetic acid" "(2-methoxyphenyl)acetic acid" "2-(carboxymethyl)anisole" "2-methoxybenzeneacetic acid" "o-methoxyphenylacetic acid" "2-(2-methoxyphenyl)-acetic acid" "acetic acid, (o-methoxyphenyl)- (8ci)" );
gibbsFormation
{
    dHf_298   -486520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-321230.0
    phase     gas;
}
