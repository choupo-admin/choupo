/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-tetradecene, 14,14-dimethoxy-, (5z)-  (C16H32O2, CAS 71393-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Tetradecene1414Dimethoxy5z;
formula     C16H32O2;
CAS         71393-96-9;
InChIKey    MNLVOZIOUUDCAP-UHFFFAOYSA-N;
MW          256.43;      // g/mol [origin=calculated method=formula-sum]
Tc          781.43;      // K   [origin=predictive method=joback]
Pc          13.437;      // bar [origin=predictive method=joback]
omega       0.8136;      // -   [origin=predictive method=lee-kesler]
Tb          614.24;      // K   [origin=predictive method=joback]
HvapTb      55600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.48 1.42336 -0.0007116 1.165e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 1; } { group dCH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "14,14-dimethoxytetradec-5-ene" );
standardThermochemistry
{
    dHf_298   -526070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     785.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-48380.0
}
