/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromoethyl benzoate  (C9H9BrO2, CAS 939-54-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromoethylBenzoate;
formula     C9H9BrO2;
CAS         939-54-8;
InChIKey    KNBBDZULQFKSIE-UHFFFAOYSA-N;
MW          229.073;      // g/mol [origin=calculated method=formula-sum]
Tc          784.78;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.6199;      // -   [origin=predictive method=lee-kesler]
Tb          556.58;      // K   [origin=predictive method=joback]
HvapTb      51746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.598 0.7633 -0.0004738 9.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid 2-bromoethyl ester" "2-bromoethyl benzoate , 98 %" "knbbdzulqfksie-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -283510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158740.0
    phase     gas;
}
