/*--------------------------------*- Choupo -*-----------------------*\
  Component: spirostan-2,3-diol  (C27H44O4, CAS 511-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spirostan23Diol;
formula     C27H44O4;
CAS         511-96-6;
InChIKey    FWCXELAAYFYCSR-UHFFFAOYSA-N;
MW          432.645;      // g/mol [origin=calculated method=formula-sum]
Tc          1340.26;      // K   [origin=predictive method=joback]
Pc          12.893;      // bar [origin=predictive method=joback]
omega       1.1907;      // -   [origin=predictive method=lee-kesler]
Tb          1093.98;      // K   [origin=predictive method=joback]
HvapTb      113140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-422.13 4.15928 -0.0036844 1.3954e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 9; } { group C; count 3; } { group OH; count 2; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 10; } { group CH_ring; count 10; } { group C_ring; count 3; } { group OH; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "digin" "gitogenin" "(25r)-5.alpha.-spirostan-2.alpha.,3.beta.-diol" "agn-pc-02lrui" "5.alpha.-spirostan-2.alpha., (25r)-" "spirostan-2, (2.alpha.,3.beta.,5.alpha.,25r)-" "5.beta.-spirostan-2.beta.,3.alpha.-diol, (25r)-" "spirostan-2,3-diol, (2.beta.,3.alpha.,5.beta.,25r)-" );
gibbsFormation
{
    dHf_298   -872050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60060.0
    phase     gas;
}
