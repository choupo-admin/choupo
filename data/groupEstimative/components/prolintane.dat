/*--------------------------------*- Choupo -*-----------------------*\
  Component: prolintane  (C15H23N, CAS 493-92-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        prolintane;
formula     C15H23N;
CAS         493-92-5;
InChIKey    OJCPSBCUMRIPFL-UHFFFAOYSA-N;
MW          217.356;      // g/mol [origin=calculated method=formula-sum]
Tc          810.63;      // K   [origin=predictive method=joback]
Pc          21.980;      // bar [origin=predictive method=joback]
omega       0.6190;      // -   [origin=predictive method=lee-kesler]
Tb          597.16;      // K   [origin=predictive method=joback]
HvapTb      53309.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.327 1.64752 -0.0011684 3.273e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-phenylpentan-2-yl)pyrrolidine" "prolintan" "1-phenyl-2-pyrrolidinylpentane" "phenylpyrrolidinopentane" "prolintane [inn:ban]" "1-(alpha-propylphenethyl)pyrrolidine" "prolintanum [inn-latin]" "1-(1-benzylbutyl)pyrrolidine" "pyrrolidine, 1-(alpha-propylphenethyl)-" "pyrrolidine, 1-[1-(phenylmethyl)butyl]-" "pyrrolidine, 1-(.alpha.-propylphenethyl)-" "1-[1-(phenylmethyl)butyl]pyrrolidine" );
standardThermochemistry
{
    dHf_298   32830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=352530.0
}
