/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-(propan-2-ylidene)tricyclo[3.2.1.02,4]octane  (C11H16, CAS 37846-64-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Propan2YlideneTricyclo321024Octane;
formula     C11H16;
CAS         37846-64-3;
InChIKey    XVHWHLALQBRFIH-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          675.27;      // K   [origin=predictive method=joback]
Pc          27.469;      // bar [origin=predictive method=joback]
omega       0.3957;      // -   [origin=predictive method=lee-kesler]
Tb          469.08;      // K   [origin=predictive method=joback]
HvapTb      40205.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.37 1.40704 -0.001197 4.22e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[3.2.1.02,4]octane,8-(1-methylethylidene)-,endo-" "tricyclo(3.2.1.02,4)octane, 8-(1-methylethylidene)-, endo-" );
gibbsFormation
{
    dHf_298   90.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     219.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=265290.0
    phase     gas;
}
