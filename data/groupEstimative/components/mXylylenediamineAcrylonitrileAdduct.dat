/*--------------------------------*- Choupo -*-----------------------*\
  Component: m-xylylenediamine/acrylonitrile adduct  (C11H15N3, CAS 73050-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mXylylenediamineAcrylonitrileAdduct;
formula     C11H15N3;
CAS         73050-11-0;
InChIKey    XMEXUJUMKRUUNG-UHFFFAOYSA-N;
MW          189.262;      // g/mol [origin=calculated method=formula-sum]
Tc          972.52;      // K   [origin=predictive method=joback]
Pc          27.269;      // bar [origin=predictive method=joback]
omega       0.8580;      // -   [origin=predictive method=lee-kesler]
Tb          728.16;      // K   [origin=predictive method=joback]
HvapTb      74402.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.092 0.7428 -0.00020266 -6.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2NH2; count 2; } { group ACRY; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-(aminomethyl)phenyl]methanamine;prop-2-enenitrile" );
gibbsFormation
{
    dHf_298   200960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     684.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=393680.0
    phase     gas;
}
