/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-octadecyldimethylamine  (C20H43N, CAS 71662-63-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Octadecyldimethylamine;
formula     C20H43N;
CAS         71662-63-0;
InChIKey    WZYYQKWAHFYHLI-HXUWFJFHSA-N;
MW          297.571;      // g/mol [origin=calculated method=formula-sum]
Tc          831.45;      // K   [origin=predictive method=joback]
Pc          10.194;      // bar [origin=predictive method=joback]
omega       0.8252;      // -   [origin=predictive method=lee-kesler]
Tb          669.20;      // K   [origin=predictive method=joback]
HvapTb      61769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.665 2.03368 -0.00118 2.637e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 15; } { group CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 15; } { group CH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-n,n-dimethyloctadecan-2-amine" "2-octadecanamine, n,n-dimethyl-" );
gibbsFormation
{
    dHf_298   -393880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     941.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225860.0
    phase     gas;
}
