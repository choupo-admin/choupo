/*--------------------------------*- Choupo -*-----------------------*\
  Component: prenyl formate  (C6H10O2, CAS 68480-28-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H10O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        prenylFormate;
formula     C6H10O2;
CAS         68480-28-4;
InChIKey    ZCROFVOAWLRGFY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          489.68;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       0.1925;      // -   [origin=predictive method=lee-kesler]
Tb          317.34;      // K   [origin=predictive method=joback]
HvapTb      26615.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.939 0.60184 -0.0005417 2.061e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-2-enyl methanoate" "3-methylbut-2-enyl formate" "2-buten-1-ol, 3-methyl-, formate" "2-buten-1-ol, 3-methyl-, 1-formate" "3-methyl but-2-enyl formate" "3-methylbut-2-en-1-yl formate" "2-buten-1-ol,3-methyl-, 1-formate" "formic acid, 3-methyl-2-butenyl ester" "2-buten-1-ol,3-methyl-, formate (9ci);3-methyl-2-butenyl formate;" );
gibbsFormation
{
    dHf_298   16710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115270.0
    phase     gas;
}
