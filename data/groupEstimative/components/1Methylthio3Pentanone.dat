/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(methylthio)-3-pentanone  (C6H12OS, CAS 66735-69-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylthio3Pentanone;
formula     C6H12OS;
CAS         66735-69-1;
InChIKey    LEZZIANNWFYCND-UHFFFAOYSA-N;
MW          132.221;      // g/mol [origin=calculated method=formula-sum]
Tc          660.33;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       0.4953;      // -   [origin=predictive method=lee-kesler]
Tb          459.53;      // K   [origin=predictive method=joback]
HvapTb      42513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.393 0.54023 -0.0002437 2.356e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2CO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CdO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylsulfanylpentan-3-one" "3-pentanone, 1-(methylthio)-" );
standardThermochemistry
{
    dHf_298   -237880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96160.0
}
