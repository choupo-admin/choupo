/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butyne-1,4-diol  (C4H6O2, CAS 110-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butyne14Diol;
formula     C4H6O2;
CAS         110-65-6;
InChIKey    DLDJFQGPPSQZKI-UHFFFAOYSA-N;
MW          86.09;      // g/mol [origin=calculated method=formula-sum]
Tc          662.54;      // K   [origin=predictive method=joback]
Pc          63.189;      // bar [origin=predictive method=joback]
omega       1.1223;      // -   [origin=predictive method=lee-kesler]
Tb          484.48;      // K   [origin=predictive method=joback]
HvapTb      60008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.392 0.302 -0.00016246 3.498e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group tC; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-2-yne-1,4-diol" "1,4-dihydroxy-2-butyne" "bis(hydroxymethyl)acetylene" "1,4-butynediol" "2-butynediol" "agrisynth b3d" "1,4-butynediol (van)" "butynediol-1,4 [french]" "1,4-butinodiol" "butynediol-1,4" "1,4-dimethoxyacetylene" "2-butin-1,4-diol" );
gibbsFormation
{
    dHf_298   -158050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88040.0
    phase     gas;
}
