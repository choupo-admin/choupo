/*--------------------------------*- Choupo -*-----------------------*\
  Component: butan-2-one;(2e)-2-(3,3-dimethyl-2-bicyclo[2.2.1]heptanylidene)ethanal  (C15H24O2, CAS 69898-17-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butan2One2e233Dimethyl2Bicyclo221HeptanylideneEthanal;
formula     C15H24O2;
CAS         69898-17-5;
InChIKey    YMSNVDSENFTSLK-OAZHBLANSA-N;
MW          236.355;      // g/mol [origin=calculated method=formula-sum]
Tc          881.24;      // K   [origin=predictive method=joback]
Pc          19.186;      // bar [origin=predictive method=joback]
omega       0.7307;      // -   [origin=predictive method=lee-kesler]
Tb          666.69;      // K   [origin=predictive method=joback]
HvapTb      62069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.729 1.64928 -0.0011914 3.7836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butan-2-one; (2e)-2-(3,3-dimethyl-2-bicyclo[2.2.1]heptanylidene)acetaldehyde" "acetaldehyde, (3,3-dimethylbicyclo(2.2.1)hept-2-ylidene)-, reaction products with me et ketone" "acetaldehyde, 2-(3,3-dimethylbicyclo(2.2.1)hept-2-ylidene)-, reaction products with me et ketone" );
gibbsFormation
{
    dHf_298   -452340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     731.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116120.0
    phase     gas;
}
