/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-oxathiane  (C4H8OS, CAS 15980-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Oxathiane;
formula     C4H8OS;
CAS         15980-15-1;
InChIKey    JBYHSSAVUBIJMK-UHFFFAOYSA-N;
MW          104.167;      // g/mol [origin=calculated method=formula-sum]
Tc          618.04;      // K   [origin=predictive method=joback]
Pc          52.586;      // bar [origin=predictive method=joback]
omega       0.2435;      // -   [origin=predictive method=lee-kesler]
Tb          390.12;      // K   [origin=predictive method=joback]
HvapTb      35558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.15 0.54381 -0.000335 7.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group FCH2O; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group O_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-thioxane" "p-thioxane" "oxathiane" "1-oxa-4-thiacyclohexane" "1,4-oxathiin, 2,3,5,6-tetrahydro-" "1, 2,3,5,6-tetrahydro-" );
standardThermochemistry
{
    dHf_298   -137970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     322.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31300.0
}
