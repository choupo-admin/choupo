/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dihydroxypropyl decanoate  (C13H26O4, CAS 26402-22-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DihydroxypropylDecanoate;
formula     C13H26O4;
CAS         26402-22-2;
InChIKey    LKUNXBRZDFMZOK-UHFFFAOYSA-N;
MW          246.347;      // g/mol [origin=calculated method=formula-sum]
Tc          909.92;      // K   [origin=predictive method=joback]
Pc          19.424;      // bar [origin=predictive method=joback]
omega       1.4918;      // -   [origin=predictive method=lee-kesler]
Tb          739.18;      // K   [origin=predictive method=joback]
HvapTb      84909.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.38 1.25792 -0.0006528 1.055e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)propyl decanoate" "monocaprin" "decanoic acid, 2,3-dihydroxypropyl ester" "decanoin, 1-mono-" "1-monodecanoyl glycerol" "decanoic acid, monoester with 1,2,3-propanetriol" "glyceryl caprate" "triglycerol trioctanoate decanoate" "glyceryl monocaprate" "1-decanoyl-rac-glycerol" "decanoic acid, ester with triglycerol trioctanoate" "glycerol 1-monocaprinate" );
standardThermochemistry
{
    dHf_298   -938670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     805.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-527870.0
}
