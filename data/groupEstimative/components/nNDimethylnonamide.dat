/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylnonamide  (C11H23NO, CAS 6225-08-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylnonamide;
formula     C11H23NO;
CAS         6225-08-7;
InChIKey    DMLHJLWUADABON-UHFFFAOYSA-N;
MW          185.311;      // g/mol [origin=calculated method=formula-sum]
Tc          687.56;      // K   [origin=predictive method=joback]
Pc          20.419;      // bar [origin=predictive method=joback]
omega       0.7304;      // -   [origin=predictive method=lee-kesler]
Tb          517.59;      // K   [origin=predictive method=joback]
HvapTb      48869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.443 1.14476 -0.0006685 1.4806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylnonanamide" );
gibbsFormation
{
    dHf_298   -315420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23600.0
    phase     gas;
}
