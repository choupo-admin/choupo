/*--------------------------------*- Choupo -*-----------------------*\
  Component: propylene glycol diisostearate  (C39H76O4, CAS 68958-54-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propyleneGlycolDiisostearate;
formula     C39H76O4;
CAS         68958-54-3;
InChIKey    OATHWIHWTWDNLJ-UHFFFAOYSA-N;
MW          609.033;      // g/mol [origin=calculated method=formula-sum]
Tc          1636.52;      // K   [origin=predictive method=joback]
Pc          4.118;      // bar [origin=predictive method=joback]
omega       -0.2799;      // -   [origin=predictive method=lee-kesler]
Tb          1207.04;      // K   [origin=predictive method=joback]
HvapTb      116058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.209 3.617 -0.0019182 3.372e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 27; } { group CH; count 3; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 29; } { group CH; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(16-methylheptadecanoyloxy)propyl 16-methylheptadecanoate" "1-methyl-1,2-ethanediyl diisooctadecanoate" "propane-1,2-diyl bis(16-methylheptadecanoate)" "isooctadecanoic acid, 1,1'-(1-methyl-1,2-ethanediyl) ester" "isooctadecanoic acid, 1-methyl-1,2-ethanediyl ester" "isooctadecanoic acid,1,1'-(1-methyl-1,2-ethanediyl) ester" "isooctadecanoicacid, 1-methyl-1,2-ethanediyl ester (9ci); emalex pg-di-is; propylene glycoldiisostearate" );
standardThermochemistry
{
    dHf_298   -1498690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1749.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-350560.0
}
