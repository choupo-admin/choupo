/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-acetyl-1-butyloxy-3,3,5,5-tetramethyl-1-cyclohexene  (C16H28O2, CAS 16556-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Acetyl1Butyloxy3355Tetramethyl1Cyclohexene;
formula     C16H28O2;
CAS         16556-52-8;
InChIKey    CEFRLRCVISSIDU-UHFFFAOYSA-N;
MW          252.398;      // g/mol [origin=calculated method=formula-sum]
Tc          861.52;      // K   [origin=predictive method=joback]
Pc          16.551;      // bar [origin=predictive method=joback]
omega       0.6984;      // -   [origin=predictive method=lee-kesler]
Tb          656.80;      // K   [origin=predictive method=joback]
HvapTb      58829.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.427 1.97012 -0.00167254 6.4386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group CH=C; count 1; } { group CH3CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-butoxy-2,2,6,6-tetramethyl-cyclohex-3-en-1-yl)ethanone" "1-(4-butoxy-2,2,6,6-tetramethyl-3-cyclohexen-1-yl)ethan-1-one" "ethanone, 1-(4-butoxy-2,2,6,6-tetramethyl-3-cyclohexen-1-yl)-" "1-(4-butoxy-2,2,6,6-tetramethylcyclohex-3-en-1-yl)ethanone" );
standardThermochemistry
{
    dHf_298   -527940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     797.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-131700.0
}
