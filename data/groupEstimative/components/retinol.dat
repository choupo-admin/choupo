/*--------------------------------*- Choupo -*-----------------------*\
  Component: retinol  (C20H30O, CAS 68-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        retinol;
formula     C20H30O;
CAS         68-26-8;
InChIKey    FPIPGXGPPPQFEQ-OVSJKPMPSA-N;
MW          286.459;      // g/mol [origin=calculated method=formula-sum]
Tc          1002.56;      // K   [origin=predictive method=joback]
Pc          15.117;      // bar [origin=predictive method=joback]
omega       0.9841;      // -   [origin=predictive method=lee-kesler]
Tb          794.69;      // K   [origin=predictive method=joback]
HvapTb      77679.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-145.329 2.2567 -0.0019012 6.918e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group C; count 1; } { group CH=CH; count 2; } { group CH=C; count 2; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dCH; count 6; } { group dC; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,4e,6e,8e)-3,7-dimethyl-9-(2,6,6-trimethylcyclohexen-1-yl)nona-2,4,6,8-tetraen-1-ol" "vitamin a" "all-trans-retinol" "vitamin a1" "alphalin" "axerophthol" "trans-retinol" "oleovitamin a" "chocola a" "alphasterol" "ophthalamin" "agiolan" );
standardThermochemistry
{
    dHf_298   -54660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     940.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=314140.0
}
