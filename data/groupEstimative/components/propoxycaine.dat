/*--------------------------------*- Choupo -*-----------------------*\
  Component: propoxycaine  (C16H26N2O3, CAS 86-43-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propoxycaine;
formula     C16H26N2O3;
CAS         86-43-1;
InChIKey    CAJIGINSTLKQMM-UHFFFAOYSA-N;
MW          294.395;      // g/mol [origin=calculated method=formula-sum]
Tc          967.98;      // K   [origin=predictive method=joback]
Pc          17.217;      // bar [origin=predictive method=joback]
omega       1.0935;      // -   [origin=predictive method=lee-kesler]
Tb          767.93;      // K   [origin=predictive method=joback]
HvapTb      77311.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.746 1.39376 -0.00069412 9.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group ACH; count 3; } { group AC; count 2; } { group CH2O; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group COO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl 4-azanyl-2-propoxy-benzoate" "pravocaine" "propoxicainum" "ranocaine" "blockain" "propoxycaine [inn]" "propossicaina [dcit]" "propoxycainum [inn-latin]" "4-amino-2-propoxybenzoic acid, 2-(diethylamino)ethyl ester" "2-diethylaminoethyl 4-amino-2-propoxybenzoate" "2-(diethylamino)ethyl 4-amino-2-propoxybenzoate" "benzoic acid, 4-amino-2-propoxy-, 2-(diethylamino)ethyl ester" );
standardThermochemistry
{
    dHf_298   -508160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     790.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61150.0
}
