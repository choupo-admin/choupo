/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl isopropylmalonate  (C10H18O4, CAS 759-36-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylIsopropylmalonate;
formula     C10H18O4;
CAS         759-36-4;
InChIKey    BYQFBFWERHXONI-UHFFFAOYSA-N;
MW          202.25;      // g/mol [origin=calculated method=formula-sum]
Tc          725.70;      // K   [origin=predictive method=joback]
Pc          21.593;      // bar [origin=predictive method=joback]
omega       0.7310;      // -   [origin=predictive method=lee-kesler]
Tb          543.96;      // K   [origin=predictive method=joback]
HvapTb      51892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.252 0.85608 -0.0003374 -7.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-propan-2-ylpropanedioate" "1,3-diethyl 2-(propan-2-yl)propanedioate" "propanedioic acid, (1-methylethyl)-, diethyl ester" "ethyl isopropylmalonate" "diethyl 2-isopropylmalonate" "isopropylmalonic acid diethyl ester" "1,3-diethyl 2-isopropylpropanedioate" "malonic acid, isopropyl-, diethyl ester" "m289" "diethyl 2-(methylethyl)propane-1,3-dioate" "2-propan-2-ylpropanedioic acid diethyl ester" "malonicacid, ethylmethyl-, diethyl ester (7ci,8ci);propanedioic acid, ethylmethyl-,diethyl ester (9ci);diethyl 2-ethyl-2-methylmalonate;diethylethylmethylmalonate;diethyl methylethylmalonate;" );
standardThermochemistry
{
    dHf_298   -894850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-592300.0
}
