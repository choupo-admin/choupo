/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-95977  (C8H10O, CAS 74437-38-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG95977;
formula     C8H10O;
CAS         74437-38-0;
InChIKey    TUTYWWCXQGWYOV-UHFFFAOYSA-N;
MW          122.167;      // g/mol [origin=calculated method=formula-sum]
Tc          655.46;      // K   [origin=predictive method=joback]
Pc          37.870;      // bar [origin=predictive method=joback]
omega       0.4219;      // -   [origin=predictive method=lee-kesler]
Tb          445.41;      // K   [origin=predictive method=joback]
HvapTb      38998.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.91 0.75532 -0.00057864 1.88e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group CH3O; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxybicyclo[2.2.1]hepta-1,3-diene" "bicyclo[2.2.1]hepta-2,5-diene,2-methoxy-" );
standardThermochemistry
{
    dHf_298   -79400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     309.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67330.0
}
