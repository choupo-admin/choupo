/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7,12-dioxaspiro[5.6]dodecane  (C10H18O2, CAS 181-28-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        712Dioxaspiro56Dodecane;
formula     C10H18O2;
CAS         181-28-2;
InChIKey    GGKFOZUGYBUSAD-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          773.00;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       0.3922;      // -   [origin=predictive method=lee-kesler]
Tb          526.31;      // K   [origin=predictive method=joback]
HvapTb      46890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.7 1.5104 -0.0012424 4.358e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,12-dioxaspiro(5.6)dodecane" "7,12-dioxaspiro(5.6)dodecane;" );
standardThermochemistry
{
    dHf_298   -369510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87800.0
}
