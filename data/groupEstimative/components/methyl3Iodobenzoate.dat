/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-iodobenzoate  (C8H7IO2, CAS 618-91-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Iodobenzoate;
formula     C8H7IO2;
CAS         618-91-7;
InChIKey    NPXOIGSBRLCOSD-UHFFFAOYSA-N;
MW          262.042;      // g/mol [origin=calculated method=formula-sum]
Tc          816.45;      // K   [origin=predictive method=joback]
Pc          35.137;      // bar [origin=predictive method=joback]
omega       0.4859;      // -   [origin=predictive method=lee-kesler]
Tb          565.66;      // K   [origin=predictive method=joback]
HvapTb      53120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.11 0.60962 -0.00036236 6.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group I; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-iodanylbenzoate" "methyl3-iodobenzoate" "methyl m-iodobenzoate" "benzoic acid, 3-iodo-, methyl ester" "3-iodomethylbenzoate" "m-iodobenzoic acid methyl ester" "3-iodobenzoic acid methyl ester" "benzoic acid, m-iodo-, methyl ester" "methyl-3-iodobenzoate" "benzoic acid, 3-iodo-,methyl ester" "m656" "benzoic acid, m-iodo-, methyl ester (8ci)" );
standardThermochemistry
{
    dHf_298   -223800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-132990.0
}
