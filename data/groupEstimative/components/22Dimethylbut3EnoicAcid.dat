/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylbut-3-enoic acid  (C6H10O2, CAS 10276-09-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylbut3EnoicAcid;
formula     C6H10O2;
CAS         10276-09-2;
InChIKey    SCFWAOWWAANBPY-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          681.46;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       0.5489;      // -   [origin=predictive method=lee-kesler]
Tb          475.84;      // K   [origin=predictive method=joback]
HvapTb      44148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.43 0.73044 -0.0005699 1.775e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyl-3-butenoic acid" "3-butenoic acid, 2,2-dimethyl-" "2,2-dimethyl-but-3-enoic acid" "2,2-dimethyl-3-butenoicacid" "3-butenoic acid,2,2-dimethyl-" );
standardThermochemistry
{
    dHf_298   -400760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253590.0
}
