/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylhexahydroazocin-5-one  (C8H15NO, CAS 71512-38-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylhexahydroazocin5One;
formula     C8H15NO;
CAS         71512-38-4;
InChIKey    HXKFJDKQJXBMEY-UHFFFAOYSA-N;
MW          141.214;      // g/mol [origin=calculated method=formula-sum]
Tc          717.39;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.4283;      // -   [origin=predictive method=lee-kesler]
Tb          491.39;      // K   [origin=predictive method=joback]
HvapTb      40602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.31 0.85842 -0.00037 1.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2CO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylazocan-5-one" );
gibbsFormation
{
    dHf_298   -210120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24730.0
    phase     gas;
}
