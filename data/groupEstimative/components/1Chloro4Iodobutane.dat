/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-4-iodobutane  (C4H8ClI, CAS 10297-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro4Iodobutane;
formula     C4H8ClI;
CAS         10297-05-9;
InChIKey    JXOSPTBRSOYXGC-UHFFFAOYSA-N;
MW          218.458;      // g/mol [origin=calculated method=formula-sum]
Tc          634.10;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.3128;      // -   [origin=predictive method=lee-kesler]
Tb          421.69;      // K   [origin=predictive method=joback]
HvapTb      38256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.834 0.4296 -0.0002956 8.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2Cl; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Cl; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-iodanyl-butane" "tetramethylene chloroiodide" "butane, 1-chloro-4-iodo-" "1-iodo-4-chlorobutane" "1-chloro-4-iodobutane;1-iodo-4-chlorobutane;4-chloro-1-iodobutane;4-chlorobutyl iodide;4-iodo-1-chlorobutane;4-iodobutyl chloride;tetramethylene chloroiodide;" );
standardThermochemistry
{
    dHf_298   -64760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28990.0
}
