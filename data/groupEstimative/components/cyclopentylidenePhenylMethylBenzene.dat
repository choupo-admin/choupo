/*--------------------------------*- Choupo -*-----------------------*\
  Component: [cyclopentylidene(phenyl)methyl]benzene  (C18H18, CAS 7714-72-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentylidenePhenylMethylBenzene;
formula     C18H18;
CAS         7714-72-9;
InChIKey    POPQCIZUXRKKGP-UHFFFAOYSA-N;
MW          234.342;      // g/mol [origin=calculated method=formula-sum]
Tc          955.81;      // K   [origin=predictive method=joback]
Pc          24.100;      // bar [origin=predictive method=joback]
omega       0.5511;      // -   [origin=predictive method=lee-kesler]
Tb          691.27;      // K   [origin=predictive method=joback]
HvapTb      61647.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.3 1.6366 -0.0011714 3.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 10; } { group AC; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, (cyclopentylidenephenylmethyl)-" );
standardThermochemistry
{
    dHf_298   205270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=406670.0
}
