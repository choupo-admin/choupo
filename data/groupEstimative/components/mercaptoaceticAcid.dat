/*--------------------------------*- Choupo -*-----------------------*\
  Component: mercaptoacetic acid  (C2H4O2S, CAS 68-11-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mercaptoaceticAcid;
formula     C2H4O2S;
CAS         68-11-1;
InChIKey    CWERGRDVMFNCDR-UHFFFAOYSA-N;
MW          92.112;      // g/mol [origin=calculated method=formula-sum]
Tc          675.86;      // K   [origin=predictive method=joback]
Pc          63.289;      // bar [origin=predictive method=joback]
omega       0.5576;      // -   [origin=predictive method=lee-kesler]
Tb          453.73;      // K   [origin=predictive method=joback]
HvapTb      43947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.561 0.2719 -0.00018 4.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group COOH; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-sulfanylethanoic acid" "thioglycolic acid" "acetic acid, mercapto-" "2-thioglycolic acid" "sulfanylacetic acid" "thioglycolate" "2-mercaptoacetic acid" "thiovanic acid" "mercaptoessigsaeure" "glycolic acid, thio-" "2-mercaptoacetate" "glycolic acid, 2-thio-" );
gibbsFormation
{
    dHf_298   -396400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-348560.0
    phase     gas;
}
