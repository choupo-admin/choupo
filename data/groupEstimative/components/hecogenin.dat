/*--------------------------------*- Choupo -*-----------------------*\
  Component: hecogenin  (C27H42O4, CAS 467-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hecogenin;
formula     C27H42O4;
CAS         467-55-0;
InChIKey    QOLRLLFJMZLYQJ-UHFFFAOYSA-N;
MW          430.629;      // g/mol [origin=calculated method=formula-sum]
Tc          1326.04;      // K   [origin=predictive method=joback]
Pc          12.674;      // bar [origin=predictive method=joback]
omega       1.0826;      // -   [origin=predictive method=lee-kesler]
Tb          1074.29;      // K   [origin=predictive method=joback]
HvapTb      101017.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-396.93 3.98348 -0.0034654 1.3008e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 8; } { group C; count 3; } { group OH; count 1; } { group CH2CO; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 10; } { group CH_ring; count 9; } { group C_ring; count 3; } { group OH; count 1; } { group O_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hydroxyspirostan-12-one" "hocogenin" "agn-pc-00jquf" "5.alpha.-spirostan-12-one, (25r)-" "(3beta,5alpha,25r)-3-hydroxyspirostan-12-one" "spirostan-12-one, 3-hydroxy-, (3.beta.,5.alpha.,25r)-" );
gibbsFormation
{
    dHf_298   -837180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38120.0
    phase     gas;
}
