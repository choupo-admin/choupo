/*--------------------------------*- Choupo -*-----------------------*\
  Component: acenaphthene  (C12H10, CAS 83-32-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acenaphthene;
formula     C12H10;
CAS         83-32-9;
InChIKey    CWRYPZZKDGJXCA-UHFFFAOYSA-N;
MW          154.212;      // g/mol [origin=calculated method=formula-sum]
Tc          778.15;      // K   [origin=predictive method=joback]
Pc          35.179;      // bar [origin=predictive method=joback]
omega       0.4658;      // -   [origin=predictive method=lee-kesler]
Tb          536.92;      // K   [origin=predictive method=joback]
HvapTb      47596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.83 1.1292 -0.00098484 3.458e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dihydroacenaphthylene" "1,8-ethylenenaphthalene" "naphthyleneethylene" "peri-ethylenenaphthalene" "acenaphthylene, 1,2-dihydro-" "ethylenenaphthalene" "1,8-dihydroacenaphthalene" "acenaphthene solution" "naphthalene, 1,8-ethylene-" "1,8-ethylenenaphthalene;1,2-dihydroacenaphthene;" "73bcd470-1e93-4e76-bf03-e06fb8fe00ea" );
standardThermochemistry
{
    dHf_298   212950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     327.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=330520.0
}
