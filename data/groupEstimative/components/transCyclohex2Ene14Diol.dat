/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-cyclohex-2-ene-1,4-diol  (C6H10O2, CAS 41513-32-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        transCyclohex2Ene14Diol;
formula     C6H10O2;
CAS         41513-32-0;
InChIKey    FDODVZVWGKVMBO-PHDIDXHHSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          721.40;      // K   [origin=predictive method=joback]
Pc          50.875;      // bar [origin=predictive method=joback]
omega       1.1349;      // -   [origin=predictive method=lee-kesler]
Tb          535.28;      // K   [origin=predictive method=joback]
HvapTb      62720.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.87 0.6814 -0.00037628 6.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,4s)-cyclohex-2-ene-1,4-diol" "(+/-)-trans-2-cyclohexene-1,4-diol" );
gibbsFormation
{
    dHf_298   -379870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-227300.0
    phase     gas;
}
