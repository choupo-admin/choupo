/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-propenyl)cyclopentene  (C8H12, CAS 37689-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12PropenylCyclopentene;
formula     C8H12;
CAS         37689-19-3;
InChIKey    PHBGIFRCMRLXFK-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          604.71;      // K   [origin=predictive method=joback]
Pc          34.199;      // bar [origin=predictive method=joback]
omega       0.3045;      // -   [origin=predictive method=lee-kesler]
Tb          403.41;      // K   [origin=predictive method=joback]
HvapTb      34252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.719 0.7865 -0.00053734 1.484e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-prop-2-enylcyclopentene" "cyclopentene,1-(2-propenyl)-" );
gibbsFormation
{
    dHf_298   44110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168910.0
    phase     gas;
}
