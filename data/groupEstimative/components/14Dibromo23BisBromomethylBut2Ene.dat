/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromo-2,3-bis(bromomethyl)but-2-ene  (C6H8Br4, CAS 30432-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromo23BisBromomethylBut2Ene;
formula     C6H8Br4;
CAS         30432-16-7;
InChIKey    GJZKNORRVIUCCH-UHFFFAOYSA-N;
MW          399.746;      // g/mol [origin=calculated method=formula-sum]
Tc          855.49;      // K   [origin=predictive method=joback]
Pc          47.171;      // bar [origin=predictive method=joback]
omega       0.7356;      // -   [origin=predictive method=lee-kesler]
Tb          605.44;      // K   [origin=predictive method=joback]
HvapTb      54808.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.634 0.7464 -0.0006766 2.476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group Br; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dC; count 2; } { group Br; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)-2,3-bis(bromomethyl)but-2-ene" "2,3-di(bromomethyl)-1,4-dibrom butene-2" "2,3-bis (bromomethyl)-1,4-dibromo-2-butene" "2,3-bis-(bromomethyl)-1,4-dibromo-2-butene" "2-butene, 2,3-bis(bromomethyl)-1,4-dibromo-" "tetrakis(bromomethyl)ethylene" "2,3-bis(bromomethyl)-1,4-dibromobut-2-ene" "2-butene,1,4-dibromo-2,3-bis(bromomethyl)-" "1,4-dibromo-2,3-bis(bromomethyl)-2-butene;tetra(bromomethyl)ethene;tetrakis(bromomethyl)ethylene;" );
standardThermochemistry
{
    dHf_298   35790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120040.0
}
