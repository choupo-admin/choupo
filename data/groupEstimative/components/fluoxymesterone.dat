/*--------------------------------*- Choupo -*-----------------------*\
  Component: fluoxymesterone  (C20H29FO3, CAS 76-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fluoxymesterone;
formula     C20H29FO3;
CAS         76-43-7;
InChIKey    YLRFCQOZQXIBAB-RBZZARIASA-N;
MW          336.447;      // g/mol [origin=calculated method=formula-sum]
Tc          1177.05;      // K   [origin=predictive method=joback]
Pc          20.346;      // bar [origin=predictive method=joback]
omega       1.4126;      // -   [origin=predictive method=lee-kesler]
Tb          948.05;      // K   [origin=predictive method=joback]
HvapTb      92837.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-348.83 3.34356 -0.00343064 1.4734e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 3; } { group C; count 3; } { group CH=C; count 1; } { group OH; count 2; } { group CH2CO; count 1; } { group CF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 7; } { group CH_ring; count 3; } { group C_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group F; count 1; } { group OH; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9r,10s,11s,13s,14s,17s)-9-fluoranyl-10,13,17-trimethyl-11,17-bis(oxidanyl)-1,2,6,7,8,11,12,14,15,16-decahydrocyclopenta[a]phenanthren-3-one" "fluoxymestrone" "halotestin" "fluoximesterone" "androfluorene" "androfluorone" "androsterolo" "fluosterone" "fluotestin" "oralsterone" "ultandrene" "flusteron" );
gibbsFormation
{
    dHf_298   -787750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     835.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-315780.0
    phase     gas;
}
