/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenamide, isooctyl 2-propenoate polymer  (C14H25NO3, CAS 50922-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenamideIsooctyl2PropenoatePolymer;
formula     C14H25NO3;
CAS         50922-82-2;
InChIKey    XVKLGCDWSRXKNR-UHFFFAOYSA-N;
MW          255.358;      // g/mol [origin=calculated method=formula-sum]
Tc          892.85;      // K   [origin=predictive method=joback]
Pc          16.893;      // bar [origin=predictive method=joback]
omega       0.9403;      // -   [origin=predictive method=lee-kesler]
Tb          698.86;      // K   [origin=predictive method=joback]
HvapTb      70118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.575 1.07264 -0.0003021 -8.264e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 2; } { group COO; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group CdO; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylheptyl prop-2-enoate;prop-2-enamide" "2-propenoic acid, isooctyl ester, polymer with 2-propenamide" "6-methylheptyl prop-2-enoate; prop-2-enamide" );
gibbsFormation
{
    dHf_298   -594400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     919.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-237360.0
    phase     gas;
}
