/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxepanone, polymer with 1,6-diisocyanatohexane and 1,6-hexanediol  (C20H36N2O6, CAS 164250-92-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OxepanonePolymerWith16DiisocyanatohexaneAnd16Hexanediol;
formula     C20H36N2O6;
CAS         164250-92-4;
InChIKey    ZPLJMDPCZDBJDM-UHFFFAOYSA-N;
MW          400.516;      // g/mol [origin=calculated method=formula-sum]
Tc          1301.74;      // K   [origin=predictive method=joback]
Pc          13.090;      // bar [origin=predictive method=joback]
omega       1.1252;      // -   [origin=predictive method=lee-kesler]
Tb          1055.87;      // K   [origin=predictive method=joback]
HvapTb      121097.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 16; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 12; } { group dCd; count 2; } { group CH2_ring; count 5; } { group OH; count 2; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-diisocyanatohexane;hexane-1,6-diol;oxepan-2-one" );
