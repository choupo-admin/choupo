/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-methyl-4-aminodiphenyl  (C13H13N, CAS 1204-78-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl4Aminodiphenyl;
formula     C13H13N;
CAS         1204-78-0;
InChIKey    NQVLOHKMEASTMW-UHFFFAOYSA-N;
MW          183.254;      // g/mol [origin=calculated method=formula-sum]
Tc          886.93;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.6027;      // -   [origin=predictive method=lee-kesler]
Tb          632.89;      // K   [origin=predictive method=joback]
HvapTb      61049.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.65 1.02392 -0.00065512 1.557e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-methylphenyl)aniline" "4'-methylbiphenylamine" "4-biphenylamine, 4'-methyl-" "4-amino-4'-methylbiphenyl" "4'-methylbiphenyl-4-amine" "4-(4-methylphenyl)phenylamine" "4'-methyl[1,1'-biphenyl]-4-amine" "4'-methyl-biphenyl-4-ylamine" "4'-methyl-[1,1'-biphenyl]-4-amine" "4'-methyl [1,1'-biphenyl]-4-amine" );
gibbsFormation
{
    dHf_298   172260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=330590.0
    phase     gas;
}
