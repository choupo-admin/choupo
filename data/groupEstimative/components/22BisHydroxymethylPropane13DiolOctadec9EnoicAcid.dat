/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(hydroxymethyl)propane-1,3-diol;octadec-9-enoic acid  (C23H46O6, CAS 12772-47-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisHydroxymethylPropane13DiolOctadec9EnoicAcid;
formula     C23H46O6;
CAS         12772-47-3;
InChIKey    ARWLNYJOVMFZNY-UHFFFAOYSA-N;
MW          418.615;      // g/mol [origin=calculated method=formula-sum]
Tc          1682.29;      // K   [origin=predictive method=joback]
Pc          11.216;      // bar [origin=predictive method=joback]
omega       0.2693;      // -   [origin=predictive method=lee-kesler]
Tb          1242.40;      // K   [origin=predictive method=joback]
HvapTb      149628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.908 2.31522 -0.0012624 2.318e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 4; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group C; count 1; } { group dCH; count 2; } { group OH; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-octadecenoic acid (9z)-,esters,ester with 2,2-bis(hydroxymethyl)-1,3-propanediol" "9-octadecenoic acid (z)-, ester with 2,2-bis(hydroxymethyl)-1,3-propanediol;pentaerythritol oleate;9-octadecenoic acid (9z)-, ester with 2,2-bis(hydroxymethyl)-1,3-propanediol;pentol.;9-octadecensure (z)-, ester mit 2,2-bis(hydroxymethyl)-1,3-propandiol;9-octadecenoic acid (z)-, ester with 2,2-bis(hydroxymethyl)-1,3-propanediol pentaerythritol oleate 9-octadecenoic acid (z)-, ester with2,2-bis(hydroxymethyl)-1,3-propanediol 9-octadecenoic acid(z)-,ester with 2,2-bis(hydroxymethyl)-1,3-propanediol" );
gibbsFormation
{
    dHf_298   -1480390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1370.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-770110.0
    phase     gas;
}
