/*--------------------------------*- Choupo -*-----------------------*\
  Component: dl-m-tyrosine  (C9H11NO3, CAS 775-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dlMTyrosine;
formula     C9H11NO3;
CAS         775-06-4;
InChIKey    JZKXXXDKRQWDET-UHFFFAOYSA-N;
MW          181.191;      // g/mol [origin=calculated method=formula-sum]
Tc          973.85;      // K   [origin=predictive method=joback]
Pc          47.694;      // bar [origin=predictive method=joback]
omega       1.1987;      // -   [origin=predictive method=lee-kesler]
Tb          730.42;      // K   [origin=predictive method=joback]
HvapTb      78335.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.709 1.0531 -0.00087256 2.93e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3-(3-hydroxyphenyl)propanoic acid" "3-(3-hydroxyphenyl)-dl-alanine" "2-amino-3-(3-hydroxyphenyl)propanoic acid" "m-tyrosine, dl-" "d,l-metatyrosine" "dl-m-tyrosine;" "dl-phenylalanine, 3-hydroxy-" "3-(m-hydroxyphenyl)-dl-alanine" "dl-meta-tyrosine" "3-hydroxy-dl-phenylalanine" "dl-3-[3-hydroxyphenyl]alanine" "(+/-)-2-amino-3-(3-hydroxyphenyl)propionic acid" );
gibbsFormation
{
    dHf_298   -491630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-297210.0
    phase     gas;
}
