/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptanophenone  (C13H18O, CAS 1671-75-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptanophenone;
formula     C13H18O;
CAS         1671-75-6;
InChIKey    UXMQORVHJMUQFD-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          782.57;      // K   [origin=predictive method=joback]
Pc          23.293;      // bar [origin=predictive method=joback]
omega       0.6632;      // -   [origin=predictive method=lee-kesler]
Tb          577.59;      // K   [origin=predictive method=joback]
HvapTb      53554.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.475 1.13192 -0.0006959 1.5996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylheptan-1-one" "1-heptanone, 1-phenyl-" "n-heptanophenone" "enanthophenone" "hexyl phenyl ketone" "1-phenyl-heptan-1-one" "2,3,4,5-tetrahydro-1h-benzo[b]azepin" );
gibbsFormation
{
    dHf_298   -187700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42070.0
    phase     gas;
}
