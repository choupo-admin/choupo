/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholest-4-en-3-ol  (C27H46O, CAS 14597-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholest4En3Ol;
formula     C27H46O;
CAS         14597-42-3;
InChIKey    UIMGHSAOLFTOBF-UHFFFAOYSA-N;
MW          386.664;      // g/mol [origin=calculated method=formula-sum]
Tc          1168.48;      // K   [origin=predictive method=joback]
Pc          10.785;      // bar [origin=predictive method=joback]
omega       0.9537;      // -   [origin=predictive method=lee-kesler]
Tb          947.58;      // K   [origin=predictive method=joback]
HvapTb      89836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-306.387 3.5591 -0.00294984 1.0573e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,6,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-ol" "allocholesterol" "4-cholesten-3.beta.-ol" "cholest-4-en-3-ol, (3.beta.)-" "coprostenol" "allocholesterin" "4:5-coprosten-3-ol" "cholest-4-en-3.beta.-ol" "cholest-4-en-3.alpha.-ol" "3.beta.-hydroxycholest-4-ene" "cholest-4-en-3-ol, (3.alpha.)-" "(3s,8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,6,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-ol" );
standardThermochemistry
{
    dHf_298   -487230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     946.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=203480.0
}
