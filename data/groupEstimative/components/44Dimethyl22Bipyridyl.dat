/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-dimethyl-2,2'-bipyridyl  (C12H12N2, CAS 1134-35-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethyl22Bipyridyl;
formula     C12H12N2;
CAS         1134-35-6;
InChIKey    NBPGPQJFYXNFKN-UHFFFAOYSA-N;
MW          184.242;      // g/mol [origin=calculated method=formula-sum]
Tc          911.73;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       0.5727;      // -   [origin=predictive method=lee-kesler]
Tb          644.88;      // K   [origin=predictive method=joback]
HvapTb      60602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.11 0.93456 -0.00057584 1.364e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C5H3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-(4-methylpyridin-2-yl)pyridine" "4,4'-dimethyl-2,2'-bipyridine" "2,2'-bi-4-picoline" "4,4'-dimethyl-2,2'-dipyridyl" "2,2'-bipyridine, 4,4'-dimethyl-" "2,2'-di-4-picolyl" "2,2'-bi(gamma-picoline)" "4,4-dimethyl-2,2-bipyridyl" "2,2'-bipyridyl, 4,4'-dimethyl-" "4,4'-dimethyl-[2,2']bipyridinyl" "4-methyl-2-(4-methyl(2-pyridyl))pyridine" "4,2'-bipyridine" );
gibbsFormation
{
    dHf_298   224690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=409820.0
    phase     gas;
}
