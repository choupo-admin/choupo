/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-methylphenoxy)acetic acid  (C9H10O3, CAS 1878-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylphenoxyAceticAcid;
formula     C9H10O3;
CAS         1878-49-5;
InChIKey    QJVXBRUGKLCUMY-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          827.30;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.8137;      // -   [origin=predictive method=lee-kesler]
Tb          605.11;      // K   [origin=predictive method=joback]
HvapTb      58140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.201 0.70802 -0.00039156 6.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methylphenoxy)ethanoic acid" "acetic acid, (2-methylphenoxy)-" "2-(2-methylphenoxy)acetic acid" "2-methylphenoxyacetic acid" "o-tolyloxyacetic acid" "(o-tolyloxy)acetic acid" "acetic acid, (o-tolyloxy)-" "acide o-methylphenoxyacetique [french]" "o-toloxyacetic acid" "o-cresoxyacetic acid" "acide o-methylphenoxyacetique" "o-methylphenoxyacetic acid" );
standardThermochemistry
{
    dHf_298   -486520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-321230.0
}
