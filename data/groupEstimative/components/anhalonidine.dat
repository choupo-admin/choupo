/*--------------------------------*- Choupo -*-----------------------*\
  Component: anhalonidine  (C12H17NO3, CAS 17627-77-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anhalonidine;
formula     C12H17NO3;
CAS         17627-77-9;
InChIKey    PRNZAMQMBOFSJY-ZETCQYMHSA-N;
MW          223.272;      // g/mol [origin=calculated method=formula-sum]
Tc          933.91;      // K   [origin=predictive method=joback]
Pc          31.245;      // bar [origin=predictive method=joback]
omega       0.9557;      // -   [origin=predictive method=lee-kesler]
Tb          700.80;      // K   [origin=predictive method=joback]
HvapTb      71245.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.61 1.04256 -0.00060664 1.424e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 1; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH3O; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group O; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s)-6,7-dimethoxy-1-methyl-1,2,3,4-tetrahydroisoquinolin-8-ol" "8-isoquinolinol, 1,2,3,4-tetrahydro-6,8-dimethoxy-1-methyl-, (s)-" );
gibbsFormation
{
    dHf_298   -426190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94580.0
    phase     gas;
}
