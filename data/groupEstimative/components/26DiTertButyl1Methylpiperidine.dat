/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-di-tert-butyl-1-methylpiperidine  (C14H29N, CAS 85237-78-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DiTertButyl1Methylpiperidine;
formula     C14H29N;
CAS         85237-78-1;
InChIKey    GWIVMGASCWOOFD-UHFFFAOYSA-N;
MW          211.393;      // g/mol [origin=calculated method=formula-sum]
Tc          737.63;      // K   [origin=predictive method=joback]
Pc          17.669;      // bar [origin=predictive method=joback]
omega       0.4276;      // -   [origin=predictive method=lee-kesler]
Tb          536.51;      // K   [origin=predictive method=joback]
HvapTb      46157.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-124.02 1.81464 -0.001266 3.479e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 2; } { group C; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group C; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-ditert-butyl-1-methyl-piperidine" "1-methyl-2,6-t-butylpiperidine" "2,6-ditert-butyl-1-methylpiperidine" "(2r,6s)-2,6-ditert-butyl-1-methylpiperidine" "piperidine,2,6-bis(1,1-dimethylethyl)-1-methyl-" "piperidine, 2,6-bis(1,1-dimethylethyl)-1-methyl-, cis-" );
gibbsFormation
{
    dHf_298   -242120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212300.0
    phase     gas;
}
