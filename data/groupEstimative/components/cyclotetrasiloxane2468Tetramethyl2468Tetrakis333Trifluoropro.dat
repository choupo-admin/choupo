/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclotetrasiloxane, 2,4,6,8-tetramethyl-2,4,6,8-tetrakis(3,3,3-trifluoropropyl)-  (C16H28F12O4Si4, CAS 429-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H28F12O4Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        cyclotetrasiloxane2468Tetramethyl2468Tetrakis333Trifluoropro;
formula     C16H28F12O4Si4;
CAS         429-67-4;
InChIKey    XOVNCWWRDSAYNE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          624.712;      // g/mol [origin=calculated method=formula-sum]
Tc          829.86;      // K   [origin=predictive method=joback]
Pc          7.953;      // bar [origin=predictive method=joback]
omega       0.6892;      // -   [origin=predictive method=lee-kesler]
Tb          673.08;      // K   [origin=predictive method=joback]
HvapTb      55832.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (134.798 1.49968 -0.000245 -2.72e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CF3; count 4; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group C; count 4; } { group F; count 12; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6,8-tetramethyl-2,4,6,8-tetrakis[3,3,3-tris(fluoranyl)propyl]-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "2,4,6,8-tetramethyl-2,4,6,8-tetrakis(3,3,3-trifluoropropyl)-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "tetramethyl tetra-3-trifluoropropyl cyclotetrasiloxane" "2,4,6,8-tetramethyl-2,4,6,8-tetrakis(3,3,3-trifluoropropyl)cyclotetrasiloxane" "cyclotetrasiloxane,2,4,6,8-tetramethyl-2,4,6,8-tetrakis(3,3,3-trifluoropropyl)-" "(3,3,3-trifluoropropyl)methylsiloxanecyclic tetramer; 1,3,5,7-tetrakis(3,3,3-trifluoropropyl)-1,3,5,7-tetramethylcyclotetrasiloxane" );
gibbsFormation
{
    dHf_298   -3649390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1276.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2949680.0
    phase     gas;
}
