  Component: 2-propenoic acid, 2-methyl-, 2-isocyanatoethyl ester, telomer with 1-dodecanethiol and ethenylbenzene  (C27H43NO3S, CAS 70942-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2Methyl2IsocyanatoethylEsterTelomerWith1Dodeca;
formula     C27H43NO3S;
CAS         70942-11-9;
InChIKey    GAFLKVDGJKSDHV-UHFFFAOYSA-N;
MW          461.705;      // g/mol [origin=calculated method=formula-sum]
Tc          1258.59;      // K   [origin=predictive method=joback]
Pc          8.535;      // bar [origin=predictive method=joback]
omega       0.8221;      // -   [origin=predictive method=lee-kesler]
Tb          1027.83;      // K   [origin=predictive method=joback]
HvapTb      100976.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2SH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCd; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecane-1-thiol;ethenylbenzene;2-isocyanatoethyl 2-methylprop-2-enoate" "2-isocyanatoethyl methacrylate, styrene, dodecanethiol telomer" );
