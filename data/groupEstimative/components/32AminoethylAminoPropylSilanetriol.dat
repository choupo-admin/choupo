/*--------------------------------*- Choupo -*-----------------------*\
  Component: {3-[(2-aminoethyl)amino]propyl}silanetriol  (C5H16N2O3Si, CAS 68400-09-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H16N2O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        32AminoethylAminoPropylSilanetriol;
formula     C5H16N2O3Si;
CAS         68400-09-9;
InChIKey    QNHNSPNFZFBEQR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          180.279;      // g/mol [origin=calculated method=formula-sum]
Tc          888.54;      // K   [origin=predictive method=joback]
Pc          46.151;      // bar [origin=predictive method=joback]
omega       2.0754;      // -   [origin=predictive method=lee-kesler]
Tb          714.64;      // K   [origin=predictive method=joback]
HvapTb      94132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.315 0.5127 -1.66e-05 -1.18e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 3; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group OH; count 3; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-[3-tris(oxidanyl)silylpropyl]ethane-1,2-diamine" "(3-((2-aminoethyl)amino)propyl)silanetriol" "n-(2-aminoethyl)-3-aminopropyl-silantriol" "hydrolyzed (gamma-(beta-aminoethylamino)propyl)triethoxysilane polymer" "n'-(3-trihydroxysilylpropyl)ethane-1,2-diamine" "silanetriol, (3-((2-aminoethyl)amino)propyl)-, homopolymer" );
gibbsFormation
{
    dHf_298   -627580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-368160.0
    phase     gas;
}
