/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene sulfide  (C6H10S, CAS 286-28-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexeneSulfide;
formula     C6H10S;
CAS         286-28-2;
InChIKey    PQWJNIJNYRPOAA-UHFFFAOYSA-N;
MW          114.206;      // g/mol [origin=calculated method=formula-sum]
Tc          625.34;      // K   [origin=predictive method=joback]
Pc          43.569;      // bar [origin=predictive method=joback]
omega       0.2521;      // -   [origin=predictive method=lee-kesler]
Tb          402.46;      // K   [origin=predictive method=joback]
HvapTb      34760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.35 0.88041 -0.0007153 2.377e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-thiabicyclo[4.1.0]heptane" "1,2-epithiocyclohexane" "1,2-cyclohexylene sulfide" "cyclohexane, 1,2-epithio-" "cyclohexene, sulfide" "cyclohexene episulfide" "7-thiabicyclo(4.1.0)heptane" "cyclohexane,2-epithio-" "7-thiabicyclo(4.1.0)heptane (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   17530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     279.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148900.0
    phase     gas;
}
