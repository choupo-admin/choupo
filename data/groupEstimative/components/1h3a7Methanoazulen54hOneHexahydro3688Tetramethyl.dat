/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-3a,7-methanoazulen-5(4h)-one, hexahydro-3,6,8,8-tetramethyl-  (C15H24O, CAS 68891-95-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1h3a7Methanoazulen54hOneHexahydro3688Tetramethyl;
formula     C15H24O;
CAS         68891-95-2;
InChIKey    CHPQWDBBFXQHQC-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          861.45;      // K   [origin=predictive method=joback]
Pc          20.812;      // bar [origin=predictive method=joback]
omega       0.5042;      // -   [origin=predictive method=lee-kesler]
Tb          625.85;      // K   [origin=predictive method=joback]
HvapTb      50085.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-217.45 2.19838 -0.002015 8.038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 4; } { group C; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group C_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cedranone" "1h-3a,7-methanoazulen-5(4h)-one, hexahydro-3,6,8,8-tetramethyl-, (3r,3ar,6s,7s,8as)-" "2,6,6,8-tetramethyltricyclo(5.3.1.01,5)undecan-9-one" "9-cedranone" "agn-pc-03f4gu" "3,6,8,8-tetramethylhexahydro-1h-3a,7-methanoazulene-5(4h)-one" "(3r-(3alpha,3abeta,6alpha,7beta,8aalpha))-hexahydro-3,6,8,8-tetramethyl-1h-3a,7-methanoazulen-5(4h)-one" "(3r-(3alpha,3abeta,6alpha,7beta,8aalpha))-hexahydro-3,6,8,8-tetramethyl-1h-3a,7-methenoazulen-5(4h)-one" );
standardThermochemistry
{
    dHf_298   -315090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76770.0
}
