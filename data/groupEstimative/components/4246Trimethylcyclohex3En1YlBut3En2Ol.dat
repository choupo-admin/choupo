/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2,4,6-trimethylcyclohex-3-en-1-yl)but-3-en-2-ol  (C13H22O, CAS 67923-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4246Trimethylcyclohex3En1YlBut3En2Ol;
formula     C13H22O;
CAS         67923-53-9;
InChIKey    WQTLBWPUJXRBIN-UHFFFAOYSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          800.26;      // K   [origin=predictive method=joback]
Pc          21.553;      // bar [origin=predictive method=joback]
omega       0.8265;      // -   [origin=predictive method=lee-kesler]
Tb          607.29;      // K   [origin=predictive method=joback]
HvapTb      61546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.15 1.25238 -0.00069124 1.327e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-buten-2-ol, 4-(2,4,6-trimethyl-3-cyclohexen-1-yl)-" "(e)-4-(2,4,6-trimethyl-1-cyclohex-3-enyl)but-3-en-2-ol" );
gibbsFormation
{
    dHf_298   -291990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28900.0
    phase     gas;
}
