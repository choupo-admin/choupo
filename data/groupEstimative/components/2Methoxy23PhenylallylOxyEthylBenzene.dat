/*--------------------------------*- Choupo -*-----------------------*\
  Component: [2-methoxy-2-[(3-phenylallyl)oxy]ethyl]benzene  (C18H20O2, CAS 68426-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy23PhenylallylOxyEthylBenzene;
formula     C18H20O2;
CAS         68426-05-1;
InChIKey    DIBGDYHBYFMHED-UHFFFAOYSA-N;
MW          268.356;      // g/mol [origin=calculated method=formula-sum]
Tc          942.14;      // K   [origin=predictive method=joback]
Pc          19.613;      // bar [origin=predictive method=joback]
omega       0.7506;      // -   [origin=predictive method=lee-kesler]
Tb          713.36;      // K   [origin=predictive method=joback]
HvapTb      64604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.148 1.45552 -0.0008828 1.913e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(1-methoxy-2-phenyl-ethoxy)prop-1-enylbenzene" "benzene, [3-(1-methoxy-2-phenylethoxy)-1-propen-1-yl]-" );
standardThermochemistry
{
    dHf_298   -94290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193280.0
}
