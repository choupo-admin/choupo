/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-pyridine, 2-(2-chlorophenyl)ethenyl-  (C13H10ClN, CAS 5350-12-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        zPyridine22ChlorophenylEthenyl;
formula     C13H10ClN;
CAS         5350-12-9;
InChIKey    YEZHQUGOABFELJ-HJWRWDBZSA-N;
MW          215.68;      // g/mol [origin=calculated method=formula-sum]
Tc          918.46;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.5473;      // -   [origin=predictive method=lee-kesler]
Tb          650.67;      // K   [origin=predictive method=joback]
HvapTb      60299.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.67 1.08206 -0.00079222 2.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group C5H4N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Cl; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(z)-2-(2-chlorophenyl)ethenyl]pyridine" "pyridine, 2-[2-(2-chlorophenyl)ethenyl]-(z)" "pyridine, 2-(2-(2-chlorophenyl)ethenyl)-, (z)-" );
standardThermochemistry
{
    dHf_298   284210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=419110.0
}
