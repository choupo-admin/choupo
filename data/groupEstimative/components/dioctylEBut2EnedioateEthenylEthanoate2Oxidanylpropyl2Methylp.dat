/*--------------------------------*- Choupo -*-----------------------*\
  Component: dioctyl (e)-but-2-enedioate;ethenyl ethanoate;2-oxidanylpropyl 2-methylprop-2-enoate  (C31H54O9, CAS 192230-35-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dioctylEBut2EnedioateEthenylEthanoate2Oxidanylpropyl2Methylp;
formula     C31H54O9;
CAS         192230-35-6;
InChIKey    TYKHRBNRWSKUJQ-VRZXRVJBSA-N;
MW          570.764;      // g/mol [origin=calculated method=formula-sum]
Tc          1612.48;      // K   [origin=predictive method=joback]
Pc          5.923;      // bar [origin=predictive method=joback]
omega       0.0665;      // -   [origin=predictive method=lee-kesler]
Tb          1233.70;      // K   [origin=predictive method=joback]
HvapTb      129805.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (141.735 2.3371 -0.0006201 -2.118e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 15; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group CH3COO; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 15; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 3; } { group dC; count 1; } { group OH; count 1; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butenedioic acid (2e)-, 1,4-dioctyl ester, polymer with ethenyl acetate and 2-hydroxypropyl 2-methyl-2-propenoate" "2-butenedioic acid (2e)-, dioctyl ester, polymer with ethenyl acetate and 2-hydroxypropyl 2-methyl-2-propenoate" );
standardThermochemistry
{
    dHf_298   -1974750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1805.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1132770.0
}
