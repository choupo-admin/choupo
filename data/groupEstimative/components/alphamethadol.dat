/*--------------------------------*- Choupo -*-----------------------*\
  Component: alphamethadol  (C21H29NO, CAS 17199-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphamethadol;
formula     C21H29NO;
CAS         17199-54-1;
InChIKey    QIRAYNIFEOXSPW-YLJYHZDGSA-N;
MW          311.469;      // g/mol [origin=calculated method=formula-sum]
Tc          1048.81;      // K   [origin=predictive method=joback]
Pc          16.701;      // bar [origin=predictive method=joback]
omega       1.0949;      // -   [origin=predictive method=lee-kesler]
Tb          833.95;      // K   [origin=predictive method=joback]
HvapTb      83542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.248 2.13658 -0.0015022 4.078e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,6r)-6-(dimethylamino)-4,4-diphenyl-heptan-3-ol" "alfametadol" "alfametadolo" "alphamethadolum" "alpha-methadol" "alpha-dl-methadol" "alfametadolo [dcit]" "aphamethadol, (+)-" "(3r,6r)-methadol" "alpha-methadol, (+)-" "usaf el-33" "alphamethadolum [inn-latin]" );
standardThermochemistry
{
    dHf_298   -107720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     770.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=322680.0
}
