/*--------------------------------*- Choupo -*-----------------------*\
  Component: minepentate  (C18H27NO3, CAS 13877-99-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        minepentate;
formula     C18H27NO3;
CAS         13877-99-1;
InChIKey    XZUULFZXNSIACY-UHFFFAOYSA-N;
MW          305.418;      // g/mol [origin=calculated method=formula-sum]
Tc          959.99;      // K   [origin=predictive method=joback]
Pc          17.303;      // bar [origin=predictive method=joback]
omega       0.8978;      // -   [origin=predictive method=lee-kesler]
Tb          746.72;      // K   [origin=predictive method=joback]
HvapTb      68904.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.636 2.06444 -0.0015536 4.915e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(dimethylamino)ethoxy]ethyl 1-phenylcyclopentane-1-carboxylate" "minepentatum [inn-latin]" "2-[2-(dimethylamino)ethoxy]ethyl 1-phenylcyclopentanecarboxylate" "2-(2-(dimethylamino)ethoxy)ethyl 1-phenylcyclopentanecarboxylate" "2-(2-dimethylaminoethoxy)ethanol-1-phenyl-cyclopentylcarboxylate" "cyclopentanecarboxylic acid, 1-phenyl-, 2-(2-(dimethylamino)ethoxy) ethyl ester" "minepentato" "minepentatum" "minepentate [ban:inn]" "2-(2-dimethylaminoethyloxy)ethyl 1-phenylcyclopentane-1-carboxylate" "cyclopentanecarboxylicacid, 1-phenyl-, 2-[2-(dimethylamino)ethoxy]ethyl ester" );
gibbsFormation
{
    dHf_298   -484570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     848.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60440.0
    phase     gas;
}
