/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,8-trimethylnonen-3-ol  (C12H24O, CAS 93882-22-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        228Trimethylnonen3Ol;
formula     C12H24O;
CAS         93882-22-5;
InChIKey    PKDBKVJGYKPROI-UHFFFAOYSA-N;
MW          184.323;      // g/mol [origin=calculated method=formula-sum]
Tc          743.44;      // K   [origin=predictive method=joback]
Pc          20.774;      // bar [origin=predictive method=joback]
omega       0.8408;      // -   [origin=predictive method=lee-kesler]
Tb          566.71;      // K   [origin=predictive method=joback]
HvapTb      57339.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.757 1.3295 -0.0009205 2.62e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,8-trimethylnon-3-en-3-ol" "(z)-2,2,8-trimethylnon-3-en-3-ol" );
standardThermochemistry
{
    dHf_298   -349840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14590.0
}
