/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-4-prop-1-enylphenol  (C10H12O2, CAS 97-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy4Prop1Enylphenol;
formula     C10H12O2;
CAS         97-54-1;
InChIKey    BJIOGJUNALELMI-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          794.17;      // K   [origin=predictive method=joback]
Pc          35.515;      // bar [origin=predictive method=joback]
omega       0.6627;      // -   [origin=predictive method=lee-kesler]
Tb          567.26;      // K   [origin=predictive method=joback]
HvapTb      56174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.41 0.92684 -0.00071352 2.341e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-4-prop-1-enyl-phenol" "phenol, 2-methoxy-4-(1-propen-1-yl)-" "2-methoxy-4-[(1z)-prop-1-en-1-yl]phenol" "4-isopropenyl-2-methoxy-phenol" "phenol,2-methoxy-4-(1e)-1-propen-1-yl-" "phenol,2-methoxy-4-(1z)-1-propen-1-yl-" "phenol,2-methoxy-4-(1-propenyl)-, (z)-; phenol, 2-methoxy-4-(1z)-1-propenyl- (9ci);phenol, 2-methoxy-4-propenyl-, (z)- (8ci); (z)-isoeugenol;cis-2-methoxy-4-propenylphenol; cis-4-propenylguaiacol; cis-isoeugenol" );
gibbsFormation
{
    dHf_298   -216980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43300.0
    phase     gas;
}
