/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzyloxyphenyl isocyanate  (C14H11NO2, CAS 50528-73-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BenzyloxyphenylIsocyanate;
formula     C14H11NO2;
CAS         50528-73-9;
InChIKey    HFIHSWMJFCMLJE-UHFFFAOYSA-N;
MW          225.247;      // g/mol [origin=calculated method=formula-sum]
Tc          909.15;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.7421;      // -   [origin=predictive method=lee-kesler]
Tb          667.35;      // K   [origin=predictive method=joback]
HvapTb      63914.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH2; count 1; } { group dCd; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-4-phenylmethoxy-benzene" "1-(benzyloxy)-4-isocyanatobenzene" "1-isocyanato-4-phenylmethoxybenzene" "4-(benzyloxy)phenyl isocyanate" "benzyl 4-isocyanatophenyl ether" "4-(phenylmethoxy)benzenisocyanate" "benzene,1-isocyanato-4-(phenylmethoxy)-" );
