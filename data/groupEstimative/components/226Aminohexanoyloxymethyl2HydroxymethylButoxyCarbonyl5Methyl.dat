/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[2-(6-aminohexanoyloxymethyl)-2-(hydroxymethyl)butoxy]carbonyl-5-methylbicyclo[2.2.1]heptane-3-carboxylic acid  (C22H37NO7, CAS 69178-35-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        226Aminohexanoyloxymethyl2HydroxymethylButoxyCarbonyl5Methyl;
formula     C22H37NO7;
CAS         69178-35-4;
InChIKey    OSUIYPNGJIVLBX-UHFFFAOYSA-N;
MW          427.538;      // g/mol [origin=calculated method=formula-sum]
Tc          1393.77;      // K   [origin=predictive method=joback]
Pc          12.081;      // bar [origin=predictive method=joback]
omega       1.0512;      // -   [origin=predictive method=lee-kesler]
Tb          1130.13;      // K   [origin=predictive method=joback]
HvapTb      121639.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.171 2.46944 -0.0015298 3.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 5; } { group C; count 1; } { group OH; count 1; } { group CH2COO; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group C; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 5; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(6-azanylhexanoyloxymethyl)-2-(hydroxymethyl)butoxy]carbonyl-5-methyl-bicyclo[2.2.1]heptane-3-carboxylic acid" "2-(2-(((6-amino-1-oxohexyl)oxy)methyl)-2-(hydroxymethyl)butyl) hydrogen 5-methylbicyclo(2.2.1)heptane-2,3-dicarboxylate" "bicyclo(2.2.1)heptane-2,3-dicarboxylic acid, 5-methyl-, 2-(2-(((6-amino-1-oxohexyl)oxy)methyl)-2-(hydroxymethyl)butyl) ester" "bicyclo[2.2.1]heptane-2,3-dicarboxylic acid, 5-methyl-, 2-[2-[[(6-amino-1-oxohexyl)oxy]methyl]-2-(hydroxymethyl)butyl] ester" "3-{[2-{[(6-aminohexanoyl)oxy]methyl}-2-(hydroxymethyl)butoxy]carbonyl}-6-methylbicyclo[2.2.1]heptane-2-carboxylic acid" "bicyclo[2.2.1]heptane-2,3-dicarboxylicacid, 5-methyl-, 2-[2-[[(6-amino-1-oxohexyl)oxy]methyl]-2-(hydroxymethyl)butyl]ester" );
standardThermochemistry
{
    dHf_298   -1531010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     944.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-811550.0
}
