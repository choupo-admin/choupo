/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2'-acetoxyacetophenone  (C10H10O3, CAS 7250-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetoxyacetophenone;
formula     C10H10O3;
CAS         7250-94-4;
InChIKey    WWEDAIJJBDFOOK-UHFFFAOYSA-N;
MW          178.187;      // g/mol [origin=calculated method=formula-sum]
Tc          791.71;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.6725;      // -   [origin=predictive method=lee-kesler]
Tb          572.15;      // K   [origin=predictive method=joback]
HvapTb      54945.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.96 0.73264 -0.00037106 4.226e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-ethanoylphenyl) ethanoate" "2-acetylphenyl acetate" "omega-acetoxyacetophenone" "2'-acetoxy acetophenone" "(2-acetylphenyl) acetate" "acetophenone, 2-hydroxy-, acetate (8ci)" );
gibbsFormation
{
    dHf_298   -454530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-303190.0
    phase     gas;
}
