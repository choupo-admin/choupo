/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-3-methylcyclopent-2-en-1-one  (C7H10O2, CAS 14189-85-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy3Methylcyclopent2En1One;
formula     C7H10O2;
CAS         14189-85-6;
InChIKey    GTEGQQAMGYNDKS-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          697.49;      // K   [origin=predictive method=joback]
Pc          36.598;      // bar [origin=predictive method=joback]
omega       0.4593;      // -   [origin=predictive method=lee-kesler]
Tb          479.07;      // K   [origin=predictive method=joback]
HvapTb      40015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.41 0.42054 -3.8e-05 -7.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dC_ring; count 2; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-3-methyl-cyclopent-2-en-1-one" "cyclotene monomethyl ether" "2-cyclopenten-1-one, 2-methoxy-3-methyl-" );
standardThermochemistry
{
    dHf_298   -342070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     303.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164570.0
}
