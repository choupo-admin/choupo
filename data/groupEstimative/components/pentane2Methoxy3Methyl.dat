/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentane, 2-methoxy-3-methyl-  (C7H16O, CAS 89045-01-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentane2Methoxy3Methyl;
formula     C7H16O;
CAS         89045-01-2;
InChIKey    ZXVHDFULCANHLR-UHFFFAOYSA-N;
MW          116.204;      // g/mol [origin=calculated method=formula-sum]
Tc          553.47;      // K   [origin=predictive method=joback]
Pc          27.965;      // bar [origin=predictive method=joback]
omega       0.3645;      // -   [origin=predictive method=lee-kesler]
Tb          381.30;      // K   [origin=predictive method=joback]
HvapTb      32810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.661 0.61748 -0.0002524 1.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-3-methyl-pentane" "agn-pc-02pefj" );
standardThermochemistry
{
    dHf_298   -330590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-101820.0
}
