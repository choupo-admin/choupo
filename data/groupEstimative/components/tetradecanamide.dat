/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecanamide  (C14H29NO, CAS 638-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecanamide;
formula     C14H29NO;
CAS         638-58-4;
InChIKey    QEALYLRSRQDCRA-UHFFFAOYSA-N;
MW          227.392;      // g/mol [origin=calculated method=formula-sum]
Tc          823.70;      // K   [origin=predictive method=joback]
Pc          16.769;      // bar [origin=predictive method=joback]
omega       0.9590;      // -   [origin=predictive method=lee-kesler]
Tb          646.32;      // K   [origin=predictive method=joback]
HvapTb      64145.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.012 1.36772 -0.0007625 1.5736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "myristamide" "myristic amide" "tetradecylamide" "myristic acid amide" "myristicamide" "tetradecanoic acid amide" );
gibbsFormation
{
    dHf_298   -411080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     779.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4530.0
    phase     gas;
}
