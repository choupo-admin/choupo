/*--------------------------------*- Choupo -*-----------------------*\
  Component: permonid  (C17H21NO2, CAS 427-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        permonid;
formula     C17H21NO2;
CAS         427-00-9;
InChIKey    LNNWVNGFPYWNQE-GMIGKAJZSA-N;
MW          271.36;      // g/mol [origin=calculated method=formula-sum]
Tc          1013.90;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.9855;      // -   [origin=predictive method=lee-kesler]
Tb          768.14;      // K   [origin=predictive method=joback]
HvapTb      74932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-266.0 2.60152 -0.00261298 1.0537e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4ar,7as,12bs)-3-methyl-2,4,4a,5,6,7,7a,13-octahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-9-ol" "desomorphine" "dihydrodeoxymorphine" "dihydrodesoxymorphine-d" "desomorphinum [inn-latin]" "morphine, 6-deoxy-7,8-dihydro-" "4,5-epoxy-3-hydroxy-n-methylmorphinan" "morphinan-3-ol, 4,5-alpha-epoxy-17-methyl-" "desomorfin" "desomorfina" "desomorphinum" "dihydrodesoxymorphine" );
standardThermochemistry
{
    dHf_298   -109800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=305060.0
}
