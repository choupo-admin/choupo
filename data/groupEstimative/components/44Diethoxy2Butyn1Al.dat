/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-diethoxy-2-butyn-1-al  (C8H12O3, CAS 74149-25-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Diethoxy2Butyn1Al;
formula     C8H12O3;
CAS         74149-25-0;
InChIKey    BZORVIUSVBCDQY-UHFFFAOYSA-N;
MW          156.181;      // g/mol [origin=calculated method=formula-sum]
Tc          681.29;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.5845;      // -   [origin=predictive method=lee-kesler]
Tb          484.70;      // K   [origin=predictive method=joback]
HvapTb      46706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.892 0.46804 -9.346e-05 -4.922e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CHO; count 1; } { group CH2O; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group tC; count 2; } { group O; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-diethoxybut-2-ynal" "2-butynal,4,4-diethoxy-" "2-butyne-1,4-dialdiethyl acetal; 4,4-diethoxy-2-butynal; acetylenedicarboxaldehyde monodiethylacetal" );
standardThermochemistry
{
    dHf_298   -291450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-92680.0
}
