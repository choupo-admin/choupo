/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyldiphenylamine  (C13H13N, CAS 552-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethyldiphenylamine;
formula     C13H13N;
CAS         552-82-9;
InChIKey    DYFFAVRFJWYYQO-UHFFFAOYSA-N;
MW          183.254;      // g/mol [origin=calculated method=formula-sum]
Tc          803.38;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.4853;      // -   [origin=predictive method=lee-kesler]
Tb          562.84;      // K   [origin=predictive method=joback]
HvapTb      51127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.43 1.20492 -0.0008584 2.319e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-n-phenyl-aniline" "n-methyl-n-phenylaniline" "benzenamine, n-methyl-n-phenyl-" "methyldiphenylamine" "diphenylamine, n-methyl-" "n,n-diphenylmethylamine" "diphenyl methylamine" "methyl-diphenyl-amine" "n-methyl diphenylamine" "n,n-diphenyl methylamine" "diphenylamine, n-methyl- (8ci)" "i672" );
standardThermochemistry
{
    dHf_298   228940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=394180.0
}
