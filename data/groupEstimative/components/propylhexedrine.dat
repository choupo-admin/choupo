/*--------------------------------*- Choupo -*-----------------------*\
  Component: propylhexedrine  (C10H21N, CAS 101-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propylhexedrine;
formula     C10H21N;
CAS         101-40-6;
InChIKey    JCRIVQIOJSSCQD-UHFFFAOYSA-N;
MW          155.285;      // g/mol [origin=calculated method=formula-sum]
Tc          701.27;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       0.4843;      // -   [origin=predictive method=lee-kesler]
Tb          497.68;      // K   [origin=predictive method=joback]
HvapTb      44331.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.699 1.15804 -0.000653 1.274e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexyl-n-methyl-propan-2-amine" "benzedrex" "obesin" "dristan" "propylhexedrin" "hexahydrodesoxyephedrine" "chp-depot" "hydromethamphetamine" "propylhexadrine" "dristan inhaler" "1-cyclohexyl-n-methylpropan-2-amine" "1-cyclohexyl-2-(methylamino)propane" );
gibbsFormation
{
    dHf_298   -147220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144720.0
    phase     gas;
}
