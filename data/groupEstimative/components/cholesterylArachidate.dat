/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholesteryl arachidate  (C47H84O2, CAS 2573-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholesterylArachidate;
formula     C47H84O2;
CAS         2573-03-7;
InChIKey    SUOVMGLZSOAHJY-JREUTYQLSA-N;
MW          681.187;      // g/mol [origin=calculated method=formula-sum]
Tc          1820.04;      // K   [origin=predictive method=joback]
Pc          3.918;      // bar [origin=predictive method=joback]
omega       -0.2485;      // -   [origin=predictive method=lee-kesler]
Tb          1371.22;      // K   [origin=predictive method=joback]
HvapTb      125084.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-304.449 5.37032 -0.00391284 1.2284e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 28; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 21; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] icosanoate" "cholesteryl eicosanoate" "20:0 cholesteryl ester" "cholest-5-en-3beta-yl eicosanoate" "cholesterol arachidate" "ce(20:0)" "cholesterol, eicosanoate" "5-cholesten-3" "a-ol 3-arachidate" "3" "a-hydroxy-5-cholestene 3-arachidate" "cholest-5-en-3-ol (3beta)-, eicosanoate" );
standardThermochemistry
{
    dHf_298   -1065080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1725.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=198330.0
}
