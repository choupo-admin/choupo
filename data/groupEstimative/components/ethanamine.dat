/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanamine  (C2H7N, CAS 75-04-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanamine;
formula     C2H7N;
CAS         75-04-7;
InChIKey    QUSNBJAOOMFDIB-UHFFFAOYSA-N;
MW          45.085;      // g/mol [origin=calculated method=formula-sum]
Tc          499.82;      // K   [origin=predictive method=joback]
Pc          54.627;      // bar [origin=predictive method=joback]
omega       0.2808;      // -   [origin=predictive method=lee-kesler]
Tb          317.89;      // K   [origin=predictive method=joback]
HvapTb      30687.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.561 0.25572 -0.0001284 2.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethylamine" "monoethylamine" "aminoethane" "1-aminoethane" "ethylamine solution" "aethylamine" "etyloamina" "ethamine" "etilamina" "ethyl amine" "etyloamina [polish]" "aethylamine [german]" );
standardThermochemistry
{
    dHf_298   -50820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     285.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32410.0
}
