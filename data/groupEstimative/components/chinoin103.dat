/*--------------------------------*- Choupo -*-----------------------*\
  Component: chinoin 103  (C20H27NO2, CAS 57281-35-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chinoin103;
formula     C20H27NO2;
CAS         57281-35-3;
InChIKey    VURUWFSVRBGGPO-UHFFFAOYSA-N;
MW          313.441;      // g/mol [origin=calculated method=formula-sum]
Tc          1113.53;      // K   [origin=predictive method=joback]
Pc          19.304;      // bar [origin=predictive method=joback]
omega       1.2942;      // -   [origin=predictive method=lee-kesler]
Tb          891.72;      // K   [origin=predictive method=joback]
HvapTb      90258.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.047 1.9367 -0.00121728 2.831e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group ACH; count 7; } { group AC; count 3; } { group CH2NH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(cyclohexylamino)-1-naphthalen-1-yloxy-butan-2-ol" "4-(cyclohexylamino)-1-(1-naphthalenyloxy)-2-butanol" "2-butanol, 4-(cyclohexylamino)-1-(1-naphthyloxy)-" "naphthoxybutanolcyclohexylamine" "4-(cyclohexylamino)-1-naphthalen-1-yloxybutan-2-ol" "2-butanol,4-(cyclohexylamino)-1-(1-naphthalenyloxy)-" );
gibbsFormation
{
    dHf_298   -221940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     776.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196530.0
    phase     gas;
}
