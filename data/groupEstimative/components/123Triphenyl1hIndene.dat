/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-triphenyl-1h-indene  (C27H20, CAS 38274-35-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Triphenyl1hIndene;
formula     C27H20;
CAS         38274-35-0;
InChIKey    URBISKZYAXNRPC-UHFFFAOYSA-N;
MW          344.457;      // g/mol [origin=calculated method=formula-sum]
Tc          1225.83;      // K   [origin=predictive method=joback]
Pc          17.879;      // bar [origin=predictive method=joback]
omega       0.8389;      // -   [origin=predictive method=lee-kesler]
Tb          944.92;      // K   [origin=predictive method=joback]
HvapTb      86991.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-156.84 2.1696 -0.00157616 4.409e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 19; } { group AC; count 4; } { group ACCH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 19; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   441680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=687920.0
}
