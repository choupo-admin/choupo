/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methylbenzanthracene  (C19H14, CAS 2319-96-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methylbenzanthracene;
formula     C19H14;
CAS         2319-96-2;
InChIKey    NYTXDSVUTXAPTH-UHFFFAOYSA-N;
MW          242.321;      // g/mol [origin=calculated method=formula-sum]
Tc          991.09;      // K   [origin=predictive method=joback]
Pc          24.483;      // bar [origin=predictive method=joback]
omega       0.7035;      // -   [origin=predictive method=lee-kesler]
Tb          732.88;      // K   [origin=predictive method=joback]
HvapTb      67070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.72 1.54032 -0.00125004 4.09e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 6; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylbenzo[a]anthracene" "5-methylbenz(a)anthracene" "5-methylbenz[a]anthracene" "5-methyltetraphene" "benz(a)anthracene, 5-methyl-" "benz[a]anthracene, 5-methyl-" "methyl-1,2-benzanthracene" "benz[a]anthracene,5-methyl-" "5-monomethylbenz[a]anthracene" "5-methylbenz[a]anthracene;5-methylbenzo[a]anthracene; 5-monomethylbenz[a]anthracene" );
gibbsFormation
{
    dHf_298   339840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=512570.0
    phase     gas;
}
