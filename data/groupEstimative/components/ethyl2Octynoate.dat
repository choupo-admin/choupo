/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-octynoate  (C10H16O2, CAS 10519-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Octynoate;
formula     C10H16O2;
CAS         10519-20-7;
InChIKey    QPMDWYXUSMRVKT-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          686.33;      // K   [origin=predictive method=joback]
Pc          24.678;      // bar [origin=predictive method=joback]
omega       0.5537;      // -   [origin=predictive method=lee-kesler]
Tb          495.62;      // K   [origin=predictive method=joback]
HvapTb      47413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.765 0.74924 -0.00033346 2.968e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group tC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl oct-2-ynoate" "ethyl 2-octynate" "2-octynoic acid, ethyl ester" "2-octynoic acid ethyl ester" "ethyl heptynecarbonate" "ethyl heptine carbonate" "2-octynoic acid, ethylester" "qpmdwyxusmrvkt-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -294710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74250.0
    phase     gas;
}
