name        33Abieta81113Trien18YliminoBis1Phenylpropan1One;
formula     C38H47NO2;
CAS         70776-87-3;
InChIKey    KHOPCXLSEXHGOA-UHFFFAOYSA-N;
MW          549.799;      // g/mol [origin=calculated method=formula-sum]
Tc          1588.77;      // K   [origin=predictive method=joback]
Pc          8.630;      // bar [origin=predictive method=joback]
omega       0.8250;      // -   [origin=predictive method=lee-kesler]
Tb          1296.61;      // K   [origin=predictive method=joback]
HvapTb      121040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-307.195 4.17188 -0.00343872 1.19312e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 1; } { group C; count 2; } { group ACH; count 13; } { group AC; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2CO; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
