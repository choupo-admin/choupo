/*--------------------------------*- Choupo -*-----------------------*\
  Component: aethoxen  (C6H11NO, CAS 3691-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aethoxen;
formula     C6H11NO;
CAS         3691-16-5;
InChIKey    MJVIZWIQHKRBPI-UHFFFAOYSA-N;
MW          113.16;      // g/mol [origin=calculated method=formula-sum]
Tc          618.35;      // K   [origin=predictive method=joback]
Pc          43.511;      // bar [origin=predictive method=joback]
omega       0.8077;      // -   [origin=predictive method=lee-kesler]
Tb          444.88;      // K   [origin=predictive method=joback]
HvapTb      46664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.699 0.9046 -0.0007937 2.817e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(aziridin-1-yl)but-3-en-2-ol" "ethoxene" "tetramin" "alpha-vinyl ae" "tetramin (secondary isomer)" ".alpha.-vinyl ae" "1-ethylenimino-2-hydroxybutene" "2-(1-aziridinyl)-1-vinylethanol" "1-(2-hydroxybut-1-enyl)aziridine" "1-ethyleneimino-2-hydroxy-3-butene" "4-aziridinyl-3-hydroxy-1,2-butene" "aziridine, 1-(2-hydroxybut-1-enyl)-" );
standardThermochemistry
{
    dHf_298   -32420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139560.0
}
