/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-phenylbutyl)benzene  (C16H18, CAS 116783-21-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PhenylbutylBenzene;
formula     C16H18;
CAS         116783-21-2;
InChIKey    PDINXYLAVFUHSA-UHFFFAOYSA-N;
MW          210.32;      // g/mol [origin=calculated method=formula-sum]
Tc          853.67;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       0.5399;      // -   [origin=predictive method=lee-kesler]
Tb          618.60;      // K   [origin=predictive method=joback]
HvapTb      55374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.148 1.37192 -0.0009122 2.297e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 10; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylbutan-2-ylbenzene" "benzene, 1,1'-(1-methyl-1,3-propanediyl)bis-" "1,3-diphenylbutane" "butane, 1,3-diphenyl-, (+)" "butane, 1,3-diphenyl-, (-)" "butane, 1,3-diphenyl-" "1,1'-butane-1,3-diyldibenzene" "(1-methylpropane-1,3-diyl)dibenzene" "benzene, 1,1'-(1-methyl-1,3-propanediyl)bis-, (r)-" );
standardThermochemistry
{
    dHf_298   94210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=306220.0
}
