/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylhexane  (C12H18, CAS 1077-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylhexane;
formula     C12H18;
CAS         1077-16-3;
InChIKey    LTEQMZWBSYACLV-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          700.18;      // K   [origin=predictive method=joback]
Pc          24.053;      // bar [origin=predictive method=joback]
omega       0.4867;      // -   [origin=predictive method=lee-kesler]
Tb          500.84;      // K   [origin=predictive method=joback]
HvapTb      44582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.925 1.06492 -0.0006602 1.571e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexylbenzene" "benzene, hexyl-" "n-hexylbenzene" "hexane, 1-phenyl-" "hexane, 1-phenyl- (8ci)" );
standardThermochemistry
{
    dHf_298   -54480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162570.0
}
