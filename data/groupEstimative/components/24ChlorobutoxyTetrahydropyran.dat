/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-chlorobutoxy)tetrahydropyran  (C9H17ClO2, CAS 41302-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24ChlorobutoxyTetrahydropyran;
formula     C9H17ClO2;
CAS         41302-05-0;
InChIKey    SZZINZURZKQZLG-UHFFFAOYSA-N;
MW          192.683;      // g/mol [origin=calculated method=formula-sum]
Tc          714.97;      // K   [origin=predictive method=joback]
Pc          26.570;      // bar [origin=predictive method=joback]
omega       0.5391;      // -   [origin=predictive method=lee-kesler]
Tb          511.87;      // K   [origin=predictive method=joback]
HvapTb      47362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.186 0.9215 -0.0004423 5.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Cl; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chloranylbutoxy)oxane" "2h-pyran, 2-(4-chlorobutoxy)tetrahydro-" "2-(4-chlorobutoxy)tetrahydro-2h-pyran" "2-((4-chlorobutyl)oxy)tetrahydro-2h-pyran" "2-[(4-chlorobutyl)oxy]tetrahydro-2h-pyran" "4-chlorobutyl tetrahydropyranyl ether" "2-(4-chlorobutoxy)oxane" "1-(2h-3,4,5,6-tetrahydropyran-2-yloxy)-4-chlorobutane" "2-(4-chlorobutoxy)tetrahydro-2h-pyran; 4-chlorobutyl tetrahydro-2h-pyran-2-yl ether" );
standardThermochemistry
{
    dHf_298   -454730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-153700.0
}
