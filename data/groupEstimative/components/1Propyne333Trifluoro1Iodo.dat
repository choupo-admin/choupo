/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propyne, 3,3,3-trifluoro-1-iodo-  (C3F3I, CAS 39130-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propyne333Trifluoro1Iodo;
formula     C3F3I;
CAS         39130-85-3;
InChIKey    VMCRDCDQTZUCQZ-UHFFFAOYSA-N;
MW          219.927;      // g/mol [origin=calculated method=formula-sum]
Tc          578.90;      // K   [origin=predictive method=joback]
Pc          45.408;      // bar [origin=predictive method=joback]
omega       0.1961;      // -   [origin=predictive method=lee-kesler]
Tb          364.96;      // K   [origin=predictive method=joback]
HvapTb      30050.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.21 0.3392 -0.00034966 1.3208e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 1; } { group C_C; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group tC; count 2; } { group F; count 3; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3-tris(fluoranyl)-1-iodanyl-prop-1-yne" "3,3,3-trifluoro-1-iodoprop-1-yne" );
standardThermochemistry
{
    dHf_298   -353160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-346290.0
}
