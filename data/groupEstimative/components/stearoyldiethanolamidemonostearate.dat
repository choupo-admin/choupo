/*--------------------------------*- Choupo -*-----------------------*\
  Component: stearoyldiethanolamidemonostearate  (C40H79NO4, CAS 55349-70-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        stearoyldiethanolamidemonostearate;
formula     C40H79NO4;
CAS         55349-70-7;
InChIKey    ZRWKXALQNLDUSY-UHFFFAOYSA-N;
MW          638.075;      // g/mol [origin=calculated method=formula-sum]
Tc          2035.21;      // K   [origin=predictive method=joback]
Pc          4.165;      // bar [origin=predictive method=joback]
omega       -0.4763;      // -   [origin=predictive method=lee-kesler]
Tb          1331.51;      // K   [origin=predictive method=joback]
HvapTb      137509.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.104 3.87894 -0.0021819 4.4586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 33; } { group OH; count 1; } { group CH2COO; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 36; } { group OH; count 1; } { group CdO; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-hydroxyethyl(octadecanoyl)amino]ethyl octadecanoate" "2-[(2-hydroxyethyl)(stearoyl)amino]ethyl stearate" "2-((2-hydroxyethyl)(1-oxooctadecyl)amino)ethyl stearate" "2-[(2-hydroxyethyl)(1-oxooctadecyl)amino]ethyl stearate" "octadecanoic acid, 2-((2-hydroxyethyl)(1-oxooctadecyl)amino)ethyl ester" "octadecanoic acid, 2-[(2-hydroxyethyl)(1-oxooctadecyl)amino]ethyl ester" "octadecanoic acid,2-[(2-hydroxyethyl)(1-oxooctadecyl)amino]ethyl ester" );
gibbsFormation
{
    dHf_298   -1383490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1859.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-179410.0
    phase     gas;
}
