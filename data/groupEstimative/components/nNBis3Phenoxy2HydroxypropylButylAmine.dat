/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(3-phenoxy-2-hydroxypropyl)butyl amine  (C22H31NO4, CAS 23257-62-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis3Phenoxy2HydroxypropylButylAmine;
formula     C22H31NO4;
CAS         23257-62-7;
InChIKey    ZDRJSLHBNGHXNK-UHFFFAOYSA-N;
MW          373.493;      // g/mol [origin=calculated method=formula-sum]
Tc          1220.76;      // K   [origin=predictive method=joback]
Pc          15.949;      // bar [origin=predictive method=joback]
omega       1.3927;      // -   [origin=predictive method=lee-kesler]
Tb          997.08;      // K   [origin=predictive method=joback]
HvapTb      108563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.393 2.01332 -0.0011932 2.48e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 10; } { group AC; count 2; } { group CH2N; count 1; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 2; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[butyl-(2-oxidanyl-3-phenoxy-propyl)amino]-3-phenoxy-propan-2-ol" "2-propanol,1,1'-(butylimino)bis[3-phenoxy-" "1-[butyl-(2-hydroxy-3-phenoxypropyl)amino]-3-phenoxypropan-2-ol" );
standardThermochemistry
{
    dHf_298   -536280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     921.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18560.0
}
