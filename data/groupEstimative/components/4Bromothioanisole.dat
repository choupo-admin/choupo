/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromothioanisole  (C7H7BrS, CAS 104-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromothioanisole;
formula     C7H7BrS;
CAS         104-95-0;
InChIKey    YEUYZNNBXLMFCW-UHFFFAOYSA-N;
MW          203.097;      // g/mol [origin=calculated method=formula-sum]
Tc          784.40;      // K   [origin=predictive method=joback]
Pc          45.164;      // bar [origin=predictive method=joback]
omega       0.4309;      // -   [origin=predictive method=lee-kesler]
Tb          526.36;      // K   [origin=predictive method=joback]
HvapTb      47366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.71 0.56301 -0.00035236 7.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-methylsulfanyl-benzene" "1-bromo-4-(methylthio)benzene" "p-bromophenyl methyl sulfide" "p-bromo thioanisole" "benzene, 1-bromo-4-(methylthio)-" "4-bromophenyl methyl sulfide" "4-bromo-thioanisole" "bromothioanisole, 4-" "p-bromo(methylthio)benzene" "methyl 4-bromophenylsulfide" "1-bromo-4-(methylsulfanyl)benzene" "p-bromothioanisole" );
gibbsFormation
{
    dHf_298   105450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158280.0
    phase     gas;
}
