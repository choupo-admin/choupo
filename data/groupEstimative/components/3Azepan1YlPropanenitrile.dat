/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(azepan-1-yl)propanenitrile  (C9H16N2, CAS 937-51-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Azepan1YlPropanenitrile;
formula     C9H16N2;
CAS         937-51-9;
InChIKey    GDQLRKPUJAWNNP-UHFFFAOYSA-N;
MW          152.241;      // g/mol [origin=calculated method=formula-sum]
Tc          760.61;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.5704;      // -   [origin=predictive method=lee-kesler]
Tb          544.26;      // K   [origin=predictive method=joback]
HvapTb      48887.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.528 1.0661 -0.0006838 1.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 6; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(hexamethyleneimino)propionitrile" "3-perhydroazepin-1-ylpropiononitrile" "1h-azepine-1-propionitrile, hexahydro-" "3-hexamethyleneiminopropionitrile" "3-(hexahydro-1h-azepin-1-yl)propionitrile" "propionitrile, 3-(hexahydro-1h-azepin-1-yl)-" "3-azaperhydroepinylpropanenitrile" );
standardThermochemistry
{
    dHf_298   77980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=301020.0
}
