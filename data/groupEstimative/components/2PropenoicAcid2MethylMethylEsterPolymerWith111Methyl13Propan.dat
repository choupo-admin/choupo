/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, methyl ester, polymer with 1,1'-(1-methyl-1,3-propanediyl) di-2-propenoate  (C15H22O6, CAS 91112-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2MethylMethylEsterPolymerWith111Methyl13Propan;
formula     C15H22O6;
CAS         91112-46-8;
InChIKey    YQSXCZPNAHQGMH-WJXKTOMQSA-N;
MW          298.335;      // g/mol [origin=calculated method=formula-sum]
Tc          1114.33;      // K   [origin=predictive method=joback]
Pc          17.303;      // bar [origin=predictive method=joback]
omega       1.2817;      // -   [origin=predictive method=lee-kesler]
Tb          897.88;      // K   [origin=predictive method=joback]
HvapTb      89951.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.952 1.29526 -0.000624 6.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 2; } { group CH2=C; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 4; } { group dC; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-methylprop-2-enoate;(2e,7e)-4-methylnona-2,7-dienedioic acid" "2-propenoic acid, 2-methyl-, methyl ester, polymer with 1-methyl-1,3-propanediyl di-2-propenoate" );
gibbsFormation
{
    dHf_298   -1137570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     974.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-790240.0
    phase     gas;
}
