/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-oxabicyclo[3,2,2]nonane  (C8H14O, CAS 283-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Oxabicyclo322Nonane;
formula     C8H14O;
CAS         283-27-2;
InChIKey    SVSOGVQZYJCDKO-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          654.45;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.3194;      // -   [origin=predictive method=lee-kesler]
Tb          435.88;      // K   [origin=predictive method=joback]
HvapTb      38254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.91 1.0338 -0.0006987 1.842e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxabicyclo[3.2.2]nonane" "3-oxabicyclo(3,2,2)nonane" "3-oxabicyclo[3.2.2]nonane(6ci,8ci,9ci)" );
gibbsFormation
{
    dHf_298   -213330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     295.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15560.0
    phase     gas;
}
