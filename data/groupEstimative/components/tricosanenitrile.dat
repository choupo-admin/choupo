/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricosanenitrile  (C23H45N, CAS 95491-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricosanenitrile;
formula     C23H45N;
CAS         95491-05-7;
InChIKey    NCWVIUAXLUGLNC-UHFFFAOYSA-N;
MW          335.62;      // g/mol [origin=calculated method=formula-sum]
Tc          1014.20;      // K   [origin=predictive method=joback]
Pc          8.397;      // bar [origin=predictive method=joback]
omega       0.8030;      // -   [origin=predictive method=lee-kesler]
Tb          827.92;      // K   [origin=predictive method=joback]
HvapTb      77270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.019 2.12362 -0.0011964 2.562e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 20; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 21; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-00oagx" );
standardThermochemistry
{
    dHf_298   -353170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1058.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=275960.0
}
