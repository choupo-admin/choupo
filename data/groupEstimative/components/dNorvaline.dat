/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-norvaline  (C5H11NO2, CAS 2013-12-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dNorvaline;
formula     C5H11NO2;
CAS         2013-12-9;
InChIKey    SNDPXSYFESPGGJ-SCSAIBSYSA-N;
MW          117.148;      // g/mol [origin=calculated method=formula-sum]
Tc          738.12;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.7971;      // -   [origin=predictive method=lee-kesler]
Tb          531.60;      // K   [origin=predictive method=joback]
HvapTb      54141.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.752 0.59742 -0.0003674 8.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanylpentanoic acid" "d(-)-norvaline" "(2r)-2-aminopentanoic acid" "(r)-2-aminovaleric acid" "d-ape" "d-2-aminovaleric acid" "(r)-(-)-2-aminopentanoic acid" "h-d-nva-oh" "d-2-aminopentanoic acid" "(r)-norvaline" "d-nva" "h-d-norvaline" );
gibbsFormation
{
    dHf_298   -468290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-288680.0
    phase     gas;
}
