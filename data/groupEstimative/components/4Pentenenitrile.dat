/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentenenitrile  (C5H7N, CAS 592-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentenenitrile;
formula     C5H7N;
CAS         592-51-8;
InChIKey    CFEYBLWMNFZOPB-UHFFFAOYSA-N;
MW          81.118;      // g/mol [origin=calculated method=formula-sum]
Tc          607.68;      // K   [origin=predictive method=joback]
Pc          35.389;      // bar [origin=predictive method=joback]
omega       0.3938;      // -   [origin=predictive method=lee-kesler]
Tb          412.76;      // K   [origin=predictive method=joback]
HvapTb      36532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.352 0.3936 -0.0002401 5.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-4-enenitrile" "allylacetonitrile" "4-cyano-1-butene" "4-pentenonitrile" "allylmethyl cyanide" "3-butenyl cyanide" "1-cyano-3-butene" "4-pentenoic acid, nitrile" "cfeyblwmnfzopb-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   143780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212240.0
    phase     gas;
}
