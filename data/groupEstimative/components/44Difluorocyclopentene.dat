/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-difluorocyclopentene  (C5H6F2, CAS 77613-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Difluorocyclopentene;
formula     C5H6F2;
CAS         77613-68-4;
InChIKey    VHNNSNNVWSXSQQ-UHFFFAOYSA-N;
MW          104.099;      // g/mol [origin=calculated method=formula-sum]
Tc          510.76;      // K   [origin=predictive method=joback]
Pc          42.887;      // bar [origin=predictive method=joback]
omega       0.2315;      // -   [origin=predictive method=lee-kesler]
Tb          327.22;      // K   [origin=predictive method=joback]
HvapTb      24488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.17 0.87 -0.00092828 4.012e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-bis(fluoranyl)cyclopentene" );
gibbsFormation
{
    dHf_298   -405250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-337380.0
    phase     gas;
}
