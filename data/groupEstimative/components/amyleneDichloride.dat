/*--------------------------------*- Choupo -*-----------------------*\
  Component: amylene dichloride  (C5H10Cl2, CAS 507-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amyleneDichloride;
formula     C5H10Cl2;
CAS         507-45-9;
InChIKey    TXTORVZCRUFBBO-UHFFFAOYSA-N;
MW          141.035;      // g/mol [origin=calculated method=formula-sum]
Tc          583.70;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       0.2485;      // -   [origin=predictive method=lee-kesler]
Tb          385.19;      // K   [origin=predictive method=joback]
HvapTb      33810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.03 0.62416 -0.000464 1.377e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)-2-methyl-butane" "butane, 2,3-dichloro-2-methyl-" "2,3-dichloro-2-methylbutane" "butene, 2,3-dichloro-2-methyl-" );
standardThermochemistry
{
    dHf_298   -192040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32240.0
}
