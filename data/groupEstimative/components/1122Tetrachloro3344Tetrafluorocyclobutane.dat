/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2-tetrachloro-3,3,4,4-tetrafluorocyclobutane  (C4Cl4F4, CAS 336-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122Tetrachloro3344Tetrafluorocyclobutane;
formula     C4Cl4F4;
CAS         336-50-5;
InChIKey    ZWDCJLJWIQMWBE-UHFFFAOYSA-N;
MW          265.836;      // g/mol [origin=calculated method=formula-sum]
Tc          647.73;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.3472;      // -   [origin=predictive method=lee-kesler]
Tb          435.88;      // K   [origin=predictive method=joback]
HvapTb      33324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-162.33 1.6876 -0.002479 1.2716e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl2; count 2; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 4; } { group F; count 4; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetrakis(chloranyl)-3,3,4,4-tetrakis(fluoranyl)cyclobutane" "1,1,2,2-tetrachlorotetrafluorocyclobutane" "cyclobutane, 1,1,2,2-tetrachloro-3,3,4,4-tetrafluoro-" "1,1,4,4-tetrachloro-2,2,3,3-tetrafluorocyclobutane" "cyclobutane,1,2,2-tetrachloro-3,3,4,4-tetrafluoro-" "1,1,2,2-tetrachloro-3,3,4,4-tetrafluoro cyclobutane" "cyclobutane,1,1,2,2-tetrachloro-3,3,4,4-tetrafluoro-" );
standardThermochemistry
{
    dHf_298   -906710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     652.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-840600.0
}
