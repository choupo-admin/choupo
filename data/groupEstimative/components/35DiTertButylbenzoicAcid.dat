/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-di-tert-butylbenzoic acid  (C15H22O2, CAS 16225-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35DiTertButylbenzoicAcid;
formula     C15H22O2;
CAS         16225-26-6;
InChIKey    NCTSLPBQVXUAHR-UHFFFAOYSA-N;
MW          234.339;      // g/mol [origin=calculated method=formula-sum]
Tc          945.12;      // K   [origin=predictive method=joback]
Pc          20.109;      // bar [origin=predictive method=joback]
omega       0.7979;      // -   [origin=predictive method=lee-kesler]
Tb          718.49;      // K   [origin=predictive method=joback]
HvapTb      67156.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.4 1.53342 -0.00110552 3.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 3; } { group AC; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-ditert-butylbenzoic acid" "3,5-di-t-butylbenzoic acid" "3,5-bis(tert-butyl)benzoic acid" "benzoic acid, 3,5-bis(1,1-dimethylethyl)-" "nctslpbqvxuahr-uhfffaoysa-" "benzoicacid, 3,5-di-tert-butyl- (6ci,7ci,8ci);" );
gibbsFormation
{
    dHf_298   -507110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-169660.0
    phase     gas;
}
