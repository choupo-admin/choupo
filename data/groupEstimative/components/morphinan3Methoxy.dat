/*--------------------------------*- Choupo -*-----------------------*\
  Component: morphinan, 3-methoxy-  (C17H23NO, CAS 1531-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morphinan3Methoxy;
formula     C17H23NO;
CAS         1531-25-5;
InChIKey    ILNSWVUXAPSPEH-USXIJHARSA-N;
MW          257.377;      // g/mol [origin=calculated method=formula-sum]
Tc          976.59;      // K   [origin=predictive method=joback]
Pc          23.657;      // bar [origin=predictive method=joback]
omega       0.7141;      // -   [origin=predictive method=lee-kesler]
Tb          725.17;      // K   [origin=predictive method=joback]
HvapTb      65136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-186.41 2.06972 -0.00172692 6.152e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -53710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=320680.0
    phase     gas;
}
