/*---------------------------------------------------------------------------*\
  FERMENTATION/Mixer / system/flowsheetDict   (LEAF -- inlet header)

  Adds the fresh Must to the recycled bottoms.  Trivial sum-of-streams;
  pedagogically present so the recycle loop has a stable place to
  re-enter the sector.
\*---------------------------------------------------------------------------*/

type        mixer;

boundary    { inlets ( Must  Recycle );  outlets ( Mixed ); }
