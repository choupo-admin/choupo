/*--------------------------------*- Choupo -*-----------------------*\
  PSEUDO-COMPONENT: kerosene_C12cut   (an SX diluent cut -- NOT a real species)

  The solvent-extraction DILUENT: a narrow kerosene cut centred on C12,
  lumped into ONE characterisation point (the flash_pseudoComponent_petCut
  pattern -- see that tutorial and its generating sibling,
  props/estimate/estimate_petroleum_cut).  An ordinary component .dat
  resolved by exact name, carrying ONLY the fields a lump can honestly own:

    identity { MW }         -- lump-average molar mass (NO formula / CAS)
    critical { Tc Pc omega }-- corresponding-states constants of the cut
    idealGasHeatCapacity{}  -- ideal-gas Cp (NO Hf: a lump has no reaction)
    liquidPure{ Tb Vliq Cp Psat } -- enough to run and close energy.

  Numbers are Riazi-Daubert (1987) style estimates anchored on a C12
  kerosene cut (Tb = 489 K, SG = 0.75); the nearest real species is
  n-dodecane (Tc 658.0 K, omega 0.576 -- the anchors below sit on it, the
  honest thing for a narrow cut).  PROVENANCE SCREAMS what it is: status
  ESTIMATE, origin estimated, lumped true.
\*---------------------------------------------------------------------------*/

name        kerosene_C12cut;
// formula / CAS OMITTED -- a pseudo-component is a LUMP, not a molecule.
MW          170.3;            // g/mol  lump-average (~C12H26)


// ---- critical corresponding-states constants of the lumped cut ----
Tc      658.0;                // K     (n-dodecane anchor for the narrow cut)
Pc      18.2;                 // bar
omega   0.576;                // [-]


// ---- ideal-gas Cp ONLY -- NO formation datum (a lump has no reaction) ----
idealGasHeatCapacity
{
    model         polynomial;
    // Cp_ig [J/(mol K)] ~ paraffinic C12 (Kesler-Lee style estimate)
    coefficients  (14.0   1.05   -4.0e-04   0.0);
    Trange        (250  1000);
}


// ---- pure-liquid (Raoult) reference -- Psat IS f(T) ----
Tb         489.0;             // K      cut normal boiling point (assay anchor)
Vliq       2.27e-4;           // m^3/mol  (~rho 750 kg/m^3 at 298 K)
liquidHeatCapacity
{
    model         polynomial;
    // Cp_liq ~ 375 J/(mol K) at 298 K, paraffinic slope (estimate)
    coefficients  (150.0   0.75   0.0   0.0);
    Trange        (250  480);
}
// Ambrose-Walton corresponding states from critical{} -- runnable with
// no measured Antoine data.
vaporPressure { model AmbroseWalton; }


provenance
{
    status        "ESTIMATE";
    origin        estimated;
    lumped        true;
    method        "Riazi-Daubert-style cut characterisation from (Tb=489 K, SG=0.75); anchors checked against n-dodecane; Cp estimates; Psat Ambrose-Walton; Vliq from cut density";
    note          "SX diluent pseudo-component, NOT a real species -- a narrow kerosene cut lumped to one point (the petCut_C7plus pattern)";
}
