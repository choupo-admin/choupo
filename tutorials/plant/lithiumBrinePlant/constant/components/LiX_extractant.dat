/*--------------------------------*- Choupo -*-----------------------*\
  PSEUDO-COMPONENT: LiX_extractant   (a chelation lump -- NOT a real species)

  The lithium-selective EXTRACTANT, lumped: a heavy organophosphorus /
  beta-diketone-class chelator (the LiX of the SX literature) whose whole
  job in this sector is to hold the tuned LiCl-organic affinity (the
  LiCl-LiX_extractant NRTL pair).  The chelation chemistry itself
  (Li+ + HX_org <-> LiX_org + H+) is NOT modelled -- that is the
  phaseEquilibrium{} upgrade; until then this lump + its tuned pair ARE
  the measured K_D's container, and this file says so out loud.

  Field discipline follows the petCut_C7plus pseudo-component pattern:
  flat MW/Tc/Pc/omega + idealGasHeatCapacity{} + Tb/Vliq -- only what a
  lump can honestly own, no formation datum.  The critical constants are
  JOBACK-STYLE ESTIMATES for a ~C18 chelator skeleton (never measured for
  the commercial mixtures); the molecule is essentially NONVOLATILE at
  process T (Tb estimate 640 K) -- it stays in the organic, as it must.
\*---------------------------------------------------------------------------*/

name        LiX_extractant;
// formula / CAS OMITTED -- a commercial-extractant LUMP, not a molecule.
MW          322.0;            // g/mol  (~C18 organophosphorus chelator class)


// ---- critical JOBACK-STYLE estimates (group contribution on the class skeleton) ----
Tc      840.0;                // K     estimated (Joback-style)
Pc      12.0;                 // bar   estimated
omega   0.92;                 // [-]   Lee-Kesler from (Tb,Tc,Pc) estimates


// ---- ideal-gas Cp ONLY -- NO formation datum (a lump has no reaction) ----
idealGasHeatCapacity
{
    model         polynomial;
    // Cp_ig [J/(mol K)] estimated, heavy-organic slope
    coefficients  (30.0   1.60   -6.0e-04   0.0);
    Trange        (250  1000);
}


// ---- liquidPure pure-liquid (Raoult) reference ----
Tb         640.0;             // K      estimated -- effectively nonvolatile here
Vliq       3.6e-4;            // m^3/mol  (~rho 900 kg/m^3 at 298 K)
liquidHeatCapacity
{
    model         polynomial;
    // Cp_liq ~ 600 J/(mol K) at 298 K (heavy-organic estimate)
    coefficients  (300.0   1.0   0.0   0.0);
    Trange        (250  550);
}
vaporPressure { model AmbroseWalton; }     // from the estimated critical{}


provenance
{
    status        "ESTIMATE";
    origin        estimated;
    lumped        true;
    method        "Joback-style group estimates on a ~C18 organophosphorus chelator skeleton; omega Lee-Kesler; Cp estimates; Psat Ambrose-Walton; Vliq from class density";
    note          "lithium-selective extractant LUMP -- the chelation equilibrium is carried by the TUNED LiCl-LiX_extractant NRTL pair, not by reaction chemistry; upgraded when phaseEquilibrium{} lands";
}
