/*--------------------------------*- Choupo -*-----------------------*\
  Component: Lithium chloride (LiCl, CAS 7447-41-8)  --  CASE-LOCAL (Route 2)

  THE STUDENT'S ROUTE, exercised for real: LiCl is NOT yet in the curated
  data/standards/components/ catalogue, so this case defines it locally and
  runs self-contained from day one.  Promotion into the standards tree is a
  REQUESTED, reviewed curation act after validation -- until then this file
  is the component, versioned inside the case.

  A non-volatile, fully-dissociating 1-1 salt (Li+ + Cl-), extremely soluble
  (~19.9 mol/kg at 25 C -- the most soluble common chloride; that is WHY the
  salar route works: Li stays in the mother liquor while NaCl and KCl
  crystallise out).  The Li+ ion lives in the standard species tree
  (data/standards/.../Li.dat) with its aqueous formation tier; the Li-Cl
  Pitzer pair is already curated (parameters/electrolyte/pitzer/pairs/).

  Sources: MW from atomic weights (IUPAC); solid rho_p 2068 kg/m^3
  (crystallographic, public domain); solubility 19.9 mol/kg (25 C) --
  primary re-citation pending (candidate: Linke & Seidell, Solubilities,
  4th ed.); liquid-Cp an ASSERTED energy-closure proxy (see the block).
\*---------------------------------------------------------------------------*/

name           LiCl;
formula        LiCl;
CAS            7447-41-8;

MW             42.394;         // g/mol
nonvolatile    true;
dissociatesTo  { Li 1; Cl 1; } // ion stoichiometry (formula-like identity; the package activates it)

// FORMATION DATUM lives PER ION (Li+, Cl-; H+(aq)=0 convention) in the
// standard species tree -- no component-level standardThermochemistry block (arity-1).

solid
{
    rho_p   2068.0;     // crystalline LiCl density [kg/m^3]
    k_v     1.0;        // volume shape factor (cube)
}

// Liquid heat capacity -- an ASSERTED hammer, NOT a physical liquid-LiCl Cp:
// ~50 J/(mol.K) is the solid-lattice Dulong-Petit value (6R) REUSED as a
// temporary energy-closure proxy.  The salt is minor and nonvolatile (water
// dominates the mixture Cp), so this only lets the balance close; it is not a
// liquid-salt Cp theory.  Replace when a real salt-solution energy model lands.
liquidHeatCapacity
{
    model         polynomial;
    coefficients  (50.0);      // J/(mol.K), constant
    Trange        (270  400);
    origin        asserted;
    why           "temporary energy-closure proxy; solid-lattice Dulong-Petit 6R value reused; not a physical liquid-LiCl Cp model";
}
