/*--------------------------------*- Choupo -*------------------------------*\
  esterification2sector  --  a TWO-SECTOR fractal plant, WIRED.

      Feed (AcOH + EtOH)
            |
        [ REACTION ]  --- esterification CSTR, its OWN kinetics in
            |               sectors/REACTION/constant/reactions
        reactorOut
            |
        [ SEPARATION ] --- isothermal flash; the ethylAcetate-water NRTL pair
            |  \            is PARTICULAR to this sector
         liquid vapor      (sectors/SEPARATION/constant/binaryPairs/NRTL/...);
                            ethanol-water is INHERITED from the standard library.

  The point of the case is the FRACTAL `constant/`: components shared across the
  plant, particular data (kinetics here, a fitted pair there) living with the
  sector that owns it, and the rest walked up to the standard catalogue.

  The root graph assembles the sectors and the inter-sector links, nothing more.
  Each stream's state lives in its own file under 0/, owned by the sector that
  produces it.
\*---------------------------------------------------------------------------*/

sectors
(
    REACTION
    SEPARATION
);

connections
{
    Feed        { to REACTION/Feed; }

    reactorOut  { from REACTION/reactorOut;
                  to   SEPARATION/reactorOut; }

    vapor      { from SEPARATION/vapor; }

    liquid      { from SEPARATION/liquid; }
}
