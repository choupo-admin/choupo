/*---------------------------------------------------------------------------*\
  chemicalPlantTutorial / system/controlDict   (PLANT level)

  The controlDict CASCADES down the folder tree: a sector or unit inherits
  this one and overrides only what it changes (same overlay rule as the
  data).  So this is the only controlDict the plant strictly needs.
\*---------------------------------------------------------------------------*/

application   choupoSolve;        // the recursive plant solver will live here
description   "Sugar plant -- fractal multi-sector proxy: a JuiceSplitter feeding three sectors (CONCENTRATION + DRYING + FERMENTATION)";

verbosity     3;

// Reports run over the FLATTENED plant (all units across all sectors), so the
// stream table, mass balance and energy balance close over the whole factory
// at once -- per-unit too, with the namespaced equipment (concentration.evap1,
// drying.SD, ...).
reports { streamTable {}  massBalance {}  energyBalance {}  utilities {}  spreadsheet {} }

// ---- Solution directory (OpenFOAM-style per-iteration stream snapshots) -----
//  PILOT of the solution-directory discipline.  Each retained recycle OUTER
//  iteration ("pseudo-time") is written as one plain Choupo dict under
//  solution/<it>/streams (gitignored, run output).  `ls solution/` is the
//  convergence history at a glance; every instant reads back through the
//  engine's own dict tokenizer.  Each instant is published via an atomic
//  rename, so a restart never reads a half write; with `flushEach true` the
//  data + directory are fsync'd, so an instant also survives a power loss.
//
//  ABSENT this whole block => the feature is OFF and the run is byte-identical
//  to before.  This is the ONLY case that opts in.
solutionControl
{
    write           true;          // MASTER opt-in.  Absent / false => zero change.
    writeInterval   5;             // write every N recycle outer iterations (+ 0 and final)
    purgeWrite      3;             // keep last N numbered instants (+ 0/ and converged)
    startFrom       startTime;     // startTime (fresh) | latestTime (restart from solution/latest)
    flushEach       true;          // true: fsync data+dir => power-loss durable.
                                   //   false: skip fsync (faster, abort-safe only).
}
