/*---------------------------------------------------------------------------*\
  batch10_adsorber_co2_n2 / constant/propertyDict

  CO2 + N2 gas mixture over a solid adsorbent, isothermal: ideal-gas
  headspace (the announced A2 assumption), no liquid phase -- ideal
  activity + ideal-gas EOS carries the whole lesson.  The competitive
  adsorption equilibrium is PAIR data, vendored under
  constant/parameters/adsorption/equilibria/zeolite13X/ (case-local copy).
\*---------------------------------------------------------------------------*/

components       ( CO2  N2 );

activityModel    { model  ideal; }
equationOfState  { model  idealGas; }
