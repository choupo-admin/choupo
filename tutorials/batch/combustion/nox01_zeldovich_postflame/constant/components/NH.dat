    // poly3 is a 250-1500/3000 K process fit).
    model    NASA7;
    low      ( 3.49290850e+00 3.11791980e-04 -1.48904840e-06 2.48164420e-09 -1.03569670e-12 4.18806290e+04 1.84832780e+00 );
    high     ( 2.78369280e+00 1.32984300e-03 -4.24780470e-07 7.83485010e-11 -5.50444700e-15 4.21208480e+04 5.74077990e+00 );
    Tlow     200.0;
    Tcommon  1000.0;
    Thigh    3500.0;
}
