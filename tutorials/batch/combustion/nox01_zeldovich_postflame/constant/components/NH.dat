MW             15.0146;       // kg/kmol
role        nonvolatile;
tags           ( radical gasPhase combustion );

standardThermochemistry
{
    dHf_298    356916.2396;            // J/mol  -- ideal-gas reference
    s_298      181.2234;           // J/(mol·K)  -- third-law absolute
}

idealGasHeatCapacity
