}

// ── Initiation (slow; high barrier) ────────────────────────────────────────
init_H2_O2                       // H2 + O2 -> HO2 + H
{
    limitingReactant  H2;
    stoichiometry
    (
        { component H2;   nu -1;  order 1; }
        { component O2;   nu -1;  order 1; }
        { component HO2;  nu  1;  order 0; }
        { component H;    nu  1;  order 0; }
    );
    kinetics { type Arrhenius;  A 1.0e8;   Ea 2.0e5; }   // SI (m³/kmol/s, J/mol)
}

// ── Chain branching: one radical in, two out (the engine of ignition) ──────
branch_H_O2                      // H + O2 <-> O + OH    (declared in CHEMKIN units)
{
    reversible        true;
    limitingReactant  H;
    stoichiometry
    (
        { component H;   nu -1;  order 1; }
        { component O2;  nu -1;  order 1; }
        { component O;   nu  1;  order 0; }
        { component OH;  nu  1;  order 0; }
    );
    kinetics
    {
        type modifiedArrhenius;
        A    1.5e12;  b 0.0;  Ea 16730;
        units { A "cm3/mol/s"; Ea "cal/mol"; }   // -> SI on load (announced)
    }
}

branch_O_H2                      // O + H2 <-> H + OH    (declared in CHEMKIN units)
{
    reversible        true;
    limitingReactant  O;
    stoichiometry
    (
        { component O;   nu -1;  order 1; }
        { component H2;  nu -1;  order 1; }
        { component H;   nu  1;  order 0; }
        { component OH;  nu  1;  order 0; }
    );
    kinetics
    {
        type modifiedArrhenius;
        A    5.0e11;  b 0.0;  Ea 9560;
        units { A "cm3/mol/s"; Ea "cal/mol"; }
    }
}

// ── Propagation ────────────────────────────────────────────────────────────
prop_OH_H2                       // OH + H2 <-> H + H2O
{
    reversible        true;
    limitingReactant  OH;
    stoichiometry
    (
        { component OH;     nu -1;  order 1; }
        { component H2;     nu -1;  order 1; }
        { component H;      nu  1;  order 0; }
        { component water;  nu  1;  order 0; }
    );
    kinetics { type modifiedArrhenius; A 1.0e11; b 0.0; Ea 2.0e4; }   // SI
}

branch_O_H2O                     // O + H2O <-> OH + OH
{
    reversible        true;
    limitingReactant  O;
    stoichiometry
    (
        { component O;      nu -1;  order 1; }
        { component water;  nu -1;  order 1; }
        { component OH;     nu  2;  order 0; }
    );
    kinetics { type modifiedArrhenius; A 3.0e10; b 0.0; Ea 7.0e4; }   // SI
}

// ── Third-body recombination / termination (drains the radical pool) ───────
recomb_H_O2_M                    // H + O2 + M -> HO2 + M
{
    limitingReactant  H;
    stoichiometry
    (
        { component H;    nu -1;  order 1; }
        { component O2;   nu -1;  order 1; }
        { component HO2;  nu  1;  order 0; }
    );
    kinetics
    {
        type thirdBody;          // k·[M], [M] = Σ eff_j·c_j
        A 5.0e6;  b 0.0;  Ea 0.0;
        thirdBody { water 12.0; H2 2.5; N2 1.0; }   // unlisted => 1.0
    }
}

ho2_H_branch                     // HO2 + H -> OH + OH
{
    limitingReactant  HO2;
    stoichiometry
    (
        { component HO2;  nu -1;  order 1; }
        { component H;    nu -1;  order 1; }
        { component OH;   nu  2;  order 0; }
    );
    kinetics { type Arrhenius; A 1.0e11; Ea 5.0e3; }   // SI
}

ho2_H_recombine                  // HO2 + H -> H2 + O2
{
    limitingReactant  HO2;
    stoichiometry
    (
        { component HO2;  nu -1;  order 1; }
        { component H;    nu -1;  order 1; }
        { component H2;   nu  1;  order 0; }
        { component O2;   nu  1;  order 0; }
    );
    kinetics { type Arrhenius; A 5.0e10; Ea 5.0e3; }   // SI
}

recomb_H_OH_M                    // H + OH + M -> H2O + M  (chain termination)
{
    limitingReactant  H;
    stoichiometry
    (
        { component H;      nu -1;  order 1; }
        { component OH;     nu -1;  order 1; }
        { component water;  nu  1;  order 0; }
    );
    kinetics
    {
        type thirdBody;
        A 5.0e6;  b 0.0;  Ea 0.0;
        thirdBody { water 12.0; H2 2.5; N2 1.0; }
    }
}
