    // -- psi_ijk : triplet (two like-sign a,b + one opposite c) --
    { kind psi; a CO3; b Cl; c K; psi 0.004; source "Harvie, Moller & Weare, Geochim. Cosmochim. Acta 48 (1984) 723 (HMW seawater system); via USGS PHREEQC pitzer.dat (public domain)"; }
    { kind psi; a CO3; b Cl; c Na; psi 0.0085; source "Harvie, Moller & Weare, Geochim. Cosmochim. Acta 48 (1984) 723 (HMW seawater system); via USGS PHREEQC pitzer.dat (public domain)"; }
