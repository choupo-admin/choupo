    // -- zeta_n,c,a : neutral-cation-anion triplet --
    { kind zeta; n CO2aq; c Na; a SO4; zeta -0.015; source "CO2-brine lambda set: Pitzer, Peiper & Busey (1984) + He & Morse (1993) as attributed in the pitzer.dat -LAMBDA listing; via USGS PHREEQC pitzer.dat (public domain)"; }
