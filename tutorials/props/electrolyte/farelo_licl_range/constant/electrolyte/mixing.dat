    // -- lambda_n,ion : neutral-ion interaction (CO2 salting-out) --
    { kind lambda; n CO2aq; ion Ca; lambda 0.183; source "CO2-brine lambda set: Pitzer, Peiper & Busey (1984) + He & Morse (1993) as attributed in the pitzer.dat -LAMBDA listing; via USGS PHREEQC pitzer.dat (public domain)"; }
    { kind lambda; n CO2aq; ion Cl; lambda -0.005; source "CO2-brine lambda set: Pitzer, Peiper & Busey (1984) + He & Morse (1993) as attributed in the pitzer.dat -LAMBDA listing; via USGS PHREEQC pitzer.dat (public domain)"; }
