    // ---- ORGANIC EXTENSION: tartaric-acid dissociation (hand-curated, NOT from
    // the PHREEQC inorganic import). MASTER = neutral H2Tart, so an acid solution
    // is electroneutral at 0% imbalance (the H+ comes from dissociation, not an
    // unbalanced cation). pKa1 2.98, pKa2 4.34 (lit., 25 C); dH from the SAME
    // Kochergina 2006 formation enthalpies as ions.dat hfAq.
    { species HTart; ion "HC4H4O6-"; z -1; masters ( { ion H2Tart; nu 1; } { ion H; nu -1; } );
      logK25 -2.98; dH 3800; source "pKa1=2.98 (lit. 25 C); dH=hf(HTart)+hf(H)-hf(H2Tart) [Kochergina 2006]"; }
