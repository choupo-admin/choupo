components       ( N2  CH4  CO2 );

activityModel    { model  ideal; }

equationOfState
{
    model       SRK;

    binaryInteractions
    (
        // Sandler 4th ed., Table 7.4-1 (and refit on natural-gas mixtures).
        { i  N2;    j  CH4;   kij  0.0289; }
        { i  CO2;   j  CH4;   kij  0.0919; }
        { i  N2;    j  CO2;   kij -0.017;  }
    );
}
