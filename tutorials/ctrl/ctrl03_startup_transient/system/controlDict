application   choupoCtrl;
description   "Open-loop CSTR START-UP transient with OpenFOAM-style real-time instant dirs: charged cold (320 K), no control, watch T(t) and the holdup approach the natural steady state by scrubbing 0/ 50/ 100/ ... s";

verbosity     3;

// ---- Time integration ----
startTime       0;        // s
endTime         1000;     // s
deltaT          1.0;      // s
writeInterval   50;       // s   (one time directory every 50 s -> 0/ 50/ ... 1000/)

// ---- solutionControl: OpenFOAM-style transient solution directories ----
//   The instant directory IS the real physical time (seconds).  At each
//   written time a `<t>/internalState` holds the reactor HOLDUP (mole
//   inventory n_i [kmol], T [K]) and a `<t>/streamFaces` holds the instantaneous
//   OUTLET face (F [kmol/s], T, P, molarFlows).  Open `500/internalState` to
//   see the tank exactly as it was at t = 500 s, on its way to steady state.
//   trajectory.csv is STILL written; remove this block for a byte-identical
//   plain run.
solutionControl
{
    write           true;
    flushEach       true;
}
