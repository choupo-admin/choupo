/*---------------------------------------------------------------------------*\
  ctrl03_startup_transient / constant/thermoPackage

  Two abstract species: compA (the cold pure charge at 320 K; its mild
  first-order exotherm warms the vessel during the open-loop start-up) and
  compB (the product it becomes).  Ideal + idealGas: this case teaches the
  OpenFOAM-style transient solution directories — scrubbing T(t) to the
  natural steady state — not thermodynamics; the models only feed sensible
  heat and density into the holdup energy balance.
\*---------------------------------------------------------------------------*/

components       ( compA  compB );

activityModel    { model  ideal; }
equationOfState  { model  idealGas; }
