/*---------------------------------------------------------------------------*\
  sprayDryer01_sugar  --  thermo package.

  Three components:
      water    -- the volatile solvent (evaporates into the air)
      N2       -- the drying-air carrier gas
      sucrose  -- the non-volatile solid (leaves as powder; never enters
                  the vapour, so it carries no Antoine block)

  The transport block supplies all three families the drying kinetics
  need, each computed from the per-component .dat data (no new data):

      model               Chung;          // gas viscosity  (mu)
      thermalConductivity { model Eucken; }   // gas k  (Cp + mu)
      diffusivity         { model Fuller; }   // binary gas D (Sigma v)

  The water-in-N2 diffusivity (Fuller) drives the mass-transfer Sherwood
  number; component order makes water (0) the diffusing species and N2
  (1) the carrier.  sucrose stays out of the gas (y = 0) so its missing
  critical data are never touched by the mixing rules.
\*---------------------------------------------------------------------------*/

components       ( water  N2  sucrose );

activityModel    { model ideal; }
equationOfState  { model idealGas; }

transport
{
    model               Chung;
    thermalConductivity { model Eucken; }
    diffusivity         { model Fuller; }
}
