/*---------------------------------------------------------------------------*\
  thermoPackage  --  proxy01_gas_loop

  Water-gas-shift quartet, gas phase, ideal.  All four carry standardThermochemistry
  + idealGasHeatCapacity, so the gas-aware Mixer (formation datum) and the
  Gibbs reactor both have what they need.
\*---------------------------------------------------------------------------*/

components       ( CO  water  CO2  H2 );

activityModel    { model  ideal;    }
equationOfState  { model  idealGas; }
