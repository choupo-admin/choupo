/*---------------------------------------------------------------------------*\
  process03_recycle  --  the classic Reactor-Separator-Recycle architecture

         freshFeed ──┐                                       ┌──► vapProd (product)
                     │                                       │
                  [mixer] ──► [reactor] ──► [separator]──────┤
                     ▲                          (flash)      │
                     │                                       └──► liqProd
                     │                                                │
                     │            [splitter]                          │
                     └────── recycle ◄─ ┤                             │
                                        └─────────► purge             │
                                                                      │
                                          (the splitter is fed by liqProd)

  Tear stream: `recycle` — declared explicitly; the Flowsheet runs
  NEWTON on the tear variables (F, z..., T) until the post-pass value
  matches the input guess to a tolerance.  (`recycleSolver Wegstein;`
  selects the fixed-point accelerator instead — try both and compare
  the iteration counts.)

  The CSTR converts ~25% per pass (small volume); without recycle most
  ethanol would simply leave in liqProd.  With ~80% recycle, the overall
  ethanol conversion approaches 100% at steady state.
\*---------------------------------------------------------------------------*/

// stream state lives on disk in 0/ (per-stream files); flowsheetDict is TOPOLOGY only

tearStreams           ( recycle );
recycleSolver          Newton;        // Newton on the tear variables (default);
                                      //   `Wegstein` for the fixed-point accelerator
recycleTol             1e-5;
recycleMaxIter         120;
// Recycle problems with flash regime switching are best solved with
// gentle / no acceleration.  Start with direct substitution (q ≡ 0)
// and add Wegstein later if convergence is too slow.
recycleWegsteinQmin    0.0;
recycleWegsteinQmax    0.0;

units
(
    {
        name        mixer01;
        type        mixer;
        inputs      ( freshFeed  recycle );
        outputs     ( mixed );
    }

    {
        name        reactor;
        type        cstr;
        in          mixed;
        outputs     ( reactorOut );

        operation   { V_R 0.020; }        // kτ ≈ 4.4, ~80% per pass
        reaction    esterification_etac;
    }

    {
        name        separator;
        type        isothermalFlash;
        in          reactorOut;
        outputs     ( liqOut  vapProd );

        operation   { T 360.0 K;  P 1.0 bar; }    // hot enough to vaporise some of this water-rich mix
    }

    {
        name        split01;
        type        splitter;
        in          liqOut;
        outputs     ( recycle  liqProd );    // recycle FEEDS BACK into mixer

        operation   { fractions ( 0.6  0.4 ); }    // 60% recycled, 40% to product
    }
);
