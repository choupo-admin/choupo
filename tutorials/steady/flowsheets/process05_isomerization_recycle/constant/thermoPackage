/*---------------------------------------------------------------------------*\
  Two C5H12 isomers, ideal solution (Raoult --- close-boiling alkanes
  mix near-ideally).  neoPentane is the volatile reactant; nPentane is
  the less-volatile product.
\*---------------------------------------------------------------------------*/

components       ( neoPentane  nPentane );

activityModel    { model  ideal; }

equationOfState  { model  idealGas; }
