/* Case-local OVERLAY -- the ROLE SWITCH only.  N2 is a supercritical SOLUTE
   in liquid NH3.  THE PHYSICS ("o sumo") lives in the PAIR catalogue:
       data/standards/parameters/Henry/N2-NH3.dat
       H_ref 8.5e8 Pa (298 K) . dH_diss +11.0 kJ/mol . v_inf 23 cm3/mol (KK)
       fitted to Larson & Black 1925 as evaluated in IUPAC SDS Vol 5/6; the
       run log announces it as [henry].  All other fields merge from the
       standard N2.dat -- this file is deliberately a delta. */
name  N2;
role  solute;
