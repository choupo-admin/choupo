            0.000000000000000E+000
            0.545316868188471
            1.27928667476266
            4.67360104497315
            0.214475412075706
            4.87691776134562
            2.34606223865439
            2.67976962463690
            8.79133144284190
            1.96539893252119
            0.000000000000000E+000
