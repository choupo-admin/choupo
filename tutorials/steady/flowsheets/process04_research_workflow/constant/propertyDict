/*---------------------------------------------------------------------------*\
  thermoPackage  --  NRTL ethanol/water; parameters loaded from file

  Note that there is NO inline `pairs ( ... )` block here.  The simulator
  will resolve the ethanol-water NRTL pair by looking, in this order:

      1. inline `pairs ( ... )` in this dict           --  not present
      2. <case>/constant/parameters/NRTL/ethanol-water.dat  --  PRESENT
      3. $CHOUPO_HOME/data/standards/parameters/NRTL/ethanol-water.dat

The case-local file wins. Open it to see the parameters this case uses.
\*---------------------------------------------------------------------------*/

components       ( ethanol  water );

activityModel
{
    model        NRTL;
}

equationOfState
{
    model        idealGas;
}
