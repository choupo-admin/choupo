/*---------------------------------------------------------------------------*\
  thermoPhysPropDict (v2) -- T2 gamma-phi, UNIQUAC liquid.

  The activity model is NOT a free choice here.  A rate constant is meaningless
  without the activity model it was regressed with: Popken, Gotze & Gmehling
  fitted their kinetics on UNIQUAC activities, with the binary parameters they
  themselves regressed against DDB vapour-liquid, gamma-infinity and heat-of-
  mixing data.  Those exact parameters (Delta u = a + b T + c T^2) live in the
  standard catalogue under parameters/UNIQUAC/, cited to Table 3 of the paper,
  and the r/q in each component's `uniquac {}` block come from its Table 2.

  Swap this for UNIFAC and the numbers below stop being the authors' numbers.
\*---------------------------------------------------------------------------*/

recordType    thermophysicalPropertySystem;
schemaVersion 2;

components ( methanol  aceticAcid  methylAcetate  water );

equilibrium
{
    formulation gammaPhi;

    liquid
    {
        activityModel { model UNIQUAC; }  // pairs from parameters/UNIQUAC/ (Popken Table 3)
        standardState pureLiquid;         // Raoult datum: gamma_i -> 1 as x_i -> 1
    }

    vapour
    {
        fugacityModel idealGas;
    }
}
