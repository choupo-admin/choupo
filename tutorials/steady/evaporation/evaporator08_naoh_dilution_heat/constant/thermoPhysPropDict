/*---------------------------------------------------------------------------*\
  thermoPhysPropDict (v2) -- T7 electrolyteGammaPhi: aqueous electrolyte
  (Pitzer) x ideal vapour; the REAL solid equilibrium rides in the inline
  chemistry{} block (TRANSITIONAL: the chemistryDict grammar is not ratified).
  Rigorous NaOH Pitzer package (calorimetrically fitted Na-OH pair -> heat-of-dilution L_phi).
  Pitzer pair resolved by cation-anion name: data/standards/parameters/Pitzer/pairs/Na-OH.dat
\*---------------------------------------------------------------------------*/

recordType    thermophysicalPropertySystem;
schemaVersion 2;

components ( water NaOH );

equilibrium
{
    formulation electrolyteGammaPhi;    // aqueous electrolyte x ideal vapour

    aqueous
    {
        solvent            water;
        apparentComponents ( NaOH );  // stream carries the salt; the model
                                        //   activates its ions (dissociatesTo)
        activityModel
        {
            model Pitzer;
        }
        compositionBasis molality;
    }

    vapour
    {
        fugacityModel idealGas;
    }
}

chemistry
{
    salts ( sodiumHydroxide );                  // the active solid equilibrium: SLE via
}                                      //   the component's solidPhases{} Ksp

caloric
{
    energyBasis elementsDatum;          // ONE datum: the elements at 298.15 K

    aqueous
    {
        enthalpyRoute ionicReferencePlusExcess;   // aqueous inf-dilution ion
    }                                             //   datum + L_phi excess
    vapour
    {
        enthalpyRoute idealGasCp;
    }
}
