/*---------------------------------------------------------------------------*\
  fitBinaryPair -- regress NRTL a_ij/b_ij/a_ji/b_ji of the ethanol-water
  binary pair against experimental Tbub-vs-x data at 1 atm.
\*---------------------------------------------------------------------------*/

type      fitBinaryPair;

pair      ethanol-water;
data      constant/experiments/ethanol-water-101kPa;
unit      bt01;

