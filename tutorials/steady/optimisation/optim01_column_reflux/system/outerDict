/*---------------------------------------------------------------------------*\
  Minimise the reboiler vapour flow V_strip on the benzene/toluene
  column by tuning two design variables:
      * refluxRatio          continuous, [3.0, 5.0]
      * feedStage            integer-valued (but treated as continuous by
                              the simplex; the column code rounds to the
                              nearest stage internally if asked), [6, 12]

  V_strip is a proxy for the reboiler duty Q_reboiler (Q_reb = V·ΔHvap
  at near-saturated bottoms).  Less V_strip → less steam → less OPEX.

  The optimum sits at the LOWER bound of R (separation gets easier as
  R rises but V grows with R via V = (R+1)·D); the trade-off is the
  product purity floor.  In this tutorial we do not impose a purity
  constraint — the student observes that, without it, Nelder-Mead
  drives R to the floor (R = 3, V_strip = 0.0556 kmol/s).

  IMPORTANT — feedStage is an INACTIVE variable here.  With D fixed by
  the spec, the objective V_strip = (R+1)·D depends ONLY on R; feedStage
  does NOT enter it, so the simplex never converges feedStage to anything
  meaningful — it simply FLOATS (it drifts to ~9.8 in this run with no
  effect on fBest).  It is kept in the variable list to show that an
  optimiser will happily carry a variable the objective is insensitive
  to.  To make feedStage matter you would add a purity-penalty term to
  the objective (so the feed location changes the achievable purity) —
  left as an exercise / future v0.18 SQP wrapper.
\*---------------------------------------------------------------------------*/

type    optimization;
method  nelderMead;

variables
(
    {
        path     units[0].operation.refluxRatio;
        min      3.0;
        max      5.0;
        initial  4.0;
    }
    {
        path     units[0].operation.feedStage;
        min      6;
        max      12;
        initial  8;
    }
);

objective
{
    kind     kpi;
    path     column01.V_strip;
    sense    minimise;
}

options
{
    maxIter     80;
    tolX        5e-3;
    tolF        1e-4;
    simplexInit 0.15;
}

report
{
    file        optimization_history.csv;
}
