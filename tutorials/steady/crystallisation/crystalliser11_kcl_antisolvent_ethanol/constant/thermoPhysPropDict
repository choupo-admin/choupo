/*---------------------------------------------------------------------------*\
  thermoPhysPropDict (v2) -- T7 electrolyteGammaPhi: aqueous electrolyte
  (eNRTL) x ideal vapour; the REAL solid equilibrium rides in the inline
  chemistry{} block (TRANSITIONAL: the chemistryDict grammar is not ratified).
  KCl + ethanol (antisolvent) eNRTL -- drowning-out crystallisation.
  eNRTL pair resolved by cation-anion name: data/standards/parameters/eNRTL/K-Cl.dat
\*---------------------------------------------------------------------------*/

recordType    thermophysicalPropertySystem;
schemaVersion 2;

components ( water ethanol KCl );

equilibrium
{
    formulation electrolyteGammaPhi;    // aqueous electrolyte x ideal vapour

    aqueous
    {
        solvent            water;
        apparentComponents ( KCl );  // stream carries the salt; the model
                                        //   activates its ions (dissociatesTo)
        activityModel
        {
            model eNRTL;
        }
        compositionBasis molality;
    }

    vapour
    {
        fugacityModel idealGas;
    }
}

chemistry
{
    salts ( sylvite );                  // the active solid equilibrium: SLE via
}                                      //   the component's solidPhases{} Ksp

caloric
{
    energyBasis elementsDatum;          // ONE datum: the elements at 298.15 K

    aqueous
    {
        enthalpyRoute ionicReferencePlusExcess;   // aqueous inf-dilution ion
    }                                             //   datum + L_phi excess
    vapour
    {
        enthalpyRoute idealGasCp;
    }
}
