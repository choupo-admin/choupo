/*---------------------------------------------------------------------------*\
  constant/propertyDict -- the case's OWN thermodynamics, declared INLINE and
  SELF-CONTAINED.  No `package <name>;` selector, no installation-catalogue
  record: this manifest lives here, and the data it cites is frozen in
  constant/propertyData/ (materialised by bin/choupo-import).  The runtime resolves case-local data plus this case snapshot and NEVER
  falls back to the installation catalogue.

  KCl is the electrolyte component (eNRTL ion-activity Ksp); KHT crystallises off
  its molecular solubility curve; ethanol is the antisolvent.  Grammar: models
  per PHASE, conventions per GROUP, parameters per PAIR (all cited).
\*---------------------------------------------------------------------------*/

components      ( water ethanol KCl potassiumBitartrate );

chemistry
{
    salts ( sylvite );
    activeSaltEquilibriumData
    {
        sylvite measuredSolubilityAnchor;
    }
}

propertyMethods
{
    liquid  electrolyte.eNRTL;
    vapour  builtin.idealGas;
    solid   builtin.saltEquilibrium;
}
