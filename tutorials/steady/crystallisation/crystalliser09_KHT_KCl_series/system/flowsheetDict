/*---------------------------------------------------------------------------*\
  crystalliser09_KHT_KCl_series  --  SELECTIVE crystallisation of two salts

      feed (hot: KCl + KHT) ──► [cryst1: COOL to 5 C] ──┬──► KHT_cake   (cream of tartar)
                                                         │
                                  liquor1 (KCl-rich) ────┘
                                       │
                ethanol ──────────────►[cryst2: ANTISOLVENT] ──┬──► KCl_cake
                                                                │
                                  finalLiquor (EtOH+water+salt) ┘
                                       │
                                       ▼
                            [recovery: DISTILLATION] ──┬──► recoveredEthanol (recycle-grade)
                                                       │
                                                       └──► stillage (water + residual salt)

  Two salts with very different solubilities are separated by two DIFFERENT
  levers, each crystalliser targeting one salt (`solute ...`):

  * CRYST1 cools the hot feed.  Potassium bitartrate (KHT) is sparingly soluble
    with a STEEP solubility curve, so cooling 50 -> 5 C precipitates most of it;
    KCl, far more soluble and only mildly T-sensitive, stays dissolved.  KHT's
    saturation is its measured solubility CURVE c_sat(T) -- no ion parameters.

  * CRYST2 doses ethanol into the KCl-rich mother liquor.  KCl drops out by
    drowning-out: the eNRTL mixed-solvent term raises gamma_pm as the dielectric
    falls, collapsing m_sat.  KCl's saturation is the ion-activity Ksp.

  The SAME package carries both routes; `useElec` is decided per solute, so KHT
  uses its curve while KCl uses the eNRTL.  Self-DESCRIBING (inline
  manifest); curated records resolve from data/standards/ at runtime.

  Basis (per kg water): 55.5 water, 3.0 KCl (below the 5 C saturation ~3.9), and
  0.078 KHT (saturated at 50 C).
\*---------------------------------------------------------------------------*/

// stream state lives on disk in 0/ (per-stream files); flowsheetDict is TOPOLOGY only

tearStreams      ( recoveredEthanol );          // close the antisolvent loop
recycleSolver     Newton;                       // Newton on the tear variables
recycleTol        1e-5;
recycleMaxIter    150;
recycleWegsteinQmin  0.0;                        // gentle (phase-changing recycle): no acceleration
recycleWegsteinQmax  0.0;

units
(
    {
        name        cryst1;                      // COOLING crystalliser -> KHT
        type        crystalliser;
        in          feed;
        outputs     ( KHT_cake  liquor1 );

        operation
        {
            operatingTemperature 278.15 K;       // cool to 5 C
            solute               potassiumBitartrate;   // target KHT (its solubility curve)
            cakeMoisture         0.10;
        }
    }

    {
        name        cryst2;                      // ANTISOLVENT crystalliser -> KCl
        type        crystalliser;
        inputs      ( liquor1  freshEthanol  recoveredEthanol );  // liquor + make-up + RECYCLE
        outputs     ( KCl_cake  finalLiquor );

        operation
        {
            operatingTemperature 278.15 K;       // stay cold
            solute               KCl;            // target KCl (the eNRTL ion-activity)
            cakeMoisture         0.10;
            dHcryst              0.0;             // KCl crystallisation heat (neglected)
        }
    }

    {
        name        recovery;                    // recover the antisolvent for recycle
        type        distillationColumn;
        model       simultaneous;                // ethanol-water azeotrope -> MESH Newton
        in          finalLiquor;                 // EtOH + water + residual salt (non-volatile)
        outputs     ( recoveredEthanol  stillage );

        operation
        {
            nStages          20;
            feedStage        10;
            refluxRatio      2.0;
            distillateRate   85.0 kmol/h;        // ~ the ethanol fed (79.6) + azeotropic water
            feedQuality      1.0;                // treat the 5 C liquor as saturated liquid
            P                1.01325 bar;
        }

        // MODEL BOUNDARY (deliberate): the package's eNRTL is for the SALT and
        // treats ethanol-water as ideal -- it has no ethanol-water azeotrope.  A
        // distillation that ignored the azeotrope would lie.  So this column
        // OVERRIDES the activity model to NRTL (ethanol-water), capping the
        // distillate at the azeotrope; the salts, with no NRTL pair, stay ideal
        // and nonvolatile -> the bottoms.  (The crystallisers keep eNRTL.)
        thermo
        {
            activityModel { model NRTL; }
        }
    }
);
