{
  "name": "choupo-gui",
  "version": "0.1.0",
  "private": true,
  "description": "Web GUI for Choupo (GPL-3.0-or-later)",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "predev": "node scripts/copyDocs.mjs",
    "dev": "vite",
    "bridge": "node bridge/claudeBridge.mjs",
    "prebuild": "node scripts/generateThirdPartyNotices.mjs && node scripts/copyDocs.mjs",
    "build": "tsc -p tsconfig.json --noEmit && node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mantine/core": "^7.13.0",
    "@mantine/hooks": "^7.13.0",
    "@mantine/notifications": "^7.13.0",
    "@tabler/icons-react": "^3.17.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.3.0",
    "fflate": "^0.8.3",
    "plotly.js-basic-dist-min": "^2.35.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plotly.js": "^2.6.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/react-plotly.js": "^2.6.3",
    "@vitejs/plugin-react": "^4.3.1",
    "node-pty": "^1.0.0",
    "postcss": "^8.4.45",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0",
    "ws": "^8.18.0"
  }
}
