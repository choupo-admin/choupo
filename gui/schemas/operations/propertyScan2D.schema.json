{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://choupo.org/schemas/operations/propertyScan2D.schema.json",
  "title": "propertyScan2D operation",
  "description": "Two-dimensional property sweep: varies two state variables on a regular grid and evaluates each property at every node. Writes one CSV row per node; failed evaluations are written as NaN.",
  "type": "object",
  "properties": {
    "varyX": {
      "type": "object",
      "title": "X axis",
      "properties": {
        "variable": { "type": "string", "title": "Axis variable (T, P, x[<comp>])" },
        "from":     { "type": "number", "title": "Lower bound" },
        "to":       { "type": "number", "title": "Upper bound" },
        "n":        { "type": "integer", "minimum": 2, "title": "Number of points" }
      },
      "required": ["variable", "from", "to", "n"]
    },
    "varyY": {
      "type": "object",
      "title": "Y axis",
      "properties": {
        "variable": { "type": "string", "title": "Axis variable" },
        "from":     { "type": "number" },
        "to":       { "type": "number" },
        "n":        { "type": "integer", "minimum": 2 }
      },
      "required": ["variable", "from", "to", "n"]
    },
    "state": {
      "type": "object",
      "title": "Held state",
      "description": "State values held fixed across the grid, typically the composition."
    },
    "properties": {
      "type": "array",
      "title": "Properties to evaluate",
      "items": { "type": "string" },
      "minItems": 1
    },
    "output": {
      "type": "object",
      "title": "Output file",
      "properties": {
        "file": { "type": "string", "title": "CSV filename" }
      },
      "required": ["file"]
    }
  },
  "required": ["varyX", "varyY", "properties", "output"],
  "additionalProperties": true
}
