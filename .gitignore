docs/theoryGuide.*
!docs/theoryGuide.tex
!docs/theoryGuide.pdf
bin/curate/refs/

__pycache__/
*.pyc
docs/*.fls
docs/*.fdb_latexmk

# Third-party combustion mechanisms (GRI/DRM/LLNL etc.) are all-rights-reserved;
# kept LOCAL for curation. Only primary-transcribed, licence-clear mechanisms
# may be committed. See data/proposed/mechanisms/INDEX.md.
data/proposed/mechanisms/

# Per-case literature/ folders hold the USER's own supplied papers (copyright
# material, sourced and owned by the user -- their responsibility) -- never commit
# the files. The suggested reference LIST (literature/README.md) is plain text and
# stays versioned, so a case documents what it was built from without shipping PDFs.
**/literature/*
!**/literature/README.md
*.kate-swp
.*.kate-swp

# Session artifacts (not for the public repo)
data.zip
V1_READINESS_REPORT.md
gui/tests/_*.test.ts

# third-party reference originals (import sources; see thirdParty/README.md)
thirdParty/*
!thirdParty/README.md
!thirdParty/chemsep/
thirdParty/chemsep/*
!thirdParty/chemsep/pcd/
thirdParty/chemsep/pcd/*
!thirdParty/chemsep/pcd/Artistic_license_2_0.txt

# stream-state outputs (regenerated by the solver); 0/ is committable state
converged/
iterations/
**/converged/
**/iterations/

# F3: projected local unit runs (regenerable artifacts, never authored state)
**/.runs/

# Dignified-unit LOCAL stream views (regenerable projections of the plant
# solution / local re-runs; NOT versioned -- the tutorial ships without them and
# `runCase` on the plant materialises them).  A unit's system/ + constant/ ARE
# versioned; only these generated artifacts are ignored.  The PLANT's own 0/
# (case-root) stays committable -- these rules are scoped to unitOperations/*/.
unitOperations/*/0/
unitOperations/*/converged/
unitOperations/*/iterations/
unitOperations/*/runInfo
unitOperations/*/log.choupoSolve
unitOperations/*/.runs/
**/unitOperations/*/0/
**/unitOperations/*/converged/
**/unitOperations/*/iterations/
**/unitOperations/*/runInfo
**/unitOperations/*/log.choupoSolve

# Isolated external-tool installs under .tools/ (no system packages).
.tools/
# Private local-only external-tool interop (kept on disk, never uploaded).
bin/dwsim-runner/
# the landing's own brand/hero assets are TRACKED source assets (the page
# must be self-contained; never rely on the GUI build shipping them)
!site/logo2-mark.png
!site/logo2.png
# Literature/ holds third-party papers (copyrighted PDFs) for PRIVATE reference
# only -- NEVER tracked, NEVER published (Vitor, forum 135.3).
/Literature/

# data/local/ -- the PRIVATE working tier: imported/licensed/unverified data
# (ChemSep pairs, CoolProp components, mechanisms, fit proposals).  NEVER
# public.  The repo ships this directory EMPTY (README + .gitkeep only); the
# runtime reads it when present (search: case > standards > local > ideal).
/data/local/*
!/data/local/README.md
!/data/local/.gitkeep
